@page "/commissioner"
@attribute [Authorize(Policy = Policies.CommissionerOrAbove)]

<PageTitle>Commissioner</PageTitle>

<div class="container mt-5">
    <div class="alert alert-info">
        <h3><span class="bi bi-people-fill"></span> Commissioner Area</h3>
        <p><strong>Access Level:</strong> Commissioner and Above (Admin, FNSB User, Commissioner)</p>
    </div>

    <h4>Welcome, Commissioner!</h4>
    <p>This page is accessible to users with <strong>commissioner</strong>, <strong>fnsbuser</strong>, or <strong>admin</strong> roles.</p>

    <div class="card mt-4">
        <div class="card-header">
            <h5>Commissioner Capabilities</h5>
        </div>
        <div class="card-body">
            <ul>
                <li>Review and approve requests</li>
                <li>Policy oversight</li>
                <li>Commission meetings</li>
                <li>All lower-level permissions</li>
            </ul>
        </div>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="mt-4">
                <p><strong>Your Email:</strong> @context.User.Identity?.Name</p>
                <p><strong>Your Roles:</strong> @string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))</p>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

@code {

}
