    private async Task<IEnumerable<PersonProfile>> SearchPersonProfiles(string searchString, CancellationToken cancellationToken)
    {
        if (personProfiles == null) return Array.Empty<PersonProfile>();

        await Task.Delay(0, cancellationToken); // Prevent warning about async method

        if (string.IsNullOrWhiteSpace(searchString))
        {
            return personProfiles
                .OrderBy(p => p.LastName)
                .ThenBy(p => p.FirstName)
                .Take(50);
        }

        searchString = searchString.ToLowerInvariant();

        return personProfiles
            .Where(p => GetPersonName(p.Id).ToLowerInvariant().Contains(searchString))
            .OrderBy(p => p.LastName)
            .ThenBy(p => p.FirstName)
            .Take(50);
    }

    private async Task<IEnumerable<CommissionSeat>> SearchCommissionSeats(string searchString, CancellationToken cancellationToken)
    {
        var orderedSeats = GetOrderedCommissionSeatsForCreate();
        if (orderedSeats == null) return Array.Empty<CommissionSeat>();

        await Task.Delay(0, cancellationToken); // Prevent warning about async method

        if (string.IsNullOrWhiteSpace(searchString))
        {
            return orderedSeats.Take(50);
        }

        searchString = searchString.ToLowerInvariant();

        return orderedSeats
            .Where(seat =>
            {
                var displayText = GetCommissionSeatWithServiceAreaDisplayText(seat).ToLowerInvariant();
                return displayText.Contains(searchString);
            })
            .Take(50);
    }

    private async Task<(bool Success, string? ErrorMessage, string[]? ErrorDetails)> CreateCommissionerProfile(CommissionerProfile entity)
    {
        try
        {
            var result = await CommissionerProfilesApi.CreateCommissionerProfileAsync(entity);

            if (result?.IsSuccess == true && result.Data != null)
            {
                // Update the entity with the returned data (which includes the ID)
                entity.Id = result.Data.Id;
                entity.ValidFrom = result.Data.ValidFrom;

                return (true, null, null);
            }
            else
            {
                return (false, result?.ErrorMessage ?? "Failed to create commissioner profile", result?.Errors);
            }
        }
        catch (Exception ex)
        {
            return (false, $"Error creating commissioner profile: {ex.Message}", null);
        }
    }

    private bool QuickFilterCommissioners(PersonProfile person, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        searchString = searchString.ToLowerInvariant();

        // Search in person name
        var personName = GetPersonName(person.Id).ToLowerInvariant();
        if (personName.Contains(searchString))
            return true;

        // Get the most recent commissioner profile for this person
        var profile = GetMostRecentCommissionerProfile(person.Id);
        if (profile == null)
            return false;

        // Search in seat type
        var seat = commissionSeats?.FirstOrDefault(s => s.Id == profile.CommissionSeatId);
        if (seat != null)
        {
            var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
            if (seatType?.Type?.ToLowerInvariant().Contains(searchString) == true)
                return true;

            var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);
            if (seatClass?.Class?.ToLowerInvariant().Contains(searchString) == true)
                return true;

            var serviceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == seat.ServiceAreaId);
            if (serviceArea?.Name?.ToLowerInvariant().Contains(searchString) == true)
                return true;
        }

        // Search in status
        var status = commissionerStatuses?.FirstOrDefault(s => s.Id == profile.CommissionerStatusId);
        if (status?.Status?.ToLowerInvariant().Contains(searchString) == true)
            return true;

        // Search for "active" or "inactive"
        var isActive = HasActiveProfile(person.Id);
        if (isActive && "active".ToUpper().Equals(searchString.ToUpper()))
            return true;
        if (!isActive && "inactive".ToUpper().Equals(searchString.ToUpper()))
            return true;

        return false;
    }
