    private async Task LoadOtherProfilesForPerson()
    {
        if (selectedCommissioner == null) return;

        isLoadingOtherProfiles = true;

        try
        {
            otherProfilesForPerson = commissionerProfiles?
                .Where(cp => cp.PersonProfileId == selectedCommissioner.PersonProfileId && cp.Id != selectedCommissioner.Id)
                .OrderByDescending(cp => cp.AppointedDate)
                .ToList();
        }
        catch (Exception)
        {
            otherProfilesForPerson = Array.Empty<CommissionerProfile>();
        }
        finally
        {
            isLoadingOtherProfiles = false;
        }
    }

    private IEnumerable<CorrespondenceProfile>? GetCorrespondenceProfiles()
    {
        if (selectedCommissioner == null) return null;

        var profiles = correspondenceProfiles?
            .Where(cp => cp.CommissionerProfileId == selectedCommissioner.Id);

        if (!isEditor)
        {
            // Only show public profiles for non-editors
            profiles = profiles?.Where(cp => cp.PublicProfile == true);
        }

        return profiles?.ToList();
    }

    private async Task LoadAllVersions()
    {
        if (selectedCommissioner == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        try
        {
            var historyResult = await CommissionerProfilesApi.GetCommissionerProfileHistoryAsync(selectedCommissioner.Id);
            var historyRecords = new List<CommissionerProfile>();

            if (historyResult?.IsSuccess == true && historyResult.Data != null)
            {
                historyRecords.AddRange(historyResult.Data);
            }

            var versions = new List<CommissionerProfile> { selectedCommissioner };
            versions.AddRange(historyRecords.Where(h => h.ValidFrom != selectedCommissioner.ValidFrom));
            
            allVersions = versions;
            currentViewVersion = selectedCommissioner;
            UpdateEditModel(currentViewVersion);

            // Load related data
            await LoadOtherProfilesForPerson();
        }
        catch (Exception ex)
        {
            historyErrorMessage = $"Error loading versions: {ex.Message}";
            allVersions = new List<CommissionerProfile> { selectedCommissioner };
            currentViewVersion = selectedCommissioner;
            UpdateEditModel(currentViewVersion);
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private async Task OnCurrentVersionChanged(CommissionerProfile newVersion)
