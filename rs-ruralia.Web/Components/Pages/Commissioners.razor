        var personName = person != null ? GetPersonName(person.Id) : "Commissioner";

        await NotesHelper.PromptForEditNoteAsync(
            DialogService,
            $"{personName} - Commissioner Profile",
            (count) => { /* Note count handled per profile */ },
            async (id, text) => await CreateEditNote(id, text, userEmail),
            entityId,
            userEmail);
