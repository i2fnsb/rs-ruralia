    private void UpdateEditModel(CommissionerProfile version)
    {
        editModel = CloneCommissioner(version);
        editContext = new EditContext(editModel);
        
        if (!IsViewingCurrentVersion())
        {
            isEditMode = false;
        }
    }

    private bool IsViewingCurrentVersion()
    {
        if (currentViewVersion == null || selectedCommissioner == null)
            return true;

        return currentViewVersion.ValidFrom == selectedCommissioner.ValidFrom;
    }

    private bool CanEditFields()
    {
        return isEditMode && IsViewingCurrentVersion();
    }

    private async Task HandleItemClick(CommissionerProfile item)
    {
        selectedCommissioner = item;
        isEditMode = false;
        ClearMessages();
        await LoadAllVersions();
        await InvokeAsync(StateHasChanged);

        var uri = NavigationManager.GetUriWithQueryParameter("id", selectedCommissioner.Id);
        NavigationManager.NavigateTo(uri, replace: true);
    }

    private async Task HandleRestore(CommissionerProfile historicalRecord)
    {
        if (selectedCommissioner == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var restoredData = CloneCommissioner(historicalRecord);
            restoredData.Id = selectedCommissioner.Id;

            var result = await CommissionerProfilesApi.UpdateCommissionerProfileAsync(restoredData.Id, restoredData);

            if (result?.IsSuccess == true)
            {
                successMessage = $"Successfully restored version from {historicalRecord.ValidFrom:g}";
                
                await LoadCommissionerProfiles();
                
                selectedCommissioner = commissionerProfiles?.FirstOrDefault(c => c.Id == selectedCommissioner.Id);
                if (selectedCommissioner != null)
                {
                    await LoadAllVersions();
                }
                
                isEditMode = false;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to restore historical version";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error restoring historical version: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void EnableEdit()
    {
        if (!IsViewingCurrentVersion())
        {
            if (selectedCommissioner != null)
            {
                currentViewVersion = selectedCommissioner;
                UpdateEditModel(currentViewVersion);
            }
        }
        
        isEditMode = true;
        ClearMessages();
    }

    private async Task SaveEdit()
    {
        if (editModel == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userEmail = user.Identity?.Name ?? user.Claims.FirstOrDefault(c => c.Type.Contains("email"))?.Value;

            if (!string.IsNullOrEmpty(userEmail))
            {
                editModel.ModifiedBy = userEmail;
            }

            var result = await CommissionerProfilesApi.UpdateCommissionerProfileAsync(editModel.Id, editModel);

            if (result?.IsSuccess == true)
            {
                successMessage = "Commissioner profile updated successfully!";
                isEditMode = false;

                await LoadCommissionerProfiles();
                selectedCommissioner = commissionerProfiles?.FirstOrDefault(c => c.Id == editModel.Id);

                if (selectedCommissioner != null)
                {
                    await LoadAllVersions();
                }
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to update commissioner profile";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating commissioner profile: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelEdit()
    {
        if (currentViewVersion != null)
        {
            editModel = CloneCommissioner(currentViewVersion);
            editContext = new EditContext(editModel);
        }
        isEditMode = false;
        ClearMessages();
    }

    private void ClearMessages()
    {
        errorMessage = null;
        errorDetails = null;
        successMessage = null;
    }

    private CommissionerProfile CloneCommissioner(CommissionerProfile source) => new()
    {
        Id = source.Id,
        PersonProfileId = source.PersonProfileId,
        CommissionSeatId = source.CommissionSeatId,
        CommissionerStatusId = source.CommissionerStatusId,
        AppointedDate = source.AppointedDate,
        EndDate = source.EndDate,
        Oath = source.Oath,
        ValidFrom = source.ValidFrom,
        ValidTo = source.ValidTo,
        ModifiedBy = source.ModifiedBy
    };

    private string GetPersonName(int personProfileId)
    {
        var person = personProfiles?.FirstOrDefault(p => p.Id == personProfileId);
        if (person == null) return $"Person ID: {personProfileId}";

        var nameParts = new List<string>();

        if (person.PersonHonorificId.HasValue)
        {
            var honorific = personHonorifics?.FirstOrDefault(h => h.Id == person.PersonHonorificId);
            if (!string.IsNullOrEmpty(honorific?.Honorific))
                nameParts.Add(honorific.Honorific);
        }

        if (!string.IsNullOrEmpty(person.FirstName))
            nameParts.Add(person.FirstName);

        if (!string.IsNullOrEmpty(person.PreferredName))
            nameParts.Add($"\"{person.PreferredName}\"");

        if (!string.IsNullOrEmpty(person.LastName))
            nameParts.Add(person.LastName);

        if (person.PersonSuffixId.HasValue)
        {
            var suffix = personSuffixes?.FirstOrDefault(s => s.Id == person.PersonSuffixId);
            if (!string.IsNullOrEmpty(suffix?.Suffix))
                nameParts.Add(suffix.Suffix);
        }

        return nameParts.Any() ? string.Join(" ", nameParts) : $"Person ID: {personProfileId}";
    }

    private string GetCommissionSeatDisplayText(CommissionSeat? seat)
    {
        if (seat == null) return "—";

        var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
        var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);

        return $"{seatType?.Type ?? "Unknown"} - {seatClass?.Class ?? "Unknown"}";
    }

    private string GetCommissionerStatusDisplayText(CommissionerStatus commissionerStatus)
    {
        if (commissionerStatus == null) return "—";
        return commissionerStatus.Status ?? "—";
    }

    private string GetCommissionerStatusDisplayText(int? commissionerStatusId)
    {
        if (!commissionerStatusId.HasValue) return "—";

        var status = commissionerStatuses?.FirstOrDefault(s => s.Id == commissionerStatusId.Value);
        return status?.Status ?? "—";
    }

    private string GetCommissionerDisplayText(CommissionerProfile commissioner)
    {
        var personName = GetPersonName(commissioner.PersonProfileId);
        var seat = commissionSeats?.FirstOrDefault(s => s.Id == commissioner.CommissionSeatId);
        var seatType = seat != null ? commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId) : null;
        
        return $"{personName} - {seatType?.Type ?? "Unknown Seat"}";
    }

