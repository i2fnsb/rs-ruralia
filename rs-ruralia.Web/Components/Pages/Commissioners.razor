    private async Task CreateEditNote(int profileId, string noteText, string? userEmail)
    {
        var note = NotesHelper.CreateCommissionerProfileNote(profileId, noteText, userEmail);

        await NotesHelper.CreateNoteAsync(
            note,
            NotesApi.CreateNoteAsync,
            () =>
            {
                // Increment refresh key to force NotesPanel to reload
                if (notesPanelRefreshKeys.ContainsKey(profileId))
                {
                    notesPanelRefreshKeys[profileId]++;
                }
                else
                {
                    notesPanelRefreshKeys[profileId] = 1;
                }
                InvokeAsync(StateHasChanged);
            });
    }

    private int? GetServiceAreaForProfile(int profileId)
    {
        // Check if we have a selected service area for this profile during editing
        if (selectedServiceAreaByProfile.TryGetValue(profileId, out var serviceAreaId) && serviceAreaId.HasValue)
        {
            return serviceAreaId;
        }

        // Otherwise, get it from the current commission seat
        if (editModel != null && editModel.Id == profileId)
        {
            var seat = commissionSeats?.FirstOrDefault(s => s.Id == editModel.CommissionSeatId);
            return seat?.ServiceAreaId;
        }

        return null;
    }

    private void OnServiceAreaChanged(int profileId, int? serviceAreaId)
    {
        selectedServiceAreaByProfile[profileId] = serviceAreaId;

        // Clear the commission seat selection when service area changes
        if (editModel != null && editModel.Id == profileId)
        {
            var currentSeat = commissionSeats?.FirstOrDefault(s => s.Id == editModel.CommissionSeatId);
            if (currentSeat?.ServiceAreaId != serviceAreaId)
            {
                // Reset to first available seat in the new service area
                var firstSeatInArea = commissionSeats?
                    .Where(s => s.ServiceAreaId == serviceAreaId)
                    .OrderBy(s => s.Id)
                    .FirstOrDefault();

                if (firstSeatInArea != null)
                {
                    editModel.CommissionSeatId = firstSeatInArea.Id;
                }
            }
        }

        StateHasChanged();
    }

    private IEnumerable<CommissionSeat>? GetFilteredCommissionSeatsForEdit(int profileId)
    {
        if (commissionSeats == null) return Array.Empty<CommissionSeat>();

        var serviceAreaId = GetServiceAreaForProfile(profileId);

        if (serviceAreaId.HasValue)
        {
            return commissionSeats
                .Where(s => s.ServiceAreaId == serviceAreaId.Value)
                .OrderBy(s => s.Id)
                .ToList();
        }

        // If no service area selected, return all seats
        return commissionSeats;
    }

    private IEnumerable<CommissionSeat>? GetOrderedCommissionSeatsForCreate()
    {
        if (commissionSeats == null) return Array.Empty<CommissionSeat>();

        // Filter out seats with class "UKN"
        var filteredSeats = commissionSeats.Where(seat =>
        {
            var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);
            return seatClass?.Class?.Equals("UKN", StringComparison.OrdinalIgnoreCase) != true;
        });

        // Order by service area name, then by seat type, then by seat class
        return filteredSeats
            .OrderBy(seat =>
            {
                var serviceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == seat.ServiceAreaId);
                return serviceArea?.Name ?? string.Empty;
            })
            .ThenBy(seat =>
            {
                var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
                return seatType?.Type ?? string.Empty;
            })
            .ThenBy(seat =>
            {
                var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);
                return seatClass?.Class ?? string.Empty;
            })
            .ToList();
    }

