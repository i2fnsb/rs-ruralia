@page "/commissioners"
@rendermode InteractiveServer 
@implements IDisposable
@using rs_ruralia.Shared.Enums
@using rs_ruralia.Web.Components.Dialogs
@using rs_ruralia.Web.Helpers
@inject CommissionerProfilesApiClient CommissionerProfilesApi
@inject CommissionerStatusesApiClient CommissionerStatusesApi
@inject CommissionSeatsApiClient CommissionSeatsApi
@inject CommissionSeatTypesApiClient CommissionSeatTypesApi
@inject CommissionSeatClassesApiClient CommissionSeatClassesApi
@inject CommissionSeatStatusesApiClient CommissionSeatStatusesApi
@inject ServiceAreasApiClient ServiceAreasApi
@inject PersonProfilesApiClient PersonProfilesApi
@inject PersonHonorificsApiClient PersonHonorificsApi
@inject PersonSuffixesApiClient PersonSuffixesApi
@inject CorrespondenceProfilesApiClient CorrespondenceProfilesApi
@inject CorrespondenceEmailsApiClient CorrespondenceEmailsApi
@inject CorrespondencePhonesApiClient CorrespondencePhonesApi
@inject NotesApiClient NotesApi
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDialogService DialogService
@inject ViewModeService ViewModeService

<EntityManagementLayout TEntity="PersonProfile"
                       Title="Commissioners"
                       Subtitle="Manage commissioner profiles, seats, and correspondence"
                       Icon="@Icons.Material.Filled.Groups"
                       ShowViewModeSelector="true"
                       ListTitle="Commissioner Profiles"
                       ListIcon="@Icons.Material.Filled.Person"
                       SearchPlaceholder="Search commissioners..."
                       ShowSearch="true"
                       SearchString="@_searchString"
                       CustomQuickFilter="@QuickFilterCommissioners"
                       ShowTotalCount="true"
                       TotalCount="@(GetPeopleWithCommissionerProfiles()?.Count())"
                       CountIcon="@Icons.Material.Filled.Groups"
                       HasSelection="@(selectedPerson != null)"
                       EntitySingularName="Commissioner"
                       EntityPluralName="commissioners"
                       EnableViewModeManagement="true"
                       EnableEditPermissionCheck="true"
                       CanEditChanged="@(async (canEdit) => { this.canEdit = canEdit; await InvokeAsync(StateHasChanged); })"
                       IsEditorChanged="@(async (editor) => { this.isEditor = editor; await InvokeAsync(StateHasChanged); })"
                       OnEditModeCancelled="@HandleEditModeCancelled"
                       SelectedItem="@selectedPerson"
                       GetSelectedItemDisplayText="@GetPersonDisplayText"
                       ShowSelectedItemChip="true"
                       ShowCreateButton="true"
                       CreateButtonTitle="Create New Commissioner Profile"
                       OnCreateClicked="@OpenCreateDialog"
                       UseBuiltInDataGrid="true"
                       IsLoadingItems="@isLoading"
                       Items="@GetPeopleWithCommissionerProfiles()"
                       OnItemClicked="@(async (item) => await HandleItemClick(item))"
                       GetItemIcon="@(c => Icons.Material.Filled.Person)"
                       GetItemDisplayText="@GetPersonDisplayText">

    <AdditionalItemColumns>
        <TemplateColumn T="PersonProfile" Title="Seat" Sortable="true">
            <CellTemplate>
                @{
                    var personProfile = GetMostRecentCommissionerProfile(context.Item.Id);
                    var seat = personProfile != null ? commissionSeats?.FirstOrDefault(s => s.Id == personProfile.CommissionSeatId) : null;
                    var seatType = seat != null ? commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId) : null;
                    var seatDisplay = seatType != null
                        ? $"{seatType.Type}" 
                        : "—";
                }
                <MudText Typo="Typo.body2">@seatDisplay</MudText>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="PersonProfile" Title="Status" Sortable="true">
            <CellTemplate>
                @{
                    var hasActiveProfile = HasActiveProfile(context.Item.Id);
                }
                @if (hasActiveProfile)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Check">Active</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Circle">Inactive</MudChip>
                }
            </CellTemplate>
        </TemplateColumn>
    </AdditionalItemColumns>

    <!-- Detail Content (Expandable Sections) -->
    <DetailContent>
        @if (selectedPerson != null && allProfilesForPerson != null)
        {
            <MudExpansionPanels MultiExpansion="true">
                @foreach (var profile in allProfilesForPerson)
                {
                    var displayData = profileDisplayCache.TryGetValue(profile.Id, out var data) ? data : null;
                    var seat = displayData?.Seat;
                    var seatType = displayData?.SeatType;
                    var seatClass = displayData?.SeatClass;
                    var serviceArea = displayData?.ServiceArea;
                    var status = displayData?.Status;
                    var isActive = displayData?.IsActive ?? false;
                    var isCurrent = displayData?.IsCurrent ?? false;
                    var isFirstProfile = allProfilesForPerson.First() == profile;

                    <SectionPanel @key="profile.Id"
                                 Title="@($"{seatType?.Type} - {seatClass?.Class} ({serviceArea?.Name})")"
                                 Icon="@Icons.Material.Filled.AccountBox"
                                 Expanded="@isFirstProfile"
                                 MinimumViewMode="ViewMode.Public">
                        <MudStack Row="true" Spacing="1">
                            <MudChip T="string" 
                                    Size="Size.Small" 
                                    Color="@(isActive ? Color.Success : Color.Default)"
                                    Icon="@(isActive ? Icons.Material.Filled.Check : Icons.Material.Filled.Circle)">
                                @(status?.Status ?? "Unknown")
                            </MudChip>
                            @if (isCurrent)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Current</MudChip>
                            }
                        </MudStack>

                        <MudExpansionPanels MultiExpansion="true">
                            <!-- Profile Details Section -->
                            <SectionPanel Title="Profile Details"
                                         Icon="@Icons.Material.Filled.Person"
                                         Expanded="true"
                                         MinimumViewMode="ViewMode.Public">
                                @{
                                    var profileVersions = GetAllVersionsOfProfile(profile);
                                    var displayVersion = currentlyDisplayedVersions.TryGetValue(profile.Id, out var tracked) ? tracked : profile;
                                }
                                <VersionedDetailsPanel TEntity="CommissionerProfile"
                                   AllVersions="@profileVersions"
                                   CurrentVersion="@displayVersion"
                                   CurrentVersionChanged="@((v) => HandleVersionChanged(profile.Id, v))"
                                   GetValidFrom="@(x => x.ValidFrom)"
                                   GetValidTo="@(x => x.ValidTo)"
                                   GetModifiedBy="@(x => x.ModifiedBy)"
                                   GetDisplayText="@GetCommissionerDisplayText"
                                   CanEdit="@(canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))"
                                   IsEditMode="@(editingProfileId == profile.Id)"
                                   OnEditClicked="@(() => EnableEditForProfile(profile.Id))"
                                   IsLoading="false"
                                   ErrorMessage="@null"
                                   OnRestore="@(async (historicalVersion) => await HandleRestoreVersion(profile.Id, historicalVersion))">

                                    <!-- Edit Mode Content -->
                                    <DetailsContent Context="version">
                                        @if (editingProfileId == profile.Id && editModel != null && editModel.Id == profile.Id)
                                        {
                                            <EditForm EditContext="@editContext" OnValidSubmit="@(() => SaveProfileEdit(profile.Id))">
                                                <DataAnnotationsValidator />
                                                <MudGrid>
                                                    @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
                                                    {
                                                        <MudItem xs="12">
                                                            <SaveCancelButtons IsSaving="@isSaving" OnCancel="@CancelEdit" />
                                                        </MudItem>
                                                    }

                                                    <AlertMessages SuccessMessage="@successMessage" 
                                                                  ErrorMessage="@errorMessage" 
                                                                  ErrorDetails="@errorDetails" />

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.PersonProfileId" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="int"
                                                                   TLookup="PersonProfile"
                                                                   Property="@(x => x.PersonProfileId)"
                                                                   ReadOnly="true"
                                                                   LookupItems="@personProfiles"
                                                                   LookupTextSelector="@(item => GetPersonName(((PersonProfile)item).Id))"
                                                                   For="@(() => editModel.PersonProfileId)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">Service Area</MudText>
                                                        <MudText Typo="Typo.body2">@(serviceArea?.Name ?? "—")</MudText>
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.CommissionSeatId" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="int"
                                                                   TLookup="CommissionSeat"
                                                                   Property="@(x => x.CommissionSeatId)"
                                                                   ReadOnly="false"
                                                                   LookupItems="@GetFilteredCommissionSeatsForEdit(profile.Id)"
                                                                   LookupTextSelector="@(item => GetCommissionSeatDisplayText((CommissionSeat)item))"
                                                                   ForeignKeyIdSelector="@(x => x.Id)"
                                                                   ForeignKeyNameSelector="@(x => GetCommissionSeatDisplayText(x))"
                                                                   ForeignKeyDescriptionSelector="@(x => $"Term: {x.TermStartDate?.ToString("MMM yyyy")} - {x.TermEndDate?.ToString("MMM yyyy")}")"
                                                                   OnForeignKeyCreate="@CreateCommissionSeat"
                                                                   OnForeignKeyUpdate="@UpdateCommissionSeat"
                                                                   OnForeignKeyDelete="@DeleteCommissionSeat"
                                                                   OnForeignKeyDataChanged="@(EventCallback.Factory.Create(this, LoadCommissionSeats))"
                                                                   ForeignKeyDialogTitle="Manage Commission Seats"
                                                                   For="@(() => editModel.CommissionSeatId)">
                                                            <ForeignKeyFormContent Context="entity">
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.ServiceAreaId" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="int"
                                                                               TLookup="ServiceArea"
                                                                               ReadOnly
                                                                               Property="@(x => x.ServiceAreaId)"
                                                                               LookupItems="@serviceAreas"
                                                                               LookupTextSelector="@(item => ((ServiceArea)item).Name ?? string.Empty)"
                                                                               For="@(() => entity.ServiceAreaId)" />
                                                                </MudItem>
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.CommissionSeatTypeId" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="int"
                                                                               TLookup="CommissionSeatType"
                                                                               ReadOnly
                                                                               Property="@(x => x.CommissionSeatTypeId)"
                                                                               LookupItems="@commissionSeatTypes"
                                                                               LookupTextSelector="@(item => ((CommissionSeatType)item).Type ?? string.Empty)"
                                                                               For="@(() => entity.CommissionSeatTypeId)" />
                                                                </MudItem>
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.CommissionSeatClassId" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="int"
                                                                               TLookup="CommissionSeatClass"
                                                                               ReadOnly
                                                                               Property="@(x => x.CommissionSeatClassId)"
                                                                               LookupItems="@commissionSeatClasses"
                                                                               LookupTextSelector="@(item => ((CommissionSeatClass)item).Class ?? string.Empty)"
                                                                               For="@(() => entity.CommissionSeatClassId)" />
                                                                </MudItem>
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.CommissionSeatStatusId" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="int"
                                                                               TLookup="CommissionSeatStatus"
                                                                               Property="@(x => x.CommissionSeatStatusId)"
                                                                               ReadOnly
                                                                               LookupItems="@commissionSeatStatuses"
                                                                               LookupTextSelector="@(item => ((CommissionSeatStatus)item).Status ?? string.Empty)"
                                                                               For="@(() => entity.CommissionSeatStatusId)" />
                                                                </MudItem>
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.TermStartDate" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="DateTime?"
                                                                               TLookup="object"
                                                                               ReadOnly
                                                                               Property="@(x => x.TermStartDate)"
                                                                               For="@(() => entity.TermStartDate)" />
                                                                </MudItem>
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.TermEndDate" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="DateTime?"
                                                                               TLookup="object"
                                                                               ReadOnly
                                                                               Property="@(x => x.TermEndDate)"
                                                                               For="@(() => entity.TermEndDate)" />
                                                                </MudItem>
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.CreationDate" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="DateTime?"
                                                                               TLookup="object"
                                                                               ReadOnly
                                                                               Property="@(x => x.CreationDate)"
                                                                               For="@(() => entity.CreationDate)" />
                                                                </MudItem>
                                                                <MudItem xs="12" md="6">
                                                                    <AutoField @bind-Value="entity.TerminationDate" 
                                                                               TModel="CommissionSeat" 
                                                                               TValue="DateTime?"
                                                                               TLookup="object"
                                                                               ReadOnly
                                                                               Property="@(x => x.TerminationDate)"
                                                                               For="@(() => entity.TerminationDate)" />
                                                                </MudItem>
                                                            </ForeignKeyFormContent>
                                                        </AutoField>
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.CommissionerStatusId" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="int"
                                                                   TLookup="CommissionerStatus"
                                                                   Property="@(x => x.CommissionerStatusId)"
                                                                   ReadOnly="false"
                                                                   LookupItems="@commissionerStatuses"
                                                                   LookupTextSelector="@(item => ((CommissionerStatus)item).Status ?? string.Empty)"
                                                                   ForeignKeyIdSelector="@(x => x.Id)"
                                                                   ForeignKeyNameSelector="@(x => x.Status ?? "")"
                                                                   ForeignKeyDescriptionSelector="@(x => x.Description ?? "")"
                                                                   OnForeignKeyCreate="@CreateCommissionerStatus"
                                                                   OnForeignKeyUpdate="@UpdateCommissionerStatus"
                                                                   OnForeignKeyDelete="@DeleteCommissionerStatus"
                                                                   OnForeignKeyDataChanged="@(EventCallback.Factory.Create(this, LoadCommissionerStatuses))"
                                                                   ForeignKeyDialogTitle="Manage Commissioner Statuses"
                                                                   For="@(() => editModel.CommissionerStatusId)">
                                                            <ForeignKeyFormContent Context="entity">
                                                                <MudItem xs="12">
                                                                    <AutoField @bind-Value="entity.Status" 
                                                                               TModel="CommissionerStatus" 
                                                                               TValue="string"
                                                                               TLookup="object"
                                                                               Property="@(x => x.Status)"
                                                                               For="@(() => entity.Status)" />
                                                                </MudItem>
                                                                <MudItem xs="12">
                                                                    <AutoField @bind-Value="entity.StatusCode" 
                                                                               TModel="CommissionerStatus" 
                                                                               TValue="string"
                                                                               TLookup="object"
                                                                               Property="@(x => x.StatusCode)"
                                                                               For="@(() => entity.StatusCode)" />
                                                                </MudItem>
                                                                <MudItem xs="12">
                                                                    <AutoField @bind-Value="entity.Description" 
                                                                               TModel="CommissionerStatus" 
                                                                               TValue="string"
                                                                               TLookup="object"
                                                                               Property="@(x => x.Description)"
                                                                               For="@(() => entity.Description)" />
                                                                </MudItem>
                                                                <MudItem xs="12">
                                                                    <AutoField @bind-Value="entity.Active" 
                                                                               TModel="CommissionerStatus" 
                                                                               TValue="bool?"
                                                                               TLookup="object"
                                                                               Property="@(x => x.Active)"
                                                                               For="@(() => entity.Active)" />
                                                                </MudItem>
                                                            </ForeignKeyFormContent>
                                                        </AutoField>
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.RegisteredVoter" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="bool?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.RegisteredVoter)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.RegisteredVoter)" />
                                                    </MudItem>
                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.ResidesInServiceArea" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="bool?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.ResidesInServiceArea)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.ResidesInServiceArea)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.RecommendedForAppointment" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="bool?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.RecommendedForAppointment)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.RecommendedForAppointment)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.DoNotAppoint" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="bool?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.DoNotAppoint)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.DoNotAppoint)" />
                                                    </MudItem>

                                                    @if (editModel.DoNotAppoint == true)
                                                    {
                                                        <MudItem xs="12">
                                                            <AutoField @bind-Value="editModel.DoNotAppointDetails" 
                                                                       TModel="CommissionerProfile" 
                                                                       TValue="string" 
                                                                       TLookup="object"
                                                                       Property="@(x => x.DoNotAppointDetails)"
                                                                       ReadOnly="false"
                                                                       For="@(() => editModel.DoNotAppointDetails)" />
                                                        </MudItem>
                                                    }

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.Oath" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="bool?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.Oath)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.Oath)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.Invoices" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="bool?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.Invoices)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.Invoices)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.AppointedDate" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.AppointedDate)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.AppointedDate)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.AssemblyMeetingDate" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.AssemblyMeetingDate)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.AssemblyMeetingDate)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.EffectiveDate" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.EffectiveDate)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.EffectiveDate)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.EndDate" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.EndDate)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.EndDate)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField Value="editModel.ValidFrom" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.ValidFrom)"
                                                                   ReadOnly="true" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField Value="editModel.ValidTo" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.ValidTo)"
                                                                   ReadOnly="true" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.ModifiedBy" 
                                                                   TModel="CommissionerProfile" 
                                                                   TValue="string" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.ModifiedBy)"
                                                                   ReadOnly="true" />
                                                    </MudItem>
                                                </MudGrid>
                                            </EditForm>
                                        }
                                    </DetailsContent>

                                    <!-- View Mode Content -->
                                    <ViewModeContent Context="version">
                                        <MudGrid Spacing="3">
                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="Person" 
                                                         Icon="@Icons.Material.Filled.Person"
                                                         ValueStyle="font-weight: 600; font-size: 1.1rem;"
                                                         PropertyExpression="@(x => x.PersonProfileId)">
                                                    <ValueContent>
                                                        @if (isEditor)
                                                        {
                                                            <MudButton Variant="Variant.Text" 
                                                                      Color="Color.Primary" 
                                                                      Size="Size.Small"
                                                                      StartIcon="@Icons.Material.Filled.OpenInNew"
                                                                      OnClick="@(() => NavigationHelper.NavigateToEntity(NavigationManager, "/persons", displayVersion.PersonProfileId))">
                                                                @GetPersonName(displayVersion.PersonProfileId)
                                                            </MudButton>
                                                        }
                                                        else
                                                        {
                                                            <MudText Typo="Typo.body1" Style="font-weight: 600; font-size: 1.1rem;">
                                                                @GetPersonName(displayVersion.PersonProfileId)
                                                            </MudText>
                                                        }
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="Service Area" 
                                                         Icon="@Icons.Material.Filled.Landscape"
                                                         PropertyExpression="@(x => x.CommissionSeatId)">
                                                    <ValueContent>
                                                        @{
                                                            var versionSeat = commissionSeats?.FirstOrDefault(s => s.Id == displayVersion.CommissionSeatId);
                                                            var versionServiceArea = versionSeat != null ? serviceAreas?.FirstOrDefault(sa => sa.Id == versionSeat.ServiceAreaId) : null;
                                                        }
                                                        @if (versionServiceArea != null)
                                                        {
                                                            <MudButton Variant="Variant.Text" 
                                                                      Color="Color.Primary" 
                                                                      Size="Size.Small"
                                                                      StartIcon="@Icons.Material.Filled.OpenInNew"
                                                                      OnClick="@(() => NavigationHelper.NavigateToEntity(NavigationManager, "/service-areas", versionServiceArea.Id))">
                                                                @versionServiceArea.Name
                                                            </MudButton>
                                                        }
                                                        else
                                                        {
                                                            <MudText>—</MudText>
                                                        }
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="Commission Seat" 
                                                         Icon="@Icons.Material.Filled.EventSeat"
                                                         PropertyExpression="@(x => x.CommissionSeatId)">
                                                    <ValueContent>
                                                        @{
                                                            var versionSeatForDisplay = commissionSeats?.FirstOrDefault(s => s.Id == displayVersion.CommissionSeatId);
                                                            var seatDisplay = GetCommissionSeatDisplayText(versionSeatForDisplay);
                                                        }
                                                        @if (versionSeatForDisplay != null)
                                                        {
                                                            <MudButton Variant="Variant.Text" 
                                                                      Color="Color.Primary" 
                                                                      Size="Size.Small"
                                                                      StartIcon="@Icons.Material.Filled.OpenInNew"
                                                                      OnClick="@(() => NavigationHelper.NavigateToEntity(NavigationManager, "/commission-seats", versionSeatForDisplay.Id))">
                                                                @seatDisplay
                                                            </MudButton>
                                                        }
                                                        else
                                                        {
                                                            <MudText>@seatDisplay</MudText>
                                                        }
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="Status" 
                                                         Icon="@Icons.Material.Filled.Circle"
                                                         PropertyExpression="@(x => x.CommissionerStatusId)">
                                                    <ValueContent>
                                                        @{
                                                            var versionStatus = commissionerStatuses?.FirstOrDefault(s => s.Id == displayVersion.CommissionerStatusId);
                                                            var isVersionActive = versionStatus?.Active == true;
                                                        }
                                                        <MudChip T="string" 
                                                                Size="Size.Small" 
                                                                Color="@(isVersionActive ? Color.Success : Color.Default)">
                                                            @(versionStatus?.Status ?? "—")
                                                        </MudChip>
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <BooleanInfoCard TModel="CommissionerProfile"
                                                               Value="@displayVersion.RegisteredVoter"
                                                               Label="Registered Voter" 
                                                               Icon="@Icons.Material.Filled.HowToVote"
                                                               PropertyExpression="@(x => x.RegisteredVoter)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <BooleanInfoCard TModel="CommissionerProfile"
                                                               Value="@displayVersion.ResidesInServiceArea"
                                                               Label="Resides In Service Area" 
                                                               Icon="@Icons.Material.Filled.House"
                                                               PropertyExpression="@(x => x.ResidesInServiceArea)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <BooleanInfoCard TModel="CommissionerProfile"
                                                               Value="@displayVersion.RecommendedForAppointment"
                                                               Label="Recommended For Appointment" 
                                                               Icon="@Icons.Material.Filled.ThumbUp"
                                                               PropertyExpression="@(x => x.RecommendedForAppointment)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <BooleanInfoCard TModel="CommissionerProfile"
                                                               Value="@displayVersion.DoNotAppoint"
                                                               Label="Do Not Appoint" 
                                                               Icon="@Icons.Material.Filled.Block"
                                                               TrueColor="Color.Error"
                                                               TrueIcon="@Icons.Material.Filled.Block"
                                                               FalseIcon="@Icons.Material.Filled.Check"
                                                               PropertyExpression="@(x => x.DoNotAppoint)" />
                                            </MudItem>

                                            @if (displayVersion.DoNotAppoint == true)
                                            {
                                                <MudItem xs="12">
                                                    <InfoCard TValue="string" TModel="CommissionerProfile"
                                                             Label="Do Not Appoint Details" 
                                                             Value="@displayVersion.DoNotAppointDetails"
                                                             Icon="@Icons.Material.Filled.Notes"
                                                             PropertyExpression="@(x => x.DoNotAppointDetails)" />
                                                </MudItem>
                                            }

                                            <MudItem xs="12" md="6">
                                                <BooleanInfoCard TModel="CommissionerProfile"
                                                               Value="@displayVersion.Oath"
                                                               Label="Oath" 
                                                               Icon="@Icons.Material.Filled.Verified"
                                                               TrueText="Taken"
                                                               FalseText="Not Taken"
                                                               FalseColor="Color.Warning"
                                                               FalseIcon="@Icons.Material.Filled.PendingActions"
                                                               PropertyExpression="@(x => x.Oath)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <BooleanInfoCard TModel="CommissionerProfile"
                                                               Value="@displayVersion.Invoices"
                                                               Label="Invoices" 
                                                               Icon="@Icons.Material.Filled.Receipt"
                                                               PropertyExpression="@(x => x.Invoices)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="Appointed Date" 
                                                         Value="@(displayVersion.AppointedDate?.ToString("MMM d, yyyy"))"
                                                         Icon="@Icons.Material.Filled.CalendarToday"
                                                         PropertyExpression="@(x => x.AppointedDate)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="Assembly Meeting Date" 
                                                         Value="@(displayVersion.AssemblyMeetingDate?.ToString("MMM d, yyyy"))"
                                                         Icon="@Icons.Material.Filled.CalendarToday"
                                                         PropertyExpression="@(x => x.AssemblyMeetingDate)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="Effective Date" 
                                                         Value="@(displayVersion.EffectiveDate?.ToString("MMM d, yyyy"))"
                                                         Icon="@Icons.Material.Filled.Event"
                                                         PropertyExpression="@(x => x.EffectiveDate)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionerProfile"
                                                         Label="End Date" 
                                                         Value="@(displayVersion.EndDate?.ToString("MMM d, yyyy"))"
                                                         Icon="@Icons.Material.Filled.Event"
                                                         PropertyExpression="@(x => x.EndDate)" />
                                            </MudItem>
                                        </MudGrid>
                                    </ViewModeContent>
                                </VersionedDetailsPanel>
                            </SectionPanel>

                            <!-- Correspondence Section -->
                            <SectionPanel Title="@(ViewModeService.IsAtLeast(ViewMode.Admin) ? "All Correspondence" : "Public Correspondence")"
                                         Icon="@Icons.Material.Filled.ContactMail"
                                         MinimumViewMode="ViewMode.Public"
                                         ShowCount="true"
                                         Count="@(GetCorrespondenceForProfile(profile.Id)?.Count() ?? 0)"
                                         CountColor="Color.Info">
                                @{
                                    var profileCorrespondence = GetCorrespondenceForProfile(profile.Id);
                                }
                                @if (profileCorrespondence != null && profileCorrespondence.Any())
                                {
                                    <MudStack Spacing="2">
                                        @foreach (var correspondence in profileCorrespondence)
                                        {
                                            var email = correspondenceEmails?.FirstOrDefault(e => e.Id == correspondence.CorrespondenceEmailId);
                                            var phone = correspondencePhones?.FirstOrDefault(p => p.Id == correspondence.CorrespondencePhoneId);

                                            <MudCard Outlined="true">
                                                <MudCardContent>
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                        <MudStack Spacing="1">
                                                            @if (correspondence.Email == true && email != null)
                                                            {
                                                                <MudText Typo="Typo.body2">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" /> @email.Email
                                                                </MudText>
                                                            }
                                                            @if (correspondence.Phone == true && phone != null)
                                                            {
                                                                <MudText Typo="Typo.body2">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> @phone.Number
                                                                </MudText>
                                                            }
                                                        </MudStack>
                                                        @if (correspondence.PublicProfile == true)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Public">Public</MudChip>
                                                        }
                                                        else
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Lock">Private</MudChip>
                                                        }
                                                    </MudStack>
                                                </MudCardContent>
                                            </MudCard>
                                        }
                                    </MudStack>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No correspondence profiles</MudText>
                                }
                            </SectionPanel>

                            <!-- Notes Section -->
                            @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
                            {
                                var noteCount = profileNoteCounts.TryGetValue(profile.Id, out var count) ? count : 0;
                                var refreshKey = notesPanelRefreshKeys.TryGetValue(profile.Id, out var key) ? key : 0;

                                <SectionPanel Title="Notes"
                                             Icon="@Icons.Material.Filled.Notes"
                                             MinimumViewMode="ViewMode.Admin"
                                             ShowCount="true"
                                             Count="@noteCount"
                                             CountColor="Color.Info">
                                    <NotesPanel @key="@($"notes-{profile.Id}-{refreshKey}")"
                                               EntityType="commissioner_profile" 
                                               EntityId="@profile.Id"
                                               ShowHistory="true"
                                               NotesCountChanged="@GetNoteCountCallback(profile.Id)" />
                                </SectionPanel>
                            }
                        </MudExpansionPanels>
                    </SectionPanel>
                }

                <!-- Report Builder Section -->
                @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
                {
                    <SectionPanel Title="Report Builder"
                                 Icon="@Icons.Material.Filled.Assessment"
                                 MinimumViewMode="ViewMode.Admin">
                        <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                            Report Builder functionality will be implemented here.
                        </MudAlert>
                    </SectionPanel>
                }
            </MudExpansionPanels>
        }
    </DetailContent>
</EntityManagementLayout>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int? PersonId { get; set; }

    private IEnumerable<CommissionerProfile>? commissionerProfiles;
    private IEnumerable<CommissionerStatus>? commissionerStatuses;
    private IEnumerable<CommissionSeat>? commissionSeats;
    private IEnumerable<CommissionSeatType>? commissionSeatTypes;
    private IEnumerable<CommissionSeatClass>? commissionSeatClasses;
    private IEnumerable<CommissionSeatStatus>? commissionSeatStatuses;
    private IEnumerable<ServiceArea>? serviceAreas;
    private IEnumerable<PersonProfile>? personProfiles;
    private IEnumerable<PersonHonorific>? personHonorifics;
    private IEnumerable<PersonSuffix>? personSuffixes;
    private IEnumerable<CorrespondenceProfile>? correspondenceProfiles;
    private IEnumerable<CorrespondenceEmail>? correspondenceEmails;
    private IEnumerable<CorrespondencePhone>? correspondencePhones;

    private PersonProfile? selectedPerson;
    private CommissionerProfile? selectedCommissioner;
    private bool isLoading = false;
    private bool isSaving = false;
    private bool isEditMode = false;
    private bool canEdit = false;
    private bool isEditor = false;
    private string? errorMessage;
    private string[]? errorDetails;
    private string? successMessage;
    private CommissionerProfile? editModel;
    private string _searchString = string.Empty;
    private EditContext? editContext;

    // Version navigation fields
    private IEnumerable<CommissionerProfile>? allVersions;
    private CommissionerProfile? currentViewVersion;
    private bool isLoadingHistory = false;
    private string? historyErrorMessage;

    // Notes management field
    private int notesCount = 0;

    // Track note counts per profile
    private Dictionary<int, int> profileNoteCounts = new();

    // Store callbacks per profile to make them stable references
    private Dictionary<int, Action<int>> noteCountCallbacks = new();

    // Correspondence loading
    private bool isLoadingCorrespondence = false;

    // Other profiles for same person
    private IEnumerable<CommissionerProfile>? otherProfilesForPerson;
    private bool isLoadingOtherProfiles = false;

    // All profiles for selected person (replacing the version history approach)
    private IEnumerable<CommissionerProfile>? allProfilesForPerson;

    // Track which profile is being edited
    private int? editingProfileId = null;

    // Track selected service area for filtering commission seats
    private Dictionary<int, int?> selectedServiceAreaByProfile = new();

    // Cache for profile version history
    private Dictionary<int, IEnumerable<CommissionerProfile>> profileVersionCache = new();

    // Track currently displayed version for each profile
    private Dictionary<int, CommissionerProfile> currentlyDisplayedVersions = new();

    // Track notes panel refresh keys
    private Dictionary<int, int> notesPanelRefreshKeys = new();

    // Cache for profile display data to improve performance
    private Dictionary<int, ProfileDisplayData> profileDisplayCache = new();

    private class ProfileDisplayData
    {
        public CommissionSeat? Seat { get; set; }
        public CommissionSeatType? SeatType { get; set; }
        public CommissionSeatClass? SeatClass { get; set; }
        public ServiceArea? ServiceArea { get; set; }
        public CommissionerStatus? Status { get; set; }
        public bool IsActive { get; set; }
        public bool IsCurrent { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        ViewModeService.OnViewModeChanged += HandleViewModeChanged;
        await LoadAllData();
        SelectCommissionerFromParameters();
    }

    protected override void OnParametersSet()
    {
        SelectCommissionerFromParameters();
    }

    public void Dispose()
    {
        ViewModeService.OnViewModeChanged -= HandleViewModeChanged;
    }

    private async void HandleViewModeChanged()
    {
        // Clear selection if the currently selected person is no longer visible
        if (selectedPerson != null && !ViewModeService.IsAtLeast(ViewMode.Admin))
        {
            // In public view, check if selected person has an active profile
            if (!HasActiveProfile(selectedPerson.Id))
            {
                selectedPerson = null;
                selectedCommissioner = null;
                allProfilesForPerson = null;
            }
        }

        if (selectedPerson != null)
            LoadAllProfilesForPerson();

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAllData()
    {
        isLoading = true;

        await DataLoaderHelper.LoadMultipleAsync(
            LoadCommissionerProfiles,
            LoadCommissionerStatuses,
            LoadCommissionSeats,
            LoadCommissionSeatTypes,
            LoadCommissionSeatClasses,
            LoadCommissionSeatStatuses,
            LoadServiceAreas,
            LoadPersonProfiles,
            LoadPersonHonorifics,
            LoadPersonSuffixes,
            LoadCorrespondenceProfiles,
            LoadCorrespondenceEmails,
            LoadCorrespondencePhones
        );

        isLoading = false;
    }

    private void HandleEditModeCancelled()
    {
        EntityPageHelper.HandleEditModeCancelled(isEditMode, CancelEdit);
    }

    private void SelectCommissionerFromParameters()
    {
        if (personProfiles == null || !personProfiles.Any() || !PersonId.HasValue)
            return;

        var target = personProfiles.FirstOrDefault(p => p.Id == PersonId.Value);

        if (target != null && selectedPerson?.Id != target.Id)
        {
            selectedPerson = target;
            selectedCommissioner = GetMostRecentCommissionerProfile(target.Id);
            isEditMode = false;
            ClearMessages();
            _ = LoadAllVersions();
        }
    }

    private async Task LoadCommissionerProfiles()
    {
        commissionerProfiles = await DataLoaderHelper.LoadDataAsync(() => CommissionerProfilesApi.GetAllCommissionerProfilesAsync());
    }

    private async Task LoadCommissionerStatuses()
    {
        commissionerStatuses = await DataLoaderHelper.LoadDataAsync(() => CommissionerStatusesApi.GetAllCommissionerStatusesAsync());
    }

    private async Task LoadCommissionSeats()
    {
        commissionSeats = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatsApi.GetAllCommissionSeatsAsync());
    }

    private async Task LoadCommissionSeatTypes()
    {
        commissionSeatTypes = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatTypesApi.GetAllCommissionSeatTypesAsync());
    }

    private async Task LoadCommissionSeatClasses()
    {
        commissionSeatClasses = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatClassesApi.GetAllCommissionSeatClassesAsync());
    }

    private async Task LoadCommissionSeatStatuses()
    {
        commissionSeatStatuses = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatStatusesApi.GetAllCommissionSeatStatusesAsync());
    }

    private async Task LoadServiceAreas()
    {
        serviceAreas = await DataLoaderHelper.LoadDataAsync(() => ServiceAreasApi.GetAllServiceAreasAsync());
    }

    private async Task LoadPersonProfiles()
    {
        personProfiles = await DataLoaderHelper.LoadDataAsync(() => PersonProfilesApi.GetAllPersonProfilesAsync());
    }

    private async Task LoadPersonHonorifics()
    {
        personHonorifics = await DataLoaderHelper.LoadDataAsync(() => PersonHonorificsApi.GetAllPersonHonorificsAsync());
    }

    private async Task LoadPersonSuffixes()
    {
        personSuffixes = await DataLoaderHelper.LoadDataAsync(() => PersonSuffixesApi.GetAllPersonSuffixesAsync());
    }

    private async Task LoadCorrespondenceProfiles()
    {
        correspondenceProfiles = await DataLoaderHelper.LoadDataAsync(() => CorrespondenceProfilesApi.GetAllCorrespondenceProfilesAsync());
    }

    private async Task LoadCorrespondenceEmails()
    {
        correspondenceEmails = await DataLoaderHelper.LoadDataAsync(() => CorrespondenceEmailsApi.GetAllCorrespondenceEmailsAsync());
    }

    private async Task LoadCorrespondencePhones()
    {
        correspondencePhones = await DataLoaderHelper.LoadDataAsync(() => CorrespondencePhonesApi.GetAllCorrespondencePhonesAsync());
    }

    private async Task LoadOtherProfilesForPerson()
    {
        if (selectedPerson == null) return;

        isLoadingOtherProfiles = true;

        try
        {
            otherProfilesForPerson = commissionerProfiles?
                .Where(cp => cp.PersonProfileId == selectedPerson.Id && cp.Id != selectedCommissioner?.Id)
                .OrderByDescending(cp => cp.AppointedDate)
                .ToList();
        }
        catch (Exception)
        {
            otherProfilesForPerson = Array.Empty<CommissionerProfile>();
        }
        finally
        {
            isLoadingOtherProfiles = false;
        }
    }

    private IEnumerable<PersonProfile>? GetPeopleWithCommissionerProfiles()
    {
        if (personProfiles == null || !personProfiles.Any() || commissionerProfiles == null)
            return Array.Empty<PersonProfile>();

        // Get unique PersonProfileIds from commissioner profiles
        var personIdsWithProfiles = commissionerProfiles
            .Select(cp => cp.PersonProfileId)
            .Distinct()
            .ToHashSet();

        // Start with all person profiles that have commissioner profiles
        var profiles = personProfiles.Where(p => personIdsWithProfiles.Contains(p.Id)).AsEnumerable();

        // In Public view mode, only show people with active commissioner profiles
        if (!ViewModeService.IsAtLeast(ViewMode.Admin))
        {
            profiles = profiles.Where(p => HasActiveProfile(p.Id));
        }

        // Return ordered by status (active first), then by name
        return profiles
            .OrderByDescending(p => HasActiveProfile(p.Id))  // Active profiles first
            .ThenBy(p => p.LastName ?? "")
            .ThenBy(p => p.FirstName ?? "")
            .ToList();
    }

    private CommissionerProfile? GetMostRecentCommissionerProfile(int personProfileId)
    {
        if (commissionerProfiles == null) return null;

        // Get all active profiles for this person (Active status AND ValidTo is null)
        var activeProfiles = commissionerProfiles
            .Where(cp => cp.PersonProfileId == personProfileId)
            .Where(cp =>
            {
                var status = commissionerStatuses?.FirstOrDefault(s => s.Id == cp.CommissionerStatusId);
                return status?.Active == true && cp.ValidTo == null;
            })
            .ToList();

        if (activeProfiles.Any())
        {
            // Prioritize "Commissioner" seat type over "Alternate Commissioner"
            var commissionerSeatType = commissionSeatTypes?.FirstOrDefault(t => 
                t.Type?.Equals("Commissioner", StringComparison.OrdinalIgnoreCase) == true ||
                t.TypeCode?.Equals("COMM", StringComparison.OrdinalIgnoreCase) == true);

            if (commissionerSeatType != null)
            {
                var commissionerProfile = activeProfiles.FirstOrDefault(cp =>
                {
                    var seat = commissionSeats?.FirstOrDefault(s => s.Id == cp.CommissionSeatId);
                    return seat?.CommissionSeatTypeId == commissionerSeatType.Id;
                });

                if (commissionerProfile != null)
                    return commissionerProfile;
            }

            // Fallback: return most recent active profile
            return activeProfiles.OrderByDescending(cp => cp.ValidFrom).First();
        }

        // If no active profile, get the most recent one overall
        return commissionerProfiles
            .Where(cp => cp.PersonProfileId == personProfileId)
            .OrderByDescending(cp => cp.ValidFrom)
            .FirstOrDefault();
    }

    private IEnumerable<CommissionerProfile>? GetUniquePersonProfiles()
    {
        if (commissionerProfiles == null || !commissionerProfiles.Any())
            return Array.Empty<CommissionerProfile>();

        // Group by PersonProfileId and return one profile per person
        return commissionerProfiles
            .GroupBy(cp => cp.PersonProfileId)
            .Select(group =>
            {
                // First try to get an active profile
                var activeProfile = group.FirstOrDefault(cp =>
                {
                    var status = commissionerStatuses?.FirstOrDefault(s => s.Id == cp.CommissionerStatusId);
                    return status?.Active == true && cp.ValidTo == null;
                });

                // If no active profile, get the most recent one
                return activeProfile ?? group.OrderByDescending(cp => cp.ValidFrom).First();
            })
            .OrderBy(cp =>
            {
                var person = personProfiles?.FirstOrDefault(p => p.Id == cp.PersonProfileId);
                return person?.LastName ?? "";
            })
            .ThenBy(cp =>
            {
                var person = personProfiles?.FirstOrDefault(p => p.Id == cp.PersonProfileId);
                return person?.FirstName ?? "";
            })
            .ToList();
    }

    private bool HasActiveProfile(int personProfileId)
    {
        if (commissionerProfiles == null) return false;

        return commissionerProfiles
            .Where(cp => cp.PersonProfileId == personProfileId)
            .Any(cp =>
            {
                var status = commissionerStatuses?.FirstOrDefault(s => s.Id == cp.CommissionerStatusId);
                return status?.Active == true;
            });
    }

    private void LoadAllProfilesForPerson()
    {
        if (selectedPerson == null) return;

        // Get all profiles for this person
        var profiles = commissionerProfiles?
            .Where(cp => cp.PersonProfileId == selectedPerson.Id);

        // In Public view mode, only show profiles with active status (where CommissionerStatus.Active = true)
        if (!ViewModeService.IsAtLeast(ViewMode.Admin))
        {
            var activeStatusIds = commissionerStatuses?
                .Where(s => s.Active == true)
                .Select(s => s.Id)
                .ToHashSet();

            if (activeStatusIds != null && activeStatusIds.Any())
            {
                profiles = profiles?.Where(cp => activeStatusIds.Contains(cp.CommissionerStatusId));
            }
        }

        // Order by most recent first
        allProfilesForPerson = profiles?
            .OrderByDescending(cp => cp.AppointedDate)
            .ToList();

        // Pre-compute display data for better performance
        profileDisplayCache.Clear();
        noteCountCallbacks.Clear();

        if (allProfilesForPerson != null)
        {
            foreach (var profile in allProfilesForPerson)
            {
                var seat = commissionSeats?.FirstOrDefault(s => s.Id == profile.CommissionSeatId);
                var seatType = seat != null ? commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId) : null;
                var seatClass = seat != null ? commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId) : null;
                var serviceArea = seat != null ? serviceAreas?.FirstOrDefault(sa => sa.Id == seat.ServiceAreaId) : null;
                var status = commissionerStatuses?.FirstOrDefault(s => s.Id == profile.CommissionerStatusId);

                profileDisplayCache[profile.Id] = new ProfileDisplayData
                {
                    Seat = seat,
                    SeatType = seatType,
                    SeatClass = seatClass,
                    ServiceArea = serviceArea,
                    Status = status,
                    IsActive = status?.Active == true,
                    IsCurrent = profile.ValidTo == null
                };

                // Create stable callback for this profile
                var profileId = profile.Id;
                noteCountCallbacks[profileId] = (count) => UpdateNoteCount(profileId, count);
            }
        }
    }

    private Action<int> GetNoteCountCallback(int profileId)
    {
        if (!noteCountCallbacks.ContainsKey(profileId))
        {
            noteCountCallbacks[profileId] = (count) => UpdateNoteCount(profileId, count);
        }
        return noteCountCallbacks[profileId];
    }

    private IEnumerable<CorrespondenceProfile>? GetCorrespondenceForProfile(int commissionerProfileId)
    {
        var profiles = correspondenceProfiles?
            .Where(cp => cp.CommissionerProfileId == commissionerProfileId);

        if (!ViewModeService.IsAtLeast(ViewMode.Admin))
        {
            // Only show public profiles for non-admins
            profiles = profiles?.Where(cp => cp.PublicProfile == true);
        }

        return profiles?.ToList();
    }

    private IEnumerable<CommissionerProfile>? GetAllVersionsOfProfile(CommissionerProfile profile)
    {
        if (profile == null) 
            return new[] { profile };

        // Check cache first
        if (profileVersionCache.TryGetValue(profile.Id, out var cachedVersions))
        {
            return cachedVersions;
        }

        // If not in cache, load from API
        _ = LoadProfileVersionsAsync(profile.Id);

        // Return just the current profile for now (will update when async load completes)
        return new[] { profile };
    }

    private async Task LoadProfileVersionsAsync(int profileId)
    {
        try
        {
            var result = await CommissionerProfilesApi.GetCommissionerProfileHistoryAsync(profileId);

            if (result?.IsSuccess == true && result.Data != null)
            {
                var versions = result.Data
                    .OrderByDescending(cp => cp.ValidFrom)
                    .ToList();

                profileVersionCache[profileId] = versions;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception)
        {
            // If history load fails, just use the current profile
            var currentProfile = allProfilesForPerson?.FirstOrDefault(p => p.Id == profileId);
            if (currentProfile != null)
            {
                profileVersionCache[profileId] = new[] { currentProfile };
            }
        }
    }

    private async Task LoadAllVersions()
    {
        if (selectedPerson == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        try
        {
            // Clear version cache when loading new person
            profileVersionCache.Clear();
            currentlyDisplayedVersions.Clear();

            // Load all profiles for this person
            LoadAllProfilesForPerson();
            await LoadOtherProfilesForPerson();
        }
        catch (Exception ex)
        {
            historyErrorMessage = $"Error loading profiles: {ex.Message}";
            allProfilesForPerson = selectedCommissioner != null 
                ? new List<CommissionerProfile> { selectedCommissioner } 
                : new List<CommissionerProfile>();
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private Task HandleVersionChanged(int profileId, CommissionerProfile selectedVersion)
    {
        // Update the currently displayed version for this profile
        currentlyDisplayedVersions[profileId] = selectedVersion;

        // Trigger UI update
        StateHasChanged();

        return Task.CompletedTask;
    }

    private async Task HandleRestoreVersion(int profileId, CommissionerProfile historicalVersion)
    {
        if (historicalVersion == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var restoredData = CloneCommissioner(historicalVersion);
            restoredData.Id = profileId;

            var userEmail = await AuthenticationHelper.SetModifiedByAsync(
                restoredData,
                AuthenticationStateProvider,
                (entity, email) => entity.ModifiedBy = email);

            var result = await CommissionerProfilesApi.UpdateCommissionerProfileAsync(profileId, restoredData);

            if (result?.IsSuccess == true)
            {
                successMessage = $"Successfully restored version from {historicalVersion.ValidFrom:g}";

                // Reload data
                await LoadCommissionerProfiles();

                // Clear caches to force reload
                profileVersionCache.Remove(profileId);
                currentlyDisplayedVersions.Remove(profileId);

                // Reload all profiles for this person
                LoadAllProfilesForPerson();

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to restore historical version";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error restoring historical version: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnCurrentVersionChanged(CommissionerProfile newVersion)
    {
        currentViewVersion = newVersion;
        UpdateEditModel(newVersion);
        await InvokeAsync(StateHasChanged);
    }

    private void OnNotesCountChanged(int count)
    {
        notesCount = count;
    }

    private void UpdateNoteCount(int profileId, int count)
    {
        profileNoteCounts[profileId] = count;
    }

    private void UpdateEditModel(CommissionerProfile version)
    {
        editModel = CloneCommissioner(version);
        editContext = new EditContext(editModel);

        if (!IsViewingCurrentVersion())
        {
            isEditMode = false;
        }
    }

    private bool IsViewingCurrentVersion()
    {
        return EntityPageHelper.IsViewingCurrentVersion(currentViewVersion, selectedCommissioner, x => x.ValidFrom);
    }

    private bool CanEditFields()
    {
