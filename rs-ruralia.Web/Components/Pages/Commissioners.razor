    private async Task OpenCreateDialog()
    {
        var createdProfile = await CreateDialogHelper.OpenCreateDialogAsync(
            DialogService,
            "Commissioner Profile",
            "Create a new commissioner profile record. All fields marked with * are required.",
            CreateCommissionerProfile,
            GetCommissionerProfileFormContent(),
            autoSetModifiedBy: true,
            dialogTitle: "Create New {0}",
            initialEntity: GetInitialCommissionerProfile());

        if (createdProfile != null)
        {
            await LoadCommissionerProfiles();

            var person = personProfiles?.FirstOrDefault(p => p.Id == createdProfile.PersonProfileId);
            if (person != null)
            {
                selectedPerson = person;
                selectedCommissioner = GetMostRecentCommissionerProfile(person.Id);
                await LoadAllVersions();
                NavigationHelper.UpdateUrlWithSelection(NavigationManager, person.Id);
            }

            successMessage = $"Commissioner profile for '{GetPersonName(createdProfile.PersonProfileId)}' created successfully!";
            await InvokeAsync(StateHasChanged);
        }
    }

    private CommissionerProfile GetInitialCommissionerProfile()
