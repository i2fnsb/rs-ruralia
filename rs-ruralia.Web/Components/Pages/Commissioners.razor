    private async Task HandleItemClick(PersonProfile item)
    {
        selectedPerson = item;
        selectedCommissioner = GetMostRecentCommissionerProfile(item.Id);
        isEditMode = false;
        ClearMessages();
        await LoadAllVersions();
        await InvokeAsync(StateHasChanged);

        NavigationHelper.UpdateUrlWithSelection(NavigationManager, selectedPerson.Id);
    }

    private async Task HandleRestore(CommissionerProfile historicalRecord)
    {
        if (selectedPerson == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var restoredData = CloneCommissioner(historicalRecord);
            restoredData.Id = selectedCommissioner?.Id ?? 0;

            if (restoredData.Id == 0)
            {
                errorMessage = "No commissioner profile selected to restore";
                return;
            }

            var result = await CommissionerProfilesApi.UpdateCommissionerProfileAsync(restoredData.Id, restoredData);

            if (result?.IsSuccess == true)
            {
                successMessage = $"Successfully restored version from {historicalRecord.ValidFrom:g}";

                await LoadCommissionerProfiles();

                selectedCommissioner = commissionerProfiles?.FirstOrDefault(c => c.PersonProfileId == selectedPerson.Id);
                if (selectedCommissioner != null)
                {
                    await LoadAllVersions();
                }

                isEditMode = false;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to restore historical version";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error restoring historical version: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void EnableEdit()
    {
        if (!IsViewingCurrentVersion())
        {
            if (selectedCommissioner != null)
            {
                currentViewVersion = selectedCommissioner;
                UpdateEditModel(currentViewVersion);
            }
        }

        isEditMode = true;
        ClearMessages();
    }

    private void EnableEditForProfile(int profileId)
    {
        var profile = allProfilesForPerson?.FirstOrDefault(p => p.Id == profileId);
        if (profile != null)
        {
            editingProfileId = profileId;
            editModel = CloneCommissioner(profile);
            editContext = new EditContext(editModel);
            ClearMessages();
        }
    }

    private async Task SaveProfileEdit(int profileId)
    {
        if (editModel == null || editModel.Id != profileId) return;

        isSaving = true;
        ClearMessages();

        var userEmail = await AuthenticationHelper.SetModifiedByAsync(
            editModel,
            AuthenticationStateProvider,
            (entity, email) => entity.ModifiedBy = email);

        var (success, errorMsg, errors, updatedEntity) = await VersionHistoryHelper.SaveEditAsync(
            editModel,
            (id, entity) => CommissionerProfilesApi.UpdateCommissionerProfileAsync(id, entity),
            x => x.Id,
            "Commissioner profile updated successfully!");

        if (success)
        {
            successMessage = errorMsg;
            editingProfileId = null;

            await LoadCommissionerProfiles();
            profileVersionCache.Remove(profileId);
            LoadAllProfilesForPerson();

            var updatedProfile = allProfilesForPerson?.FirstOrDefault(p => p.Id == profileId);
            if (updatedProfile != null)
            {
                currentlyDisplayedVersions[profileId] = updatedProfile;
                _ = LoadProfileVersionsAsync(profileId);
            }

            await InvokeAsync(StateHasChanged);
            await PromptForEditNote(profileId, userEmail);
        }
        else
        {
            errorMessage = errorMsg;
            errorDetails = errors;
        }

        isSaving = false;
    }

    private void CancelEdit()
    {
        if (currentViewVersion != null)
        {
            editModel = CloneCommissioner(currentViewVersion);
            editContext = new EditContext(editModel);
        }
        isEditMode = false;
        editingProfileId = null;
        ClearMessages();
    }

    private void ClearMessages()
    {
        EntityPageHelper.ClearMessages(ref errorMessage, ref errorDetails, ref successMessage);
    }

    private CommissionerProfile CloneCommissioner(CommissionerProfile source) => EntityCloneHelper.ShallowClone(source);

    private string GetPersonName(int personProfileId)
    {
        var person = personProfiles?.FirstOrDefault(p => p.Id == personProfileId);
        if (person == null) return $"Person ID: {personProfileId}";

        var nameParts = new List<string>();

        if (person.PersonHonorificId.HasValue)
        {
            var honorific = personHonorifics?.FirstOrDefault(h => h.Id == person.PersonHonorificId);
            if (!string.IsNullOrEmpty(honorific?.Honorific))
                nameParts.Add(honorific.Honorific);
        }

        if (!string.IsNullOrEmpty(person.FirstName))
            nameParts.Add(person.FirstName);

        if (!string.IsNullOrEmpty(person.PreferredName))
            nameParts.Add($"\"{person.PreferredName}\"");

        if (!string.IsNullOrEmpty(person.LastName))
            nameParts.Add(person.LastName);

        if (person.PersonSuffixId.HasValue)
        {
            var suffix = personSuffixes?.FirstOrDefault(s => s.Id == person.PersonSuffixId);
            if (!string.IsNullOrEmpty(suffix?.Suffix))
                nameParts.Add(suffix.Suffix);
        }

        return nameParts.Any() ? string.Join(" ", nameParts) : $"Person ID: {personProfileId}";
    }

    private string GetCommissionSeatDisplayText(CommissionSeat? seat)
    {
        if (seat == null) return "—";

        var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
        var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);

        var parts = new List<string>();

        if (!string.IsNullOrEmpty(seatType?.Type))
            parts.Add(seatType.Type);

        if (!string.IsNullOrEmpty(seatClass?.Class))
            parts.Add(seatClass.Class);

        return parts.Any() ? string.Join(" - ", parts) : "—";
    }

    private string GetCommissionSeatWithServiceAreaDisplayText(CommissionSeat seat)
    {
        if (seat == null) return "—";

        var serviceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == seat.ServiceAreaId);
        var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
        var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);

        var parts = new List<string>();

        // Add service area first for grouping
        if (!string.IsNullOrEmpty(serviceArea?.Name))
            parts.Add($"[{serviceArea.Name}]");

        if (!string.IsNullOrEmpty(seatType?.Type))
            parts.Add(seatType.Type);

        if (!string.IsNullOrEmpty(seatClass?.Class))
            parts.Add(seatClass.Class);

        if (seat.TermStartDate.HasValue && seat.TermEndDate.HasValue)
            parts.Add($"({seat.TermStartDate.Value:MMM yyyy} - {seat.TermEndDate.Value:MMM yyyy})");

        return parts.Any() ? string.Join(" - ", parts) : "—";
    }

    private IEnumerable<CommissionSeat>? GetFilteredCommissionSeats(int commissionSeatId)
    {
        if (commissionSeats == null) return Array.Empty<CommissionSeat>();

        var currentSeat = commissionSeats.FirstOrDefault(s => s.Id == commissionSeatId);
        if (currentSeat == null) return commissionSeats;

        // Filter seats to only those in the same service area
        return commissionSeats
            .Where(s => s.ServiceAreaId == currentSeat.ServiceAreaId)
            .ToList();
    }

