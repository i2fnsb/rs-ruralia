@page "/fnsbuser"
@attribute [Authorize(Policy = Policies.FnsbUserOrAbove)]

<PageTitle>FNSB User</PageTitle>

<div class="container mt-5">
    <div class="alert alert-warning">
        <h3><span class="bi bi-person-badge-fill"></span> FNSB User Area</h3>
        <p><strong>Access Level:</strong> FNSB User and Above (Admin, FNSB User)</p>
    </div>

    <h4>Welcome, FNSB User!</h4>
    <p>This page is accessible to users with <strong>fnsbuser</strong> or <strong>admin</strong> roles.</p>

    <div class="card mt-4">
        <div class="card-header">
            <h5>FNSB User Capabilities</h5>
        </div>
        <div class="card-body">
            <ul>
                <li>FNSB internal operations</li>
                <li>Department management</li>
                <li>Report generation</li>
                <li>All lower-level permissions</li>
            </ul>
        </div>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="mt-4">
                <p><strong>Your Email:</strong> @context.User.Identity?.Name</p>
                <p><strong>Your Roles:</strong> @string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))</p>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

