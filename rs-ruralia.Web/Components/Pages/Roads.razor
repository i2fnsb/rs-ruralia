    private void StageAddSubdivision(RoadSubdivision? subdivision)
    {
        if (subdivision == null) return;

        // If it was marked for removal, unmark it
        if (subdivisionsToRemove.Contains(subdivision.Id))
        {
            subdivisionsToRemove.Remove(subdivision.Id);
        }
        else if (!roadSubdivisionsForSelectedRoad?.Any(s => s.Id == subdivision.Id) ?? true)
        {
            // Only add to staged additions if it's not already assigned
            subdivisionsToAdd.Add(subdivision.Id);
        }

        StateHasChanged();
    }

    private void StageRemoveSubdivision(RoadSubdivision subdivision)
    {
        if (subdivision == null) return;

        // If it was marked for addition, just remove from that list
        if (subdivisionsToAdd.Contains(subdivision.Id))
        {
            subdivisionsToAdd.Remove(subdivision.Id);
        }
        else
        {
            // Mark existing subdivision for removal
            subdivisionsToRemove.Add(subdivision.Id);
        }

        StateHasChanged();
    }

    private IEnumerable<RoadSubdivision> GetDisplayedSubdivisions()
    {
        var displayed = new List<RoadSubdivision>();

        // Start with currently assigned subdivisions
        if (roadSubdivisionsForSelectedRoad != null)
        {
            displayed.AddRange(roadSubdivisionsForSelectedRoad.Where(s => !subdivisionsToRemove.Contains(s.Id)));
        }

        // Add staged additions
        if (roadSubdivisions != null)
        {
            var toAdd = roadSubdivisions.Where(s => subdivisionsToAdd.Contains(s.Id));
            displayed.AddRange(toAdd);
        }

        return displayed;
    }

    private IEnumerable<RoadSubdivision> GetAvailableSubdivisions()
    {
        if (roadSubdivisions == null) return Array.Empty<RoadSubdivision>();

        var assignedIds = new HashSet<int>();

        // Add currently assigned subdivisions (unless marked for removal)
        if (roadSubdivisionsForSelectedRoad != null)
        {
            assignedIds.UnionWith(roadSubdivisionsForSelectedRoad
                .Where(s => !subdivisionsToRemove.Contains(s.Id))
                .Select(s => s.Id));
        }

        // Add staged additions
        assignedIds.UnionWith(subdivisionsToAdd);

        return roadSubdivisions.Where(s => !assignedIds.Contains(s.Id)).OrderBy(s => s.Name);
    }

    private async Task<IEnumerable<RoadSubdivision>> SearchAvailableSubdivisions(string searchString, CancellationToken cancellationToken)
    {
        var available = GetAvailableSubdivisions();

        await Task.Delay(0, cancellationToken); // Prevent warning about async method

        if (string.IsNullOrWhiteSpace(searchString))
        {
            return available.Take(50);
        }

        searchString = searchString.ToLowerInvariant();

        return available
            .Where(s => s.Name?.ToLowerInvariant().Contains(searchString) == true)
            .Take(50);
    }
