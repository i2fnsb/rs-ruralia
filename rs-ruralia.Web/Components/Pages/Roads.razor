        }
    }

    private async Task LoadServiceAreas()
    {
        try
        {
            var result = await ServiceAreasApi.GetAllServiceAreasAsync();
            if (result?.IsSuccess == true && result.Data != null)
            {
                serviceAreas = result.Data;
            }
            else
            {
                serviceAreas = Array.Empty<ServiceArea>();
            }
        }
        catch (Exception)
        {
            serviceAreas = Array.Empty<ServiceArea>();
        }
    }

    private async Task LoadRelatedRoads()
    {
        if (selectedRoad == null || !selectedRoad.RoadNameId.HasValue) return;

        isLoadingRelatedRoads = true;

        try
        {
            var result = await RoadsApi.GetAllRoadsAsync();

            if (result?.IsSuccess == true && result.Data != null)
            {
                relatedRoads = result.Data
                    .Where(r => r.RoadNameId == selectedRoad.RoadNameId && r.Id != selectedRoad.Id)
                    .OrderBy(r => r.Phase)
                    .ToList();
            }
            else
            {
                relatedRoads = Array.Empty<Road>();
            }
        }
        catch (Exception)
        {
            relatedRoads = Array.Empty<Road>();
        }
        finally
        {
            isLoadingRelatedRoads = false;
        }
    }

    private async Task LoadAllVersions()
    {
        if (selectedRoad == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        try
        {
            var historyResult = await RoadsApi.GetRoadHistoryAsync(selectedRoad.Id);
            var historyRecords = new List<Road>();

            if (historyResult?.IsSuccess == true && historyResult.Data != null)
            {
                historyRecords.AddRange(historyResult.Data);
            }

            var versions = new List<Road> { selectedRoad };
            versions.AddRange(historyRecords.Where(h => h.ValidFrom != selectedRoad.ValidFrom));

            allVersions = versions;
            currentViewVersion = selectedRoad;
            UpdateEditModel(currentViewVersion);

            // Load related data
            await LoadRelatedRoads();
            await LoadSubdivisionsForRoad();
        }
        catch (Exception ex)
        {
            historyErrorMessage = $"Error loading versions: {ex.Message}";
            allVersions = new List<Road> { selectedRoad };
            currentViewVersion = selectedRoad;
            UpdateEditModel(currentViewVersion);
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private string? GetFeatureLayerUrl()
    {
        return Configuration.GetValue<string>("FeatureLayer:ServiceAreasUrl");
    }

    private Dictionary<string, string>? GetServiceAreaQueryParameters()
    {
        if (selectedRoad == null) return null;

        var serviceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == selectedRoad.ServiceAreaId);
        if (serviceArea?.FeatureObjectId == null)
            return null;

        return new Dictionary<string, string>
        {
            { "where", $"OBJECTID = {serviceArea.FeatureObjectId}" },
            { "outFields", "*" },
            { "returnGeometry", "true" }
        };
    }

    private void OnCalculatedDistanceChanged(double? distance)
    {
        // Just store the calculated distance for display, don't auto-apply to field
        calculatedDistanceFeet = distance;
        StateHasChanged();
    }

    private void OnApplyDistanceToField(double distance)
    {
        // Only apply to DistanceFeet field when admin clicks the button
        if (editModel != null)
        {
            editModel.DistanceFeet = (decimal)distance;
            StateHasChanged();
        }
    }

    private async Task OnCurrentVersionChanged(Road newVersion)
    {
        currentViewVersion = newVersion;
        UpdateEditModel(newVersion);
        await InvokeAsync(StateHasChanged);
    }

    private void OnNotesCountChanged(int count)
    {
        notesCount = count;
        StateHasChanged();
    }

    private void UpdateEditModel(Road version)
    {
        editModel = CloneRoad(version);
        editContext = new EditContext(editModel);
        
        if (!IsViewingCurrentVersion())
        {
            isEditMode = false;
        }
    }

    private bool IsViewingCurrentVersion()
    {
        if (currentViewVersion == null || selectedRoad == null)
            return true;

        return currentViewVersion.ValidFrom == selectedRoad.ValidFrom;
    }

    private bool CanEditFields()
    {
        return isEditMode && IsViewingCurrentVersion();
    }

    private async Task HandleItemClick(Road item)
    {
        selectedRoad = item;
        isEditMode = false;
        ClearMessages();
        await LoadAllVersions();
        await InvokeAsync(StateHasChanged);

        var uri = NavigationManager.GetUriWithQueryParameter("id", selectedRoad.Id);
        NavigationManager.NavigateTo(uri, replace: true);
    }

    private async Task HandleRestore(Road historicalRecord)
    {
        if (selectedRoad == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var restoredData = CloneRoad(historicalRecord);
            restoredData.Id = selectedRoad.Id;

            var result = await RoadsApi.UpdateRoadAsync(restoredData.Id, restoredData);

            if (result?.IsSuccess == true)
            {
                successMessage = $"Successfully restored version from {historicalRecord.ValidFrom:g}";
                
                await LoadRoads();
                
                selectedRoad = roads?.FirstOrDefault(r => r.Id == selectedRoad.Id);
                if (selectedRoad != null)
                {
                    await LoadAllVersions();
                }
                
                isEditMode = false;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to restore historical version";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error restoring historical version: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void EnableEdit()
    {
        if (!IsViewingCurrentVersion())
        {
            if (selectedRoad != null)
            {
                currentViewVersion = selectedRoad;
                UpdateEditModel(currentViewVersion);
            }
        }

        isEditMode = true;
        ClearMessages();

        // Clear staged subdivision changes when entering edit mode
        subdivisionsToAdd.Clear();
        subdivisionsToRemove.Clear();
    }

    private async Task SaveEdit()
    {
        if (editModel == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userEmail = user.Identity?.Name ?? user.Claims.FirstOrDefault(c => c.Type.Contains("email"))?.Value;

            if (!string.IsNullOrEmpty(userEmail))
            {
                editModel.ModifiedBy = userEmail;
            }

            // Save the road first
            var result = await RoadsApi.UpdateRoadAsync(editModel.Id, editModel);

            if (result?.IsSuccess == true)
            {
                // Now apply subdivision changes
                var subdivisionErrors = new List<string>();

                // Remove subdivisions
                foreach (var subdivisionId in subdivisionsToRemove)
                {
                    var removeResult = await RoadsApi.RemoveSubdivisionFromRoadAsync(editModel.Id, subdivisionId);
                    if (removeResult?.IsSuccess != true)
                    {
                        subdivisionErrors.Add($"Failed to remove subdivision ID {subdivisionId}");
                    }
                }

                // Add subdivisions
                foreach (var subdivisionId in subdivisionsToAdd)
                {
                    var addResult = await RoadsApi.AddSubdivisionToRoadAsync(editModel.Id, subdivisionId);
                    if (addResult?.IsSuccess != true)
                    {
                        subdivisionErrors.Add($"Failed to add subdivision ID {subdivisionId}");
                    }
                }

                if (subdivisionErrors.Any())
                {
                    successMessage = "Road updated successfully, but some subdivision changes failed.";
                    errorMessage = string.Join("; ", subdivisionErrors);
                }
                else
                {
                    successMessage = "Road updated successfully!";
                }

                isEditMode = false;

                // Clear staged changes
                subdivisionsToAdd.Clear();
                subdivisionsToRemove.Clear();

                await LoadRoads();
                selectedRoad = roads?.FirstOrDefault(r => r.Id == editModel.Id);

                if (selectedRoad != null)
                {
                    await LoadAllVersions();
                }

                // Prompt user to add a note about the changes
                await PromptForEditNote(editModel.Id, userEmail);
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to update road";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating road: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelEdit()
    {
        if (currentViewVersion != null)
        {
            editModel = CloneRoad(currentViewVersion);
            editContext = new EditContext(editModel);
        }
        isEditMode = false;
        ClearMessages();

        // Clear staged subdivision changes when canceling edit
        subdivisionsToAdd.Clear();
        subdivisionsToRemove.Clear();
    }

    private void ClearMessages()
    {
        errorMessage = null;
        errorDetails = null;
        successMessage = null;
    }

    private Road CloneRoad(Road source) => new()
    {
        Id = source.Id,
        RoadNameId = source.RoadNameId,
        Phase = source.Phase,
        DistanceFeet = source.DistanceFeet,
        StartDescription = source.StartDescription,
        EndDescription = source.EndDescription,
        StartCoordinates = source.StartCoordinates,
        EndCoordinates = source.EndCoordinates,
        ApprovedForMaintenance = source.ApprovedForMaintenance,
        Mpo = source.Mpo,
        LegacySubdivisionName = source.LegacySubdivisionName,
        RoadSurfaceTypeId = source.RoadSurfaceTypeId,
        ResponderCodeId = source.ResponderCodeId,
        ServiceAreaId = source.ServiceAreaId,
        RoadLocation = source.RoadLocation,
        ValidFrom = source.ValidFrom,
        ValidTo = source.ValidTo,
        ModifiedBy = source.ModifiedBy
    };

    private string GetRoadDisplayText(Road road)
    {
        var roadName = roadNames?.FirstOrDefault(rn => rn.Id == road.RoadNameId);
        var name = roadName?.Name ?? "Unknown Road";
        return $"{name}";
    }

    private bool RoadsQuickFilter(Road road, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        // Search in Road Name
        var roadName = roadNames?.FirstOrDefault(rn => rn.Id == road.RoadNameId);
        if (roadName?.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        // Search in Service Area
        var serviceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == road.ServiceAreaId);
        if (serviceArea?.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        return false;
    }

