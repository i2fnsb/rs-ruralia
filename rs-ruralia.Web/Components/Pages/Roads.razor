    private async Task LoadSubdivisionsForRoad()
    {
        if (selectedRoad == null) return;

        try
        {
            var result = await RoadsApi.GetSubdivisionsByRoadIdAsync(selectedRoad.Id);
            if (result?.IsSuccess == true && result.Data != null)
            {
                roadSubdivisionsForSelectedRoad = result.Data;
            }
            else
            {
                roadSubdivisionsForSelectedRoad = Array.Empty<RoadSubdivision>();
            }
        }
