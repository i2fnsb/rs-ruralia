    private async Task<(bool Success, string? ErrorMessage, string[]? Errors)> CreateRoad(Road entity)
    {
        try
        {
            var result = await RoadsApi.CreateRoadAsync(entity);

            if (result?.IsSuccess == true && result.Data != null)
            {
                return (true, null, null);
            }

            return (false, result?.ErrorMessage ?? "Failed to create road", result?.Errors);
        }
        catch (Exception ex)
        {
            return (false, $"Error creating road: {ex.Message}", null);
        }
    }

