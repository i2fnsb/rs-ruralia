    private string GetRoadDisplayText(Road road)
    {
        var roadName = roadNames?.FirstOrDefault(rn => rn.Id == road.RoadNameId);
        var name = roadName?.Name ?? "Unknown Road";
        return $"{name}";
    }

    private bool RoadsQuickFilter(Road road, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        // Search in Road Name
        var roadName = roadNames?.FirstOrDefault(rn => rn.Id == road.RoadNameId);
        if (roadName?.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        // Search in Service Area
        var serviceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == road.ServiceAreaId);
        if (serviceArea?.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        return false;
    }

