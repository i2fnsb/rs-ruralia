    private async Task LoadRelatedRoads()
    {
        if (selectedRoad == null || !selectedRoad.RoadNameId.HasValue) return;

        isLoadingRelatedRoads = true;

        try
        {
            var result = await RoadsApi.GetAllRoadsAsync();

            if (result?.IsSuccess == true && result.Data != null)
            {
                relatedRoads = result.Data
                    .Where(r => r.RoadNameId == selectedRoad.RoadNameId && r.Id != selectedRoad.Id)
                    .OrderBy(r => r.Phase)
                    .ToList();
            }
            else
            {
                relatedRoads = Array.Empty<Road>();
            }
        }
        catch (Exception)
        {
            relatedRoads = Array.Empty<Road>();
        }
        finally
        {
            isLoadingRelatedRoads = false;
        }
    }

    private async Task LoadAllVersions()
    {
        if (selectedRoad == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        var (versions, current, error) = await VersionHistoryHelper.LoadAllVersionsAsync(
            selectedRoad,
            id => RoadsApi.GetRoadHistoryAsync(id),
            x => x.Id,
            x => x.ValidFrom);

        allVersions = versions;
        currentViewVersion = current;
        historyErrorMessage = error;
        UpdateEditModel(currentViewVersion);

        // Load related data
        await LoadRelatedRoads();
        await LoadSubdivisionsForRoad();

        isLoadingHistory = false;
    }

