    private void UpdateEditModel(PersonProfile version)
    {
        editModel = ClonePerson(version);
        editContext = new EditContext(editModel);
        
        if (!IsViewingCurrentVersion())
        {
            isEditMode = false;
        }
    }

    private bool IsViewingCurrentVersion()
    {
        if (currentViewVersion == null || selectedPerson == null)
            return true;

        return currentViewVersion.ValidFrom == selectedPerson.ValidFrom;
    }

    private bool CanEditFields()
    {
        return isEditMode && IsViewingCurrentVersion();
    }

    private async Task HandleItemClick(PersonProfile item)
    {
        selectedPerson = item;
        isEditMode = false;
        ClearMessages();
        await LoadAllVersions();
        await InvokeAsync(StateHasChanged);

        var uri = NavigationManager.GetUriWithQueryParameter("id", selectedPerson.Id);
        NavigationManager.NavigateTo(uri, replace: true);
    }

    private async Task HandleRestore(PersonProfile historicalRecord)
    {
        if (selectedPerson == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var restoredData = ClonePerson(historicalRecord);
            restoredData.Id = selectedPerson.Id;

            var result = await PersonProfilesApi.UpdatePersonProfileAsync(restoredData.Id, restoredData);

            if (result?.IsSuccess == true)
            {
                successMessage = $"Successfully restored version from {historicalRecord.ValidFrom:g}";
                
                await LoadPersonProfiles();
                
                selectedPerson = personProfiles?.FirstOrDefault(p => p.Id == selectedPerson.Id);
                if (selectedPerson != null)
                {
                    await LoadAllVersions();
                }
                
                isEditMode = false;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to restore historical version";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error restoring historical version: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void EnableEdit()
    {
        if (!IsViewingCurrentVersion())
        {
            if (selectedPerson != null)
            {
                currentViewVersion = selectedPerson;
                UpdateEditModel(currentViewVersion);
            }
        }
        
        isEditMode = true;
        ClearMessages();
    }

    private async Task SaveEdit()
    {
        if (editModel == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userEmail = user.Identity?.Name ?? user.Claims.FirstOrDefault(c => c.Type.Contains("email"))?.Value;

            if (!string.IsNullOrEmpty(userEmail))
            {
                editModel.ModifiedBy = userEmail;
            }

            var result = await PersonProfilesApi.UpdatePersonProfileAsync(editModel.Id, editModel);

            if (result?.IsSuccess == true)
            {
                successMessage = "Person profile updated successfully!";
                isEditMode = false;

                await LoadPersonProfiles();
                selectedPerson = personProfiles?.FirstOrDefault(p => p.Id == editModel.Id);

                if (selectedPerson != null)
                {
                    await LoadAllVersions();
                }
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to update person profile";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating person profile: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelEdit()
    {
        if (currentViewVersion != null)
        {
            editModel = ClonePerson(currentViewVersion);
            editContext = new EditContext(editModel);
        }
        isEditMode = false;
        ClearMessages();
    }

    private void ClearMessages()
    {
        errorMessage = null;
        errorDetails = null;
        successMessage = null;
    }

    private PersonProfile ClonePerson(PersonProfile source) => new()
    {
        Id = source.Id,
        PersonHonorificId = source.PersonHonorificId,
        FirstName = source.FirstName,
        PreferredName = source.PreferredName,
        LastName = source.LastName,
        PersonSuffixId = source.PersonSuffixId,
        ValidFrom = source.ValidFrom,
        ValidTo = source.ValidTo,
        ModifiedBy = source.ModifiedBy
    };

    private string GetPersonDisplayText(PersonProfile person)
    {
        var nameParts = new List<string>();

        if (person.PersonHonorificId.HasValue)
        {
            var honorific = personHonorifics?.FirstOrDefault(h => h.Id == person.PersonHonorificId);
            if (!string.IsNullOrEmpty(honorific?.Honorific))
                nameParts.Add(honorific.Honorific);
        }

        if (!string.IsNullOrEmpty(person.FirstName))
            nameParts.Add(person.FirstName);

        if (!string.IsNullOrEmpty(person.PreferredName))
            nameParts.Add($"\"{person.PreferredName}\"");

        if (!string.IsNullOrEmpty(person.LastName))
            nameParts.Add(person.LastName);

        if (person.PersonSuffixId.HasValue)
        {
            var suffix = personSuffixes?.FirstOrDefault(s => s.Id == person.PersonSuffixId);
            if (!string.IsNullOrEmpty(suffix?.Suffix))
                nameParts.Add(suffix.Suffix);
        }

        return nameParts.Any() ? string.Join(" ", nameParts) : $"Person ID: {person.Id}";
    }

    private string GetCommissionSeatDisplayText(CommissionSeat? seat)
    {
        if (seat == null) return "—";
        
        var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
        var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);
        
        return $"{seatType?.Type ?? "Unknown"} - {seatClass?.Class ?? "Unknown"}";
    }

