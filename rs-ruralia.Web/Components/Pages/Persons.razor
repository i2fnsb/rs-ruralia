@page "/persons"
@attribute [Authorize(Policy = Policies.AdminOnly)]
@rendermode InteractiveServer 
@using rs_ruralia.Shared.Enums
@using rs_ruralia.Web.Authorization
@using rs_ruralia.Web.Components.Dialogs
@using rs_ruralia.Web.Helpers
@inject PersonProfilesApiClient PersonProfilesApi
@inject PersonHonorificsApiClient PersonHonorificsApi
@inject PersonSuffixesApiClient PersonSuffixesApi
@inject CorrespondenceProfilesApiClient CorrespondenceProfilesApi
@inject CorrespondenceEmailsApiClient CorrespondenceEmailsApi
@inject CorrespondencePhonesApiClient CorrespondencePhonesApi
@inject CommissionerProfilesApiClient CommissionerProfilesApi
@inject CommissionerStatusesApiClient CommissionerStatusesApi
@inject CommissionSeatsApiClient CommissionSeatsApi
@inject CommissionSeatTypesApiClient CommissionSeatTypesApi
@inject CommissionSeatClassesApiClient CommissionSeatClassesApi
@inject VendorProfilesApiClient VendorProfilesApi
@inject ServiceAreasApiClient ServiceAreasApi
@inject NotesApiClient NotesApi
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDialogService DialogService
@inject ViewModeService ViewModeService

<EntityManagementLayout TEntity="PersonProfile"
                       Title="Persons"
                       Subtitle="Manage person profiles and relationships (Admin Only)"
                       Icon="@Icons.Material.Filled.People"
                       ShowViewModeSelector="false"
                       ListTitle="Persons"
                       ListIcon="@Icons.Material.Filled.Person"
                       SearchPlaceholder="Search persons..."
                       ShowSearch="true"
                       SearchString="@_searchString"
                       ShowTotalCount="true"
                       TotalCount="@(personProfiles?.Count())"
                       CountIcon="@Icons.Material.Filled.People"
                       HasSelection="@(selectedPerson != null)"
                       EntitySingularName="a Person"
                       EntityPluralName="persons"
                       EnableViewModeManagement="false"
                       EnableEditPermissionCheck="true"
                       CanEditChanged="@(async (canEdit) => { this.canEdit = canEdit; await InvokeAsync(StateHasChanged); })"
                       OnEditModeCancelled="@HandleEditModeCancelled"
                       SelectedItem="@selectedPerson"
                       GetSelectedItemDisplayText="@GetPersonDisplayText"
                       ShowSelectedItemChip="true"
                       ShowCreateButton="true"
                       CreateButtonTitle="Create New Person"
                       OnCreateClicked="@OpenCreateDialog"
                       UseBuiltInDataGrid="true"
                       IsLoadingItems="@isLoading"
                       Items="@personProfiles"
                       OnItemClicked="@(async (item) => await HandleItemClick(item))"
                       GetItemIcon="@(p => Icons.Material.Filled.Person)"
                       GetItemDisplayText="@GetPersonDisplayText">

    <AdditionalItemColumns>
        <TemplateColumn T="PersonProfile" Title="Contact">
            <CellTemplate>
                @{
                    var primaryContact = GetPrimaryCorrespondence(context.Item.Id);
                    @(primaryContact?.EmailAddress ?? primaryContact?.PhoneNumber ?? "—")
                }
            </CellTemplate>
        </TemplateColumn>
    </AdditionalItemColumns>

    <!-- Detail Content (Expandable Sections) -->
    <DetailContent>
        <MudExpansionPanels MultiExpansion="true">
            <!-- Details Section -->
            <SectionPanel Title="Details" 
                         Icon="@Icons.Material.Filled.Info" 
                         Expanded="true"
                         MinimumViewMode="ViewMode.Admin">
                <VersionedDetailsPanel TEntity="PersonProfile"
                   AllVersions="@allVersions"
                   CurrentVersion="@currentViewVersion"
                   CurrentVersionChanged="@OnCurrentVersionChanged"
                   GetValidFrom="@(x => x.ValidFrom)"
                   GetValidTo="@(x => x.ValidTo)"
                   GetModifiedBy="@(x => x.ModifiedBy)"
                   GetDisplayText="@GetPersonDisplayText"
                   CanEdit="@(canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))"
                   IsEditMode="@isEditMode"
                   OnEditClicked="@EnableEdit"
                   IsLoading="@(isLoading || isLoadingHistory)"
                   ErrorMessage="@(errorMessage ?? historyErrorMessage)"
                   OnRestore="@HandleRestore">
                    
                    <!-- Edit Mode Content -->
                    <DetailsContent Context="version">
                        @if (editContext != null && editModel != null)
                        {
                            <EditForm EditContext="@editContext" OnValidSubmit="SaveEdit">
                                <DataAnnotationsValidator />
                                <MudGrid>
                                    <MudItem xs="12">
                                        @if (canEdit && IsViewingCurrentVersion() && ViewModeService.IsAtLeast(ViewMode.Admin))
                                        {
                                            @if (isEditMode)
                                            {
                                                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-3">
                                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Disabled="@isSaving">
                                                        @if (isSaving)
                                                        {
                                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                                            <MudText Class="ms-2">Saving...</MudText>
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Filled.Save" Class="me-1" /> <MudText>Save</MudText>
                                                        }
                                                    </MudButton>
                                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="CancelEdit" Disabled="@isSaving">
                                                        Cancel
                                                    </MudButton>
                                                </MudStack>
                                            }
                                        }
                                    </MudItem>

                                    @if (!string.IsNullOrEmpty(successMessage))
                                    {
                                        <MudItem xs="12">
                                            <MudAlert Severity="Severity.Success" Variant="Variant.Filled">@successMessage</MudAlert>
                                        </MudItem>
                                    }

                                    @if (!string.IsNullOrEmpty(errorMessage))
                                    {
                                        <MudItem xs="12">
                                            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                                                <MudText>@errorMessage</MudText>
                                                @if (errorDetails != null && errorDetails.Length > 0)
                                                {
                                                    <MudList T="string" Dense="true">
                                                        @foreach (var detail in errorDetails)
                                                        {
                                                            <MudListItem>@detail</MudListItem>
                                                        }
                                                    </MudList>
                                                }
                                            </MudAlert>
                                        </MudItem>
                                    }

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.PersonHonorificId" 
                                                   TModel="PersonProfile" 
                                                   TValue="int?"
                                                   TLookup="PersonHonorific"
                                                   Property="@(x => x.PersonHonorificId)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   LookupItems="@personHonorifics"
                                                   LookupTextSelector="@(item => ((PersonHonorific)item).Honorific ?? "")"
                                                   For="@(() => editModel.PersonHonorificId)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.FirstName" 
                                                   TModel="PersonProfile" 
                                                   TValue="string" 
                                                   TLookup="object"
                                                   Property="@(x => x.FirstName)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   For="@(() => editModel.FirstName)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.PreferredName" 
                                                   TModel="PersonProfile" 
                                                   TValue="string" 
                                                   TLookup="object"
                                                   Property="@(x => x.PreferredName)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   For="@(() => editModel.PreferredName)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.LastName" 
                                                   TModel="PersonProfile" 
                                                   TValue="string" 
                                                   TLookup="object"
                                                   Property="@(x => x.LastName)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   For="@(() => editModel.LastName)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.PersonSuffixId" 
                                                   TModel="PersonProfile" 
                                                   TValue="int?"
                                                   TLookup="PersonSuffix"
                                                   Property="@(x => x.PersonSuffixId)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   LookupItems="@personSuffixes"
                                                   LookupTextSelector="@(item => ((PersonSuffix)item).Suffix ?? "")"
                                                   For="@(() => editModel.PersonSuffixId)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField Value="editModel.ValidFrom" 
                                                   TModel="PersonProfile" 
                                                   TValue="DateTime?" 
                                                   TLookup="object"
                                                   Property="@(x => x.ValidFrom)"
                                                   ReadOnly="true" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.ModifiedBy" 
                                                   TModel="PersonProfile" 
                                                   TValue="string" 
                                                   TLookup="object"
                                                   Property="@(x => x.ModifiedBy)"
                                                   ReadOnly="true" />
                                    </MudItem>
                                </MudGrid>
                            </EditForm>
                        }
                    </DetailsContent>

                    <!-- View Mode Content -->
                    <ViewModeContent Context="version">
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <InfoCard TValue="string" TModel="PersonProfile"
                                         Label="Full Name" 
                                         Icon="@Icons.Material.Filled.Person"
                                         ValueStyle="font-weight: 600; font-size: 1.3rem;"
                                         PropertyExpression="@(x => x.FirstName)">
                                    <ValueContent>
                                        <MudText Typo="Typo.h6">@GetPersonDisplayText(version)</MudText>
                                    </ValueContent>
                                </InfoCard>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="PersonProfile"
                                         Label="Honorific" 
                                         Icon="@Icons.Material.Filled.Star"
                                         PropertyExpression="@(x => x.PersonHonorificId)">
                                    <ValueContent>
                                        @{
                                            var honorific = personHonorifics?.FirstOrDefault(h => h.Id == version.PersonHonorificId);
                                            <MudText>@(honorific?.Honorific ?? "—")</MudText>
                                        }
                                    </ValueContent>
                                </InfoCard>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="PersonProfile"
                                         Label="Suffix" 
                                         Icon="@Icons.Material.Filled.Badge"
                                         PropertyExpression="@(x => x.PersonSuffixId)">
                                    <ValueContent>
                                        @{
                                            var suffix = personSuffixes?.FirstOrDefault(s => s.Id == version.PersonSuffixId);
                                            <MudText>@(suffix?.Suffix ?? "—")</MudText>
                                        }
                                    </ValueContent>
                                </InfoCard>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="PersonProfile"
                                         Label="First Name" 
                                         Value="@version.FirstName"
                                         Icon="@Icons.Material.Filled.Person"
                                         PropertyExpression="@(x => x.FirstName)" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="PersonProfile"
                                         Label="Last Name" 
                                         Value="@version.LastName"
                                         Icon="@Icons.Material.Filled.PersonOutline"
                                         PropertyExpression="@(x => x.LastName)" />
                            </MudItem>

                            @if (!string.IsNullOrEmpty(version.PreferredName))
                            {
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="PersonProfile"
                                             Label="Preferred Name" 
                                             Value="@version.PreferredName"
                                             Icon="@Icons.Material.Filled.Info"
                                             PropertyExpression="@(x => x.PreferredName)" />
                                </MudItem>
                            }
                        </MudGrid>
                    </ViewModeContent>
                </VersionedDetailsPanel>
            </SectionPanel>

            <!-- Correspondence Profiles -->
            <SectionPanel Title="Correspondence Profiles" 
                         Icon="@Icons.Material.Filled.ContactMail"
                         MinimumViewMode="ViewMode.Admin"
                         ShowCount="true"
                         Count="@(GetCorrespondenceProfiles()?.Count() ?? 0)"
                         CountColor="Color.Info">
                @if (selectedPerson != null)
                {
                    <MudStack Spacing="2">
                        @if (isLoadingCorrespondence)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            var profiles = GetCorrespondenceProfiles();
                            if (profiles != null && profiles.Any())
                            {
                                @foreach (var profile in profiles)
                                {
                                    var email = correspondenceEmails?.FirstOrDefault(e => e.Id == profile.CorrespondenceEmailId);
                                    var phone = correspondencePhones?.FirstOrDefault(p => p.Id == profile.CorrespondencePhoneId);
                                    
                                    <MudCard Outlined="true">
                                        <MudCardContent>
                                            <MudStack Spacing="2">
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.h6">Correspondence</MudText>
                                                    @if (profile.PublicProfile == true)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Public">Public</MudChip>
                                                    }
                                                    else
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Lock">Private</MudChip>
                                                    }
                                                </MudStack>
                                                
                                                @if (profile.Email == true && email != null)
                                                {
                                                    <MudText Typo="Typo.body2">
                                                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" /> @email.Email
                                                    </MudText>
                                                }
                                                
                                                @if (profile.Phone == true && phone != null)
                                                {
                                                    <MudText Typo="Typo.body2">
                                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> @phone.Number
                                                    </MudText>
                                                }
                                            </MudStack>
                                        </MudCardContent>
                                    </MudCard>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No correspondence profiles found.</MudText>
                            }
                        }
                    </MudStack>
                }
            </SectionPanel>

            <!-- Commissioner Profiles -->
            <SectionPanel Title="Commissioner Profiles" 
                         Icon="@Icons.Material.Filled.Groups"
                         MinimumViewMode="ViewMode.Admin"
                         ShowCount="true"
                         Count="@(personCommissionerProfiles?.Count() ?? 0)"
                         CountColor="Color.Primary">
                @if (selectedPerson != null)
                {
                    <MudStack Spacing="2">
                        @if (isLoadingCommissioners)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (personCommissionerProfiles != null && personCommissionerProfiles.Any())
                        {
                            <MudTable T="CommissionerProfile" Items="@personCommissionerProfiles" Hover="true" Striped="true" Dense="true">
                                <HeaderContent>
                                    <MudTh>Commission Seat</MudTh>
                                    <MudTh>Service Area</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Appointed</MudTh>
                                    <MudTh>End Date</MudTh>
                                    <MudTh Style="width: 100px;">Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Commission Seat">
                                        @{
                                            var seat = commissionSeats?.FirstOrDefault(s => s.Id == context.CommissionSeatId);
                                            @GetCommissionSeatDisplayText(seat)
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Service Area">
                                        @{
                                            var seat = commissionSeats?.FirstOrDefault(s => s.Id == context.CommissionSeatId);
                                            var serviceArea = seat != null ? serviceAreas?.FirstOrDefault(sa => sa.Id == seat.ServiceAreaId) : null;
                                            @(serviceArea?.Name ?? "—")
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Status">
                                        @{
                                            var status = commissionerStatuses?.FirstOrDefault(s => s.Id == context.CommissionerStatusId);
                                            <MudChip T="string" Size="Size.Small" Color="@(status?.Active == true ? Color.Success : Color.Default)">
                                                @(status?.Status ?? "—")
                                            </MudChip>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Appointed">@(context.AppointedDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                    <MudTd DataLabel="End Date">@(context.EndDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                    <MudTd DataLabel="Actions">
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                      Size="Size.Small" 
                                                      Color="Color.Primary" 
                                                      OnClick="@(() => NavigationManager.NavigateTo($"/commissioners?id={context.Id}"))" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No commissioner profiles found.</MudText>
                        }
                    </MudStack>
                }
            </SectionPanel>

            <!-- Vendor Profiles -->
            <SectionPanel Title="Vendor Profiles" 
                         Icon="@Icons.Material.Filled.Store"
                         MinimumViewMode="ViewMode.Admin"
                         ShowCount="true"
                         Count="@(personVendorProfiles?.Count() ?? 0)"
                         CountColor="Color.Secondary">
                @if (selectedPerson != null)
                {
                    <MudStack Spacing="2">
                        @if (isLoadingVendors)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (personVendorProfiles != null && personVendorProfiles.Any())
                        {
                            <MudTable T="VendorProfile" Items="@personVendorProfiles" Hover="true" Striped="true" Dense="true">
                                <HeaderContent>
                                    <MudTh>Vendor Name</MudTh>
                                    <MudTh>Vendor ID</MudTh>
                                    <MudTh>Created</MudTh>
                                    <MudTh Style="width: 100px;">Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Vendor Name">@(context.Name ?? "—")</MudTd>
                                    <MudTd DataLabel="Vendor ID">@(context.VendorId ?? "—")</MudTd>
                                    <MudTd DataLabel="Created">@context.ValidFrom.ToString("MMM d, yyyy")</MudTd>
                                    <MudTd DataLabel="Actions">
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                      Size="Size.Small" 
                                                      Color="Color.Primary" 
                                                      OnClick="@(() => NavigationManager.NavigateTo($"/vendors?id={context.Id}"))" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No vendor profiles found.</MudText>
                        }
                    </MudStack>
                }
            </SectionPanel>

            <!-- Notes Section -->
            @if (canEdit)
            {
                <SectionPanel Title="Notes"
                             Icon="@Icons.Material.Filled.Notes"
                             MinimumViewMode="ViewMode.Admin"
                             ShowCount="true"
                             Count="@notesCount"
                             CountColor="Color.Dark">
                    <NotesPanel EntityType="person_profile" 
                               EntityId="@selectedPerson.Id"
                               HighlightedNoteDate="@(currentViewVersion?.ValidFrom)"
                               ShowHistory="true"
                               NotesCountChanged="@OnNotesCountChanged" />
                </SectionPanel>
            }

            <!-- Report Builder Section -->
            @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
            {
                <SectionPanel Title="Report Builder"
                             Icon="@Icons.Material.Filled.Assessment"
                             MinimumViewMode="ViewMode.Admin">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                        Report Builder functionality will be implemented here.
                    </MudAlert>
                </SectionPanel>
            }
        </MudExpansionPanels>
    </DetailContent>
</EntityManagementLayout>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int? PersonId { get; set; }

    private IEnumerable<PersonProfile>? personProfiles;
    private IEnumerable<PersonHonorific>? personHonorifics;
    private IEnumerable<PersonSuffix>? personSuffixes;
    private IEnumerable<CorrespondenceProfile>? correspondenceProfiles;
    private IEnumerable<CorrespondenceEmail>? correspondenceEmails;
    private IEnumerable<CorrespondencePhone>? correspondencePhones;
    private IEnumerable<CommissionerProfile>? commissionerProfiles;
    private IEnumerable<CommissionerProfile>? personCommissionerProfiles;
    private IEnumerable<CommissionerStatus>? commissionerStatuses;
    private IEnumerable<CommissionSeat>? commissionSeats;
    private IEnumerable<CommissionSeatType>? commissionSeatTypes;
    private IEnumerable<CommissionSeatClass>? commissionSeatClasses;
    private IEnumerable<VendorProfile>? vendorProfiles;
    private IEnumerable<VendorProfile>? personVendorProfiles;
    private IEnumerable<ServiceArea>? serviceAreas;
    
    private PersonProfile? selectedPerson;
    private bool isLoading = false;
    private bool isSaving = false;
    private bool isEditMode = false;
    private bool canEdit = false;
    private string? errorMessage;
    private string[]? errorDetails;
    private string? successMessage;
    private PersonProfile? editModel;
    private string _searchString = string.Empty;
    private EditContext? editContext;

    // Version navigation fields
    private IEnumerable<PersonProfile>? allVersions;
    private PersonProfile? currentViewVersion;
    private bool isLoadingHistory = false;
    private string? historyErrorMessage;

    // Notes management field
    private int notesCount = 0;

    // Related data loading
    private bool isLoadingCorrespondence = false;
    private bool isLoadingCommissioners = false;
    private bool isLoadingVendors = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
        SelectPersonFromParameters();
    }

    protected override void OnParametersSet()
    {
        SelectPersonFromParameters();
    }

    private async Task LoadAllData()
    {
        isLoading = true;
        
        var tasks = new List<Task>
        {
            LoadPersonProfiles(),
            LoadPersonHonorifics(),
            LoadPersonSuffixes(),
            LoadCorrespondenceProfiles(),
            LoadCorrespondenceEmails(),
            LoadCorrespondencePhones(),
            LoadCommissionerProfiles(),
            LoadCommissionerStatuses(),
            LoadCommissionSeats(),
            LoadCommissionSeatTypes(),
            LoadCommissionSeatClasses(),
            LoadVendorProfiles(),
            LoadServiceAreas()
        };

        await Task.WhenAll(tasks);
        isLoading = false;
    }

    private void HandleEditModeCancelled()
    {
        if (isEditMode)
        {
            CancelEdit();
        }
    }

    private void SelectPersonFromParameters()
    {
        if (personProfiles == null || !personProfiles.Any() || !PersonId.HasValue)
            return;

        var target = personProfiles.FirstOrDefault(p => p.Id == PersonId.Value);

        if (target != null && selectedPerson?.Id != target.Id)
        {
            selectedPerson = target;
            isEditMode = false;
            ClearMessages();
            _ = LoadAllVersions();
        }
    }

    private async Task LoadPersonProfiles()
    {
        try
        {
            var result = await PersonProfilesApi.GetAllPersonProfilesAsync();
            personProfiles = result?.Data ?? Array.Empty<PersonProfile>();
        }
        catch (Exception)
        {
            personProfiles = Array.Empty<PersonProfile>();
        }
    }

    private async Task LoadPersonHonorifics()
    {
        try
        {
            var result = await PersonHonorificsApi.GetAllPersonHonorificsAsync();
            personHonorifics = result?.Data ?? Array.Empty<PersonHonorific>();
        }
        catch (Exception)
        {
            personHonorifics = Array.Empty<PersonHonorific>();
        }
    }

    private async Task LoadPersonSuffixes()
    {
        try
        {
            var result = await PersonSuffixesApi.GetAllPersonSuffixesAsync();
            personSuffixes = result?.Data ?? Array.Empty<PersonSuffix>();
        }
        catch (Exception)
        {
            personSuffixes = Array.Empty<PersonSuffix>();
        }
    }

    private async Task LoadCorrespondenceProfiles()
    {
        try
        {
            var result = await CorrespondenceProfilesApi.GetAllCorrespondenceProfilesAsync();
            correspondenceProfiles = result?.Data ?? Array.Empty<CorrespondenceProfile>();
        }
        catch (Exception)
        {
            correspondenceProfiles = Array.Empty<CorrespondenceProfile>();
        }
    }

    private async Task LoadCorrespondenceEmails()
    {
        try
        {
            var result = await CorrespondenceEmailsApi.GetAllCorrespondenceEmailsAsync();
            correspondenceEmails = result?.Data ?? Array.Empty<CorrespondenceEmail>();
        }
        catch (Exception)
        {
            correspondenceEmails = Array.Empty<CorrespondenceEmail>();
        }
    }

    private async Task LoadCorrespondencePhones()
    {
        try
        {
            var result = await CorrespondencePhonesApi.GetAllCorrespondencePhonesAsync();
            correspondencePhones = result?.Data ?? Array.Empty<CorrespondencePhone>();
        }
        catch (Exception)
        {
            correspondencePhones = Array.Empty<CorrespondencePhone>();
        }
    }

    private async Task LoadCommissionerProfiles()
    {
        try
        {
            var result = await CommissionerProfilesApi.GetAllCommissionerProfilesAsync();
            commissionerProfiles = result?.Data ?? Array.Empty<CommissionerProfile>();
        }
        catch (Exception)
        {
            commissionerProfiles = Array.Empty<CommissionerProfile>();
        }
    }

    private async Task LoadCommissionerStatuses()
    {
        try
        {
            var result = await CommissionerStatusesApi.GetAllCommissionerStatusesAsync();
            commissionerStatuses = result?.Data ?? Array.Empty<CommissionerStatus>();
        }
        catch (Exception)
        {
            commissionerStatuses = Array.Empty<CommissionerStatus>();
        }
    }

    private async Task LoadCommissionSeats()
    {
        try
        {
            var result = await CommissionSeatsApi.GetAllCommissionSeatsAsync();
            commissionSeats = result?.Data ?? Array.Empty<CommissionSeat>();
        }
        catch (Exception)
        {
            commissionSeats = Array.Empty<CommissionSeat>();
        }
    }

    private async Task LoadCommissionSeatTypes()
    {
        try
