    private void LoadPersonRelationships()
    {
        if (selectedPerson == null) return;

        isLoadingCommissioners = true;
        isLoadingVendors = true;

        try
        {
            // Load commissioner profiles for this person
            personCommissionerProfiles = commissionerProfiles?
                .Where(cp => cp.PersonProfileId == selectedPerson.Id)
                .OrderByDescending(cp => cp.AppointedDate)
                .ToList();

            // TODO: Load vendor profiles for this person
            // VendorProfile doesn't have PersonProfileId - need to determine relationship
            // It might be through a junction table or another mechanism
            // For now, return empty list
            personVendorProfiles = Array.Empty<VendorProfile>();
        }
        catch (Exception)
        {
            personCommissionerProfiles = Array.Empty<CommissionerProfile>();
            personVendorProfiles = Array.Empty<VendorProfile>();
        }
        finally
        {
            isLoadingCommissioners = false;
            isLoadingVendors = false;
        }
    }

    private IEnumerable<CorrespondenceProfile>? GetCorrespondenceProfiles()
    {
        if (selectedPerson == null) return null;

        return correspondenceProfiles?
            .Where(cp => cp.PersonProfileId == selectedPerson.Id)
            .ToList();
    }

    private (string? PhoneNumber, string? EmailAddress)? GetPrimaryCorrespondence(int personProfileId)
    {
        var correspondence = correspondenceProfiles?
            .FirstOrDefault(cp => cp.PersonProfileId == personProfileId);

        if (correspondence == null)
            return null;

        string? phoneNumber = null;
        if (correspondence.Phone == true && correspondence.CorrespondencePhoneId.HasValue)
        {
            var phone = correspondencePhones?.FirstOrDefault(p => p.Id == correspondence.CorrespondencePhoneId);
            phoneNumber = phone?.Number;
        }

        string? emailAddress = null;
        if (correspondence.Email == true && correspondence.CorrespondenceEmailId.HasValue)
        {
            var email = correspondenceEmails?.FirstOrDefault(e => e.Id == correspondence.CorrespondenceEmailId);
            emailAddress = email?.Email;
        }

        if (!string.IsNullOrEmpty(phoneNumber) || !string.IsNullOrEmpty(emailAddress))
        {
            return (phoneNumber, emailAddress);
        }

        return null;
    }

    private async Task LoadAllVersions()
    {
        if (selectedPerson == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        try
        {
            var historyResult = await PersonProfilesApi.GetPersonProfileHistoryAsync(selectedPerson.Id);
            var historyRecords = new List<PersonProfile>();

            if (historyResult?.IsSuccess == true && historyResult.Data != null)
            {
                historyRecords.AddRange(historyResult.Data);
            }

            var versions = new List<PersonProfile> { selectedPerson };
            versions.AddRange(historyRecords.Where(h => h.ValidFrom != selectedPerson.ValidFrom));
            
            allVersions = versions;
            currentViewVersion = selectedPerson;
            UpdateEditModel(currentViewVersion);

            // Load related data
            LoadPersonRelationships();
        }
        catch (Exception ex)
        {
            historyErrorMessage = $"Error loading versions: {ex.Message}";
            allVersions = new List<PersonProfile> { selectedPerson };
            currentViewVersion = selectedPerson;
            UpdateEditModel(currentViewVersion);
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private async Task OnCurrentVersionChanged(PersonProfile newVersion)
    {
        currentViewVersion = newVersion;
        UpdateEditModel(newVersion);
        await InvokeAsync(StateHasChanged);
    }

    private void OnNotesCountChanged(int count)
    {
        notesCount = count;
