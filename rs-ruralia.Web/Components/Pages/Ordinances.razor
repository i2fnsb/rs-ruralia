@page "/ordinances"
@rendermode InteractiveServer
@using rs_ruralia.Shared.Enums
@using rs_ruralia.Web.Components.Dialogs
@inject OrdinancesApiClient OrdinancesApi
@inject OrdinanceTypesApiClient OrdinanceTypesApi
@inject ServiceAreasApiClient ServiceAreasApi
@inject NotesApiClient NotesApi
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDialogService DialogService
@inject ViewModeService ViewModeService

<EntityManagementLayout TEntity="Ordinance"
                       Title="Ordinances"
                       Subtitle="Manage and view rural service area ordinances and regulations"
                       Icon="@Icons.Material.Filled.Gavel"
                       ShowViewModeSelector="true"
                       ListTitle="Ordinances"
                       ListIcon="@Icons.Material.Filled.Gavel"
                       SearchPlaceholder="Search ordinances..."
                       ShowSearch="true"
                       SearchString="@_searchString"
                       CustomQuickFilter="@OrdinancesQuickFilter"
                       ShowTotalCount="true"
                       TotalCount="@(ordinances?.Count())"
                       CountIcon="@Icons.Material.Filled.Description"
                       HasSelection="@(selectedOrdinance != null)"
                       EntitySingularName="Ordinance"
                       EntityPluralName="ordinances"
                       EnableViewModeManagement="true"
                       EnableEditPermissionCheck="true"
                       CanEditChanged="@(async (canEdit) => { this.canEdit = canEdit; await InvokeAsync(StateHasChanged); })"
                       OnEditModeCancelled="@HandleEditModeCancelled"
                       SelectedItem="@selectedOrdinance"
                       GetSelectedItemDisplayText="@(o => $"{o.OrdinanceName} ({o.OrdinanceYear})")"
                       ShowSelectedItemChip="true"
                       ShowCreateButton="true"
                       CreateButtonTitle="Create New Ordinance"
                       OnCreateClicked="@OpenCreateDialog"
                       UseBuiltInDataGrid="true"
                       IsLoadingItems="@isLoading"
                       Items="@ordinances"
                       OnItemClicked="@(async (item) => await HandleItemClick(item))"
                       GetItemIcon="@(o => Icons.Material.Filled.Gavel)"
                       GetItemDisplayText="@(o => o.OrdinanceName ?? "")">

    <AdditionalItemColumns>
        <PropertyColumn T="Ordinance" TProperty="int?" Property="@(x => x.OrdinanceYear)" Title="Year" />
    </AdditionalItemColumns>

    <!-- Detail Content (Expandable Sections) -->
    <DetailContent>
        <MudExpansionPanels MultiExpansion="true">
            <!-- Details Section -->
            <SectionPanel Title="Details" 
                         Icon="@Icons.Material.Filled.Info" 
                         Expanded="true"
                         MinimumViewMode="ViewMode.Public">
                <VersionedDetailsPanel TEntity="Ordinance"
                   AllVersions="@allVersions"
                   CurrentVersion="@currentViewVersion"
                   CurrentVersionChanged="@OnCurrentVersionChanged"
                   GetValidFrom="@(x => x.ValidFrom)"
                   GetValidTo="@(x => x.ValidTo)"
                   GetModifiedBy="@(x => x.ModifiedBy)"
                   GetDisplayText="@(x => $"{x.OrdinanceName} ({x.OrdinanceYear})")"
                   CanEdit="@(canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))"
                   IsEditMode="@isEditMode"
                   OnEditClicked="@EnableEdit"
                   IsLoading="@(isLoading || isLoadingHistory)"
                   ErrorMessage="@(errorMessage ?? historyErrorMessage)"
                   OnRestore="@HandleRestore">
                    <!-- Edit Mode Content -->
                    <DetailsContent Context="version">
                        @if (editContext != null && editModel != null)
                        {
                            <EditForm EditContext="@editContext" OnValidSubmit="SaveEdit">
                                <DataAnnotationsValidator />
                                <MudGrid>
                                    @if (canEdit && IsViewingCurrentVersion() && ViewModeService.IsAtLeast(ViewMode.Admin) && isEditMode)
                                    {
                                        <MudItem xs="12">
                                            <SaveCancelButtons IsSaving="@isSaving" OnCancel="@CancelEdit" />
                                        </MudItem>
                                    }

                                    <AlertMessages SuccessMessage="@successMessage" 
                                                  ErrorMessage="@errorMessage" 
                                                  ErrorDetails="@errorDetails" />

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.OrdinanceName" 
                                                   TModel="Ordinance" 
                                                   TValue="string" 
                                                   TLookup="object"
                                                   Property="@(x => x.OrdinanceName)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   For="@(() => editModel.OrdinanceName)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.OrdinanceYear" 
                                                   TModel="Ordinance" 
                                                   TValue="int?" 
                                                   TLookup="object"
                                                   Property="@(x => x.OrdinanceYear)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   For="@(() => editModel.OrdinanceYear)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.OrdinancePassed" 
                                                   TModel="Ordinance" 
                                                   TValue="bool?" 
                                                   TLookup="object"
                                                   Property="@(x => x.OrdinancePassed)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   For="@(() => editModel.OrdinancePassed)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.OrdinanceTypeId" 
                                                   TModel="Ordinance" 
                                                   TValue="int?"
                                                   TLookup="OrdinanceType"
                                                   Property="@(x => x.OrdinanceTypeId)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   LookupItems="@ordinanceTypes"
                                                   LookupTextSelector="@(item => $"{((OrdinanceType)item).Type} - {((OrdinanceType)item).Description}")"
                                                   ForeignKeyIdSelector="@(x => x.Id)"
                                                   ForeignKeyNameSelector="@(x => x.Type ?? "")"
                                                   ForeignKeyDescriptionSelector="@(x => x.Description ?? "")"
                                                   OnForeignKeyCreate="@CreateOrdinanceType"
                                                   OnForeignKeyUpdate="@UpdateOrdinanceType"
                                                   OnForeignKeyDelete="@DeleteOrdinanceType"
                                                   OnForeignKeyDataChanged="@(EventCallback.Factory.Create(this, LoadOrdinanceTypes))"
                                                   ForeignKeyDialogTitle="Manage Ordinance Types"
                                                   For="@(() => editModel.OrdinanceTypeId)">
                                            <ForeignKeyFormContent Context="entity">
                                                <MudItem xs="12">
                                                    <AutoField @bind-Value="entity.Type" 
                                                               TModel="OrdinanceType" 
                                                               TValue="string"
                                                               TLookup="object"
                                                               Property="@(x => x.Type)"
                                                               For="@(() => entity.Type)" />
                                                </MudItem>
                                                <MudItem xs="12">
                                                    <AutoField @bind-Value="entity.Description" 
                                                               TModel="OrdinanceType" 
                                                               TValue="string"
                                                               TLookup="object"
                                                               Property="@(x => x.Description)"
                                                               For="@(() => entity.Description)" />
                                                </MudItem>
                                            </ForeignKeyFormContent>
                                        </AutoField>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.ServiceAreaId" 
                                                   TModel="Ordinance" 
                                                   TValue="int?"
                                                   TLookup="ServiceArea"
                                                   Property="@(x => x.ServiceAreaId)"
                                                   ReadOnly="@(!CanEditFields())"
                                                   LookupItems="@serviceAreas"
                                                   LookupTextSelector="@(item => ((ServiceArea)item).Name ?? "")"
                                                   For="@(() => editModel.ServiceAreaId)" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField Value="editModel.ValidFrom" 
                                                   TModel="Ordinance" 
                                                   TValue="DateTime?" 
                                                   TLookup="object"
                                                   Property="@(x => x.ValidFrom)"
                                                   ReadOnly="true" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <AutoField @bind-Value="editModel.ModifiedBy" 
                                                   TModel="Ordinance" 
                                                   TValue="string" 
                                                   TLookup="object"
                                                   Property="@(x => x.ModifiedBy)"
                                                   ReadOnly="true" />
                                    </MudItem>
                                </MudGrid>
                            </EditForm>
                        }
                    </DetailsContent>

                    <!-- View Mode Content -->
                    <ViewModeContent Context="version">
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="Ordinance"
                                         Label="Ordinance Name" 
                                         Value="@version.OrdinanceName" 
                                         Icon="@Icons.Material.Filled.Gavel"
                                         ValueStyle="font-weight: 600; font-size: 1.1rem;"
                                         PropertyExpression="@(x => x.OrdinanceName)" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="Ordinance"
                                         Label="Year" 
                                         Value="@(version.OrdinanceYear?.ToString())"
                                         Icon="@Icons.Material.Filled.CalendarToday"
                                         PropertyExpression="@(x => x.OrdinanceYear)" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <BooleanInfoCard TModel="Ordinance"
                                               Value="@version.OrdinancePassed"
                                               Label="Ordinance Passed" 
                                               Icon="@Icons.Material.Filled.HowToVote"
                                               FalseColor="Color.Error"
                                               PropertyExpression="@(x => x.OrdinancePassed)" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="Ordinance"
                                         Label="Ordinance Type" 
                                         Icon="@Icons.Material.Filled.Category"
                                         PropertyExpression="@(x => x.OrdinanceTypeId)">
                                    <ValueContent>
                                        @{
                                            var type = ordinanceTypes?.FirstOrDefault(t => t.Id == version.OrdinanceTypeId);
                                            <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                                @(type != null ? $"{type.Type} - {type.Description}" : "—")
                                            </MudText>
                                        }
                                    </ValueContent>
                                </InfoCard>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <InfoCard TValue="string" TModel="Ordinance"
                                         Label="Service Area" 
                                         Icon="@Icons.Material.Filled.Landscape"
                                         PropertyExpression="@(x => x.ServiceAreaId)">
                                    <ValueContent>
                                        @{
                                            var serviceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == version.ServiceAreaId);
                                            if (serviceArea != null)
                                            {
                                                <MudButton Variant="Variant.Text" 
                                                          Color="Color.Primary" 
                                                          Size="Size.Small"
                                                          StartIcon="@Icons.Material.Filled.OpenInNew"
                                                          OnClick="@(() => NavigationManager.NavigateTo($"/service-areas?id={serviceArea.Id}"))">
                                                    @serviceArea.Name
                                                </MudButton>
                                            }
                                            else
                                            {
                                                <MudText>—</MudText>
                                            }
                                        }
                                    </ValueContent>
                                </InfoCard>
                            </MudItem>
                        </MudGrid>
                    </ViewModeContent>
                </VersionedDetailsPanel>
            </SectionPanel>

            <!-- Notes Section -->
            @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
            {
                <SectionPanel Title="Notes"
                             Icon="@Icons.Material.Filled.Notes"
                             MinimumViewMode="ViewMode.Admin"
                             ShowCount="true"
                             Count="@notesCount"
                             CountColor="Color.Dark">
                    <NotesPanel EntityType="ordinance" 
                               EntityId="@selectedOrdinance.Id"
                               HighlightedNoteDate="@(currentViewVersion?.ValidFrom)"
                               ShowHistory="true"
                               NotesCountChanged="@OnNotesCountChanged" />
                </SectionPanel>
            }
        </MudExpansionPanels>
    </DetailContent>
</EntityManagementLayout>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int? OrdinanceId { get; set; }

    private IEnumerable<Ordinance>? ordinances;
    private IEnumerable<OrdinanceType>? ordinanceTypes;
    private IEnumerable<ServiceArea>? serviceAreas;
    private Ordinance? selectedOrdinance;

    // Notes management field
    private int notesCount = 0;
    private bool isLoading = false;
    private bool isSaving = false;
    private bool isEditMode = false;
    private bool canEdit = false;
    private string? errorMessage;
    private string[]? errorDetails;
    private string? successMessage;
    private Ordinance? editModel;
    private string _searchString = string.Empty;
    private EditContext? editContext;

    // Version navigation fields
    private IEnumerable<Ordinance>? allVersions;
    private Ordinance? currentViewVersion;
    private bool isLoadingHistory = false;
    private string? historyErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrdinances();
        await LoadOrdinanceTypes();
        await LoadServiceAreas();
        SelectOrdinanceFromParameters();
    }

    protected override void OnParametersSet()
    {
        SelectOrdinanceFromParameters();
    }

    private void HandleEditModeCancelled()
    {
        EntityPageHelper.HandleEditModeCancelled(isEditMode, CancelEdit);
    }

    private void SelectOrdinanceFromParameters()
    {
        if (ordinances == null || !ordinances.Any() || !OrdinanceId.HasValue)
            return;

        var targetOrdinance = ordinances.FirstOrDefault(o => o.Id == OrdinanceId.Value);

        if (targetOrdinance != null && selectedOrdinance?.Id != targetOrdinance.Id)
        {
            selectedOrdinance = targetOrdinance;
            isEditMode = false;
            ClearMessages();
            _ = LoadAllVersions();
        }
    }

    private async Task LoadOrdinances()
    {
        isLoading = true;
        ClearMessages();

        ordinances = await DataLoaderHelper.LoadDataWithErrorHandlingAsync(
            () => OrdinancesApi.GetAllOrdinancesAsync(),
            onError: (error, errors) =>
            {
                errorMessage = error ?? "Failed to load ordinances";
                errorDetails = errors;
            });

        isLoading = false;
    }

    private async Task LoadOrdinanceTypes()
    {
        ordinanceTypes = await DataLoaderHelper.LoadDataAsync(() => OrdinanceTypesApi.GetAllOrdinanceTypesAsync());
    }

    private async Task LoadServiceAreas()
    {
        serviceAreas = await DataLoaderHelper.LoadDataAsync(() => ServiceAreasApi.GetAllServiceAreasAsync());
    }

    private async Task LoadAllVersions()
    {
        if (selectedOrdinance == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        var (versions, current, error) = await VersionHistoryHelper.LoadAllVersionsAsync(
            selectedOrdinance,
            id => OrdinancesApi.GetOrdinanceHistoryAsync(id),
            x => x.Id,
            x => x.ValidFrom);

        allVersions = versions;
        currentViewVersion = current;
        historyErrorMessage = error;
        UpdateEditModel(currentViewVersion);

        isLoadingHistory = false;
    }

    private async Task OnCurrentVersionChanged(Ordinance newVersion)
    {
        currentViewVersion = newVersion;
        UpdateEditModel(newVersion);
        await InvokeAsync(StateHasChanged);
    }

    private void OnNotesCountChanged(int count)
    {
        notesCount = count;
        StateHasChanged();
    }

    private void UpdateEditModel(Ordinance version)
    {
        editModel = CloneOrdinance(version);
        editContext = new EditContext(editModel);
        
        if (!IsViewingCurrentVersion())
        {
            isEditMode = false;
        }
    }

    private bool IsViewingCurrentVersion()
    {
        return EntityPageHelper.IsViewingCurrentVersion(currentViewVersion, selectedOrdinance, x => x.ValidFrom);
    }

    private bool CanEditFields()
    {
        return EntityPageHelper.CanEditFields(isEditMode, IsViewingCurrentVersion());
    }

    private async Task HandleItemClick(Ordinance item)
    {
        selectedOrdinance = item;
        isEditMode = false;
        ClearMessages();
        await LoadAllVersions();
        await InvokeAsync(StateHasChanged);

        NavigationHelper.UpdateUrlWithSelection(NavigationManager, selectedOrdinance.Id);
    }

    private async Task HandleRestore(Ordinance historicalRecord)
    {
        if (selectedOrdinance == null) return;

        isSaving = true;
        ClearMessages();

        var (success, errorMsg, errors) = await VersionHistoryHelper.HandleRestoreAsync(
            selectedOrdinance,
            historicalRecord,
            CloneOrdinance,
            (entity, id) => entity.Id = id,
            (id, entity) => OrdinancesApi.UpdateOrdinanceAsync(id, entity),
            x => x.Id,
            x => x.ValidFrom);

        if (success)
        {
            successMessage = errorMsg;
            await LoadOrdinances();
            selectedOrdinance = ordinances?.FirstOrDefault(o => o.Id == selectedOrdinance.Id);
            if (selectedOrdinance != null)
            {
                await LoadAllVersions();
            }
            isEditMode = false;
        }
        else
        {
            errorMessage = errorMsg;
            errorDetails = errors;
        }

        isSaving = false;
    }

    private void EnableEdit()
    {
        if (!IsViewingCurrentVersion())
        {
            if (selectedOrdinance != null)
            {
                currentViewVersion = selectedOrdinance;
                UpdateEditModel(currentViewVersion);
            }
        }
        
        isEditMode = true;
        ClearMessages();
    }

    private async Task SaveEdit()
    {
        if (editModel == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var userEmail = await AuthenticationHelper.SetModifiedByAsync(
                editModel,
                AuthenticationStateProvider,
                (entity, email) => entity.ModifiedBy = email);

            var result = await OrdinancesApi.UpdateOrdinanceAsync(editModel.Id, editModel);

            if (result?.IsSuccess == true)
            {
                successMessage = "Ordinance updated successfully!";
                isEditMode = false;

                await LoadOrdinances();
                selectedOrdinance = ordinances?.FirstOrDefault(o => o.Id == editModel.Id);

                if (selectedOrdinance != null)
                {
                    await LoadAllVersions();
                }

                // Prompt user to add a note about the changes
                await PromptForEditNote(editModel.Id, userEmail);
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to update ordinance";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating ordinance: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelEdit()
    {
        if (currentViewVersion != null)
        {
            editModel = CloneOrdinance(currentViewVersion);
            editContext = new EditContext(editModel);
        }
        isEditMode = false;
        ClearMessages();
    }

    private void ClearMessages()
    {
        EntityPageHelper.ClearMessages(ref errorMessage, ref errorDetails, ref successMessage);
    }

    private Ordinance CloneOrdinance(Ordinance source) => EntityCloneHelper.ShallowClone(source);

    private bool OrdinancesQuickFilter(Ordinance ordinance, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        // Search in Ordinance Name
        if (ordinance.OrdinanceName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        // Search in Ordinance Year
        if (ordinance.OrdinanceYear?.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        return false;
    }

    private async Task<bool> CreateOrdinanceType(OrdinanceType entity)
    {
        var result = await OrdinanceTypesApi.CreateOrdinanceTypeAsync(entity);
        return result?.IsSuccess ?? false;
    }

    private async Task<bool> UpdateOrdinanceType(OrdinanceType entity)
    {
        var result = await OrdinanceTypesApi.UpdateOrdinanceTypeAsync(entity.Id, entity);
        return result?.IsSuccess ?? false;
    }

    private async Task<bool> DeleteOrdinanceType(OrdinanceType entity)
    {
        var result = await OrdinanceTypesApi.DeleteOrdinanceTypeAsync(entity.Id);
        return result?.IsSuccess ?? false;
    }

    private async Task PromptForEditNote(int ordinanceId, string? userEmail)
    {
        await NotesHelper.PromptForEditNoteAsync(
            DialogService,
            $"{selectedOrdinance?.OrdinanceName} ({selectedOrdinance?.OrdinanceYear})",
            OnNotesCountChanged,
            async (id, text) => await CreateEditNote(id, text, userEmail),
            ordinanceId,
            userEmail);
    }

    private async Task CreateEditNote(int ordinanceId, string noteText, string? userEmail)
    {    var note = NotesHelper.CreateOrdinanceNote(ordinanceId, noteText, userEmail);
        await NotesHelper.CreateNoteAsync(
            note,
            NotesApi.CreateNoteAsync,
            () => InvokeAsync(StateHasChanged));
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<CreateEntityDialog<Ordinance>>
        {
            { x => x.EntityDisplayName, "Ordinance" },
            { x => x.Description, "Create a new ordinance record. All fields marked with * are required." },
            { x => x.OnCreate, new Func<Ordinance, Task<(bool, string?, string[]?)>>(CreateOrdinance) },
            { x => x.AutoSetModifiedBy, true },
            { x => x.FormContent, GetOrdinanceFormContent() }
        };

        var options = new DialogOptions 
        { 
            CloseButton = true, 
            MaxWidth = MaxWidth.Large, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<CreateEntityDialog<Ordinance>>("Create New Ordinance", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Ordinance createdOrdinance)
        {
            await LoadOrdinances();

            selectedOrdinance = ordinances?.FirstOrDefault(o => o.Id == createdOrdinance.Id);
            if (selectedOrdinance != null)
            {
                await LoadAllVersions();

                var uri = NavigationManager.GetUriWithQueryParameter("id", selectedOrdinance.Id);
                NavigationManager.NavigateTo(uri, replace: true);
            }

            successMessage = $"Ordinance '{createdOrdinance.OrdinanceName}' created successfully!";
            await InvokeAsync(StateHasChanged);
        }
    }

    private RenderFragment<Ordinance> GetOrdinanceFormContent() => entity => __builder =>
    {
        <MudItem xs="12" md="6">
            <AutoField @bind-Value="entity.OrdinanceName" 
                       TModel="Ordinance" 
                       TValue="string" 
                       TLookup="object"
                       Property="@(x => x.OrdinanceName)"
                       For="@(() => entity.OrdinanceName)" />
        </MudItem>
        <MudItem xs="12" md="6">
            <AutoField @bind-Value="entity.OrdinanceYear" 
                       TModel="Ordinance" 
                       TValue="int?" 
                       TLookup="object"
                       Property="@(x => x.OrdinanceYear)"
                       For="@(() => entity.OrdinanceYear)" />
        </MudItem>
        <MudItem xs="12" md="6">
            <AutoField @bind-Value="entity.OrdinancePassed" 
                       TModel="Ordinance" 
                       TValue="bool?" 
                       TLookup="object"
                       Property="@(x => x.OrdinancePassed)"
                       For="@(() => entity.OrdinancePassed)" />
        </MudItem>
        <MudItem xs="12" md="6">
            <AutoField @bind-Value="entity.OrdinanceTypeId" 
                       TModel="Ordinance" 
                       TValue="int?"
                       TLookup="OrdinanceType"
                       Property="@(x => x.OrdinanceTypeId)"
                       LookupItems="@ordinanceTypes"
                       LookupTextSelector="@(item => $"{((OrdinanceType)item).Type} - {((OrdinanceType)item).Description}")"
                       For="@(() => entity.OrdinanceTypeId)" />
        </MudItem>
        <MudItem xs="12" md="6">
            <AutoField @bind-Value="entity.ServiceAreaId" 
                       TModel="Ordinance" 
                       TValue="int?"
                       TLookup="ServiceArea"
                       Property="@(x => x.ServiceAreaId)"
                       LookupItems="@serviceAreas"
                       LookupTextSelector="@(item => ((ServiceArea)item).Name ?? "")"
                       For="@(() => entity.ServiceAreaId)" />
        </MudItem>
    };

    private async Task<(bool Success, string? ErrorMessage, string[]? ErrorDetails)> CreateOrdinance(Ordinance entity)
    {
        try
        {
            var result = await OrdinancesApi.CreateOrdinanceAsync(entity);

            if (result?.IsSuccess == true && result.Data != null)
            {
                entity.Id = result.Data.Id;
                entity.ValidFrom = result.Data.ValidFrom;

                return (true, null, null);
            }
            else
            {
                return (false, result?.ErrorMessage ?? "Failed to create ordinance", result?.Errors);
            }
        }
        catch (Exception ex)
        {
            return (false, $"Error creating ordinance: {ex.Message}", null);
        }
    }
}