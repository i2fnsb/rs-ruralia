        NavigationHelper.UpdateUrlWithSelection(NavigationManager, selectedServiceArea.Id);
    }

    private void EnableEditForSeat(int seatId)
    {
        var seat = allSeatsForServiceArea?.FirstOrDefault(s => s.Id == seatId);
        if (seat != null)
        {
            editingSeatId = seatId;
            editModel = CloneSeat(seat);
            editContext = new EditContext(editModel);
            ClearMessages();
        }
    }

    private async Task SaveSeatEdit(int seatId)
    {
        if (editModel == null || editModel.Id != seatId) return;

        isSaving = true;
        ClearMessages();

        var userEmail = await AuthenticationHelper.SetModifiedByAsync(
            editModel,
            AuthenticationStateProvider,
            (entity, email) => entity.ModifiedBy = email);

        var (success, errorMsg, errors, updatedEntity) = await VersionHistoryHelper.SaveEditAsync(
            editModel,
            (id, entity) => CommissionSeatsApi.UpdateCommissionSeatAsync(id, entity),
            x => x.Id,
            "Commission seat updated successfully!");

        if (success)
        {
            successMessage = errorMsg;
            editingSeatId = null;

            await LoadCommissionSeats();
            seatVersionCache.Remove(seatId);
            LoadAllSeatsForServiceArea();

            var updatedSeat = allSeatsForServiceArea?.FirstOrDefault(s => s.Id == seatId);
            if (updatedSeat != null)
            {
                currentlyDisplayedVersions[seatId] = updatedSeat;
                _ = LoadSeatVersionsAsync(seatId);
            }

            await InvokeAsync(StateHasChanged);
            await PromptForEditNote(seatId, userEmail);
        }
        else
        {
            errorMessage = errorMsg;
            errorDetails = errors;
        }

        isSaving = false;
    }

    private async Task HandleRestoreVersion(int seatId, CommissionSeat historicalVersion)
    {
        if (historicalVersion == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var restoredData = CloneSeat(historicalVersion);
            restoredData.Id = seatId;

            var userEmail = await AuthenticationHelper.SetModifiedByAsync(
                restoredData,
                AuthenticationStateProvider,
                (entity, email) => entity.ModifiedBy = email);

            var result = await CommissionSeatsApi.UpdateCommissionSeatAsync(seatId, restoredData);

            if (result?.IsSuccess == true)
            {
                successMessage = $"Successfully restored version from {historicalVersion.ValidFrom:g}";

                await LoadCommissionSeats();

                seatVersionCache.Remove(seatId);
                currentlyDisplayedVersions.Remove(seatId);

                LoadAllSeatsForServiceArea();

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to restore historical version";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error restoring historical version: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task PromptForEditNote(int entityId, string? userEmail)
    {
        var seat = allSeatsForServiceArea?.FirstOrDefault(s => s.Id == entityId);
        var seatName = seat != null ? GetSeatDisplayText(seat) : "Commission Seat";

        await NotesHelper.PromptForEditNoteAsync(
            DialogService,
            seatName,
            (count) => { /* Note count handled per seat */ },
            async (id, text) => await CreateEditNote(id, text, userEmail),
            entityId,
            userEmail);
    }

    private async Task CreateEditNote(int seatId, string noteText, string? userEmail)
    {
        var note = NotesHelper.CreateCommissionSeatNote(seatId, noteText, userEmail);

        await NotesHelper.CreateNoteAsync(
            note,
            NotesApi.CreateNoteAsync,
            () =>
            {
                // Increment refresh key to force NotesPanel to reload
                if (notesPanelRefreshKeys.ContainsKey(seatId))
                {
                    notesPanelRefreshKeys[seatId]++;
                }
                else
                {
                    notesPanelRefreshKeys[seatId] = 1;
                }
                InvokeAsync(StateHasChanged);
            });
    }

