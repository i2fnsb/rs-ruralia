@page "/commission-seats"
@rendermode InteractiveServer 
@using rs_ruralia.Shared.Enums
@using rs_ruralia.Web.Components.Dialogs
@using rs_ruralia.Web.Helpers
@inject CommissionSeatsApiClient CommissionSeatsApi
@inject CommissionSeatTypesApiClient CommissionSeatTypesApi
@inject CommissionSeatClassesApiClient CommissionSeatClassesApi
@inject CommissionSeatStatusesApiClient CommissionSeatStatusesApi
@inject ServiceAreasApiClient ServiceAreasApi
@inject CommissionerProfilesApiClient CommissionerProfilesApi
@inject CommissionerStatusesApiClient CommissionerStatusesApi
@inject PersonProfilesApiClient PersonProfilesApi
@inject PersonHonorificsApiClient PersonHonorificsApi
@inject PersonSuffixesApiClient PersonSuffixesApi
@inject NotesApiClient NotesApi
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDialogService DialogService
@inject ViewModeService ViewModeService

<EntityManagementLayout TEntity="ServiceArea"
                       Title="Commission Seats"
                       Subtitle="Manage commission seat assignments and commissioners"
                       Icon="@Icons.Material.Filled.EventSeat"
                       ShowViewModeSelector="true"
                       ListTitle="Service Areas"
                       ListIcon="@Icons.Material.Filled.Landscape"
                       SearchPlaceholder="Search service areas..."
                       ShowSearch="true"
                       SearchString="@_searchString"
                       CustomQuickFilter="@QuickFilterServiceAreas"
                       ShowTotalCount="true"
                       TotalCount="@(serviceAreas?.Count())"
                       CountIcon="@Icons.Material.Filled.Landscape"
                       HasSelection="@(selectedServiceArea != null)"
                       EntitySingularName="Service Area"
                       EntityPluralName="service areas"
                       EnableViewModeManagement="true"
                       EnableEditPermissionCheck="true"
                       CanEditChanged="@(async (canEdit) => { this.canEdit = canEdit; await InvokeAsync(StateHasChanged); })"
                       IsEditorChanged="@(async (editor) => { this.isEditor = editor; await InvokeAsync(StateHasChanged); })"
                       OnEditModeCancelled="@HandleEditModeCancelled"
                       SelectedItem="@selectedServiceArea"
                       GetSelectedItemDisplayText="@(sa => sa.Name ?? string.Empty)"
                       ShowSelectedItemChip="true"
                       ShowCreateButton="false"
                       UseBuiltInDataGrid="true"
                       IsLoadingItems="@isLoading"
                       Items="@serviceAreas"
                       OnItemClicked="@(async (item) => await HandleItemClick(item))"
                       GetItemIcon="@(sa => Icons.Material.Filled.Landscape)"
                       GetItemDisplayText="@(sa => sa.Name ?? string.Empty)">

    <AdditionalItemColumns>
        <TemplateColumn T="ServiceArea" Title="Total Seats" Sortable="true">
            <CellTemplate>
                @{
                    var seatCount = GetNonUknSeatsForServiceArea(context.Item.Id)?.Count() ?? 0;
                }
                <MudText Typo="Typo.body2">@seatCount</MudText>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="ServiceArea" Title="Vacant Seats" Sortable="true">
            <CellTemplate>
                @{
                    var vacantCount = GetVacantSeatsCount(context.Item.Id);
                    var becomingVacantCount = GetBecomingVacantSeatsCount(context.Item.Id);
                }
                @if (vacantCount > 0 || becomingVacantCount > 0)
                {
                    <MudStack Row="true" Spacing="1">
                        @if (vacantCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.WarningAmber">@vacantCount Vacant</MudChip>
                        }
                        @if (becomingVacantCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.TrendingDown">@becomingVacantCount Expiring</MudChip>
                        }
                    </MudStack>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Check">All Filled</MudChip>
                }
            </CellTemplate>
        </TemplateColumn>
    </AdditionalItemColumns>

    <!-- Detail Content (Expandable Sections) -->
    <DetailContent>
        @if (selectedServiceArea != null && allSeatsForServiceArea != null)
        {
            <MudExpansionPanels MultiExpansion="true">
                @foreach (var seat in allSeatsForServiceArea)
                {
                    var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
                    var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);
                    var seatStatus = commissionSeatStatuses?.FirstOrDefault(s => s.Id == seat.CommissionSeatStatusId);
                    var isUkn = seatClass?.Class?.Equals("UKN", StringComparison.OrdinalIgnoreCase) == true;
                    var isVacant = IsSeatVacant(seat.Id);
                    var isBecomingVacant = IsSeatBecomingVacant(seat.Id);
                    var isFirstSeat = allSeatsForServiceArea.First() == seat;

                    // Skip UKN seats in Public view
                    if (isUkn && !ViewModeService.IsAtLeast(ViewMode.Admin))
                    {
                        continue;
                    }

                    <SectionPanel @key="seat.Id"
                                 Title="@($"{seatType?.Type} - {seatClass?.Class}")"
                                 Icon="@Icons.Material.Filled.EventSeat"
                                 Expanded="@isFirstSeat"
                                 MinimumViewMode="ViewMode.Public">
                        <MudStack Row="true" Spacing="1" Class="mb-3">
                            <MudChip T="string" 
                                    Size="Size.Small" 
                                    Color="Color.Info"
                                    Icon="@Icons.Material.Filled.Info">
                                @(seatStatus?.Status ?? "Unknown")
                            </MudChip>
                            @if (isVacant)
                            {
                                <MudChip T="string" 
                                        Size="Size.Small" 
                                        Color="Color.Warning" 
                                        Icon="@Icons.Material.Filled.WarningAmber">
                                    VACANT
                                </MudChip>
                            }
                            else if (isBecomingVacant)
                            {
                                <MudChip T="string" 
                                        Size="Size.Small" 
                                        Color="Color.Error" 
                                        Icon="@Icons.Material.Filled.TrendingDown">
                                    EXPIRING SOON
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" 
                                        Size="Size.Small" 
                                        Color="Color.Success" 
                                        Icon="@Icons.Material.Filled.Check">
                                    Filled
                                </MudChip>
                            }
                        </MudStack>

                        <MudExpansionPanels MultiExpansion="true">
                            <!-- Seat Details Section -->
                            <SectionPanel Title="Seat Details"
                                         Icon="@Icons.Material.Filled.Info"
                                         Expanded="true"
                                         MinimumViewMode="ViewMode.Public">
                                @{
                                    var seatVersions = GetAllVersionsOfSeat(seat);
                                    var displayVersion = currentlyDisplayedVersions.TryGetValue(seat.Id, out var tracked) ? tracked : seat;
                                }
                                <VersionedDetailsPanel TEntity="CommissionSeat"
                                   AllVersions="@seatVersions"
                                   CurrentVersion="@displayVersion"
                                   CurrentVersionChanged="@((v) => HandleVersionChanged(seat.Id, v))"
                                   GetValidFrom="@(x => x.ValidFrom)"
                                   GetValidTo="@(x => x.ValidTo)"
                                   GetModifiedBy="@(x => x.ModifiedBy)"
                                   GetDisplayText="@GetSeatDisplayText"
                                   CanEdit="@(canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))"
                                   IsEditMode="@(editingSeatId == seat.Id)"
                                   OnEditClicked="@(() => EnableEditForSeat(seat.Id))"
                                   IsLoading="false"
                                   ErrorMessage="@null"
                                   OnRestore="@(async (historicalVersion) => await HandleRestoreVersion(seat.Id, historicalVersion))">

                                    <!-- Edit Mode Content -->
                                    <DetailsContent Context="version">
                                        @if (editingSeatId == seat.Id && editModel != null && editModel.Id == seat.Id)
                                        {
                                            <EditForm EditContext="@editContext" OnValidSubmit="@(() => SaveSeatEdit(seat.Id))">
                                                <DataAnnotationsValidator />
                                                <MudGrid>
                                                    @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
                                                    {
                                                        <MudItem xs="12">
                                                            <SaveCancelButtons IsSaving="@isSaving" OnCancel="@CancelEdit" />
                                                        </MudItem>
                                                    }

                                                    <AlertMessages SuccessMessage="@successMessage" 
                                                                  ErrorMessage="@errorMessage" 
                                                                  ErrorDetails="@errorDetails" />

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.CommissionSeatTypeId" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="int"
                                                                   TLookup="CommissionSeatType"
                                                                   Property="@(x => x.CommissionSeatTypeId)"
                                                                   ReadOnly="false"
                                                                   LookupItems="@commissionSeatTypes"
                                                                   LookupTextSelector="@(item => ((CommissionSeatType)item).Type ?? string.Empty)"
                                                                   For="@(() => editModel.CommissionSeatTypeId)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.CommissionSeatClassId" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="int"
                                                                   TLookup="CommissionSeatClass"
                                                                   Property="@(x => x.CommissionSeatClassId)"
                                                                   ReadOnly="false"
                                                                   LookupItems="@commissionSeatClasses"
                                                                   LookupTextSelector="@(item => ((CommissionSeatClass)item).Class ?? string.Empty)"
                                                                   For="@(() => editModel.CommissionSeatClassId)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.CommissionSeatStatusId" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="int"
                                                                   TLookup="CommissionSeatStatus"
                                                                   Property="@(x => x.CommissionSeatStatusId)"
                                                                   ReadOnly="false"
                                                                   LookupItems="@commissionSeatStatuses"
                                                                   LookupTextSelector="@(item => ((CommissionSeatStatus)item).Status ?? string.Empty)"
                                                                   For="@(() => editModel.CommissionSeatStatusId)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.ServiceAreaId" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="int"
                                                                   TLookup="ServiceArea"
                                                                   Property="@(x => x.ServiceAreaId)"
                                                                   ReadOnly="true"
                                                                   LookupItems="@serviceAreas"
                                                                   LookupTextSelector="@(item => ((ServiceArea)item).Name ?? "")"
                                                                   For="@(() => editModel.ServiceAreaId)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.TermStartDate" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.TermStartDate)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.TermStartDate)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.TermEndDate" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.TermEndDate)"
                                                                   ReadOnly="false"
                                                                   For="@(() => editModel.TermEndDate)" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField Value="editModel.ValidFrom" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.ValidFrom)"
                                                                   ReadOnly="true" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField Value="editModel.ValidTo" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="DateTime?" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.ValidTo)"
                                                                   ReadOnly="true" />
                                                    </MudItem>

                                                    <MudItem xs="12" md="6">
                                                        <AutoField @bind-Value="editModel.ModifiedBy" 
                                                                   TModel="CommissionSeat" 
                                                                   TValue="string" 
                                                                   TLookup="object"
                                                                   Property="@(x => x.ModifiedBy)"
                                                                   ReadOnly="true" />
                                                    </MudItem>
                                                </MudGrid>
                                            </EditForm>
                                        }
                                    </DetailsContent>

                                    <!-- View Mode Content -->
                                    <ViewModeContent Context="version">
                                        <MudGrid Spacing="3">
                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionSeat"
                                                         Label="Seat Type" 
                                                         Icon="@Icons.Material.Filled.Category"
                                                         ValueStyle="font-weight: 600; font-size: 1.1rem;"
                                                         PropertyExpression="@(x => x.CommissionSeatTypeId)">
                                                    <ValueContent>
                                                        @{
                                                            var versionSeatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == displayVersion.CommissionSeatTypeId);
                                                        }
                                                        <MudText Typo="Typo.body1" Style="font-weight: 600; font-size: 1.1rem;">
                                                            @(versionSeatType?.Type ?? "—")
                                                        </MudText>
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionSeat"
                                                         Label="Seat Class" 
                                                         Icon="@Icons.Material.Filled.Class"
                                                         PropertyExpression="@(x => x.CommissionSeatClassId)">
                                                    <ValueContent>
                                                        @{
                                                            var versionSeatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == displayVersion.CommissionSeatClassId);
                                                        }
                                                        <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                                            @(versionSeatClass?.Class ?? "—")
                                                        </MudText>
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionSeat"
                                                         Label="Status" 
                                                         Icon="@Icons.Material.Filled.Circle"
                                                         PropertyExpression="@(x => x.CommissionSeatStatusId)">
                                                    <ValueContent>
                                                        @{
                                                            var versionStatus = commissionSeatStatuses?.FirstOrDefault(s => s.Id == displayVersion.CommissionSeatStatusId);
                                                        }
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                                            @(versionStatus?.Status ?? "—")
                                                        </MudChip>
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionSeat"
                                                         Label="Service Area" 
                                                         Icon="@Icons.Material.Filled.Landscape"
                                                         PropertyExpression="@(x => x.ServiceAreaId)">
                                                    <ValueContent>
                                                        @{
                                                            var versionServiceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == displayVersion.ServiceAreaId);
                                                        }
                                                        @if (versionServiceArea != null && isEditor)
                                                        {
                                                            <MudButton Variant="Variant.Text" 
                                                                      Color="Color.Primary" 
                                                                      Size="Size.Small"
                                                                      StartIcon="@Icons.Material.Filled.OpenInNew"
                                                                      OnClick="@(() => NavigationHelper.NavigateToEntity(NavigationManager, "/service-areas", versionServiceArea.Id))">
                                                                @versionServiceArea.Name
                                                            </MudButton>
                                                        }
                                                        else
                                                        {
                                                            <MudText>@(versionServiceArea?.Name ?? "—")</MudText>
                                                        }
                                                    </ValueContent>
                                                </InfoCard>
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionSeat"
                                                         Label="Term Start Date" 
                                                         Value="@(displayVersion.TermStartDate?.ToString("MMM d, yyyy"))"
                                                         Icon="@Icons.Material.Filled.CalendarToday"
                                                         PropertyExpression="@(x => x.TermStartDate)" />
                                            </MudItem>

                                            <MudItem xs="12" md="6">
                                                <InfoCard TValue="string" TModel="CommissionSeat"
                                                         Label="Term End Date" 
                                                         Value="@(displayVersion.TermEndDate?.ToString("MMM d, yyyy"))"
                                                         Icon="@Icons.Material.Filled.Event"
                                                         PropertyExpression="@(x => x.TermEndDate)" />
                                            </MudItem>
                                        </MudGrid>
                                    </ViewModeContent>
                                </VersionedDetailsPanel>
                            </SectionPanel>

                            <!-- Commissioners Section -->
                            <SectionPanel Title="@(ViewModeService.IsAtLeast(ViewMode.Admin) ? "All Commissioners" : "Active Commissioners")"
                                         Icon="@Icons.Material.Filled.Groups"
                                         MinimumViewMode="ViewMode.Public"
                                         ShowCount="true"
                                         Count="@(GetCommissionersForSeat(seat.Id)?.Count() ?? 0)"
                                         CountColor="Color.Secondary">
                                @{
                                    var commissioners = GetCommissionersForSeat(seat.Id);
                                }
                                @if (commissioners != null && commissioners.Any())
                                {
                                    <MudTable T="CommissionerProfile" Items="@commissioners" Hover="true" Striped="true" Dense="true" Elevation="0">
                                        <HeaderContent>
                                            <MudTh>Person</MudTh>
                                            <MudTh>Status</MudTh>
                                            <MudTh>Appointed</MudTh>
                                            <MudTh>Effective</MudTh>
                                            <MudTh>End Date</MudTh>
                                            @if (isEditor)
                                            {
                                                <MudTh Style="width: 100px;">Actions</MudTh>
                                            }
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Person">
                                                @if (isEditor)
                                                {
                                                    <MudButton Variant="Variant.Text" 
                                                              Color="Color.Primary" 
                                                              Size="Size.Small"
                                                              StartIcon="@Icons.Material.Filled.Person"
                                                              OnClick="@(() => NavigationHelper.NavigateToEntity(NavigationManager, "/commissioners", context.PersonProfileId))">
                                                        @GetPersonName(context.PersonProfileId)
                                                    </MudButton>
                                                }
                                                else
                                                {
                                                    @GetPersonName(context.PersonProfileId)
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Status">
                                                @{
                                                    var commStatus = commissionerStatuses?.FirstOrDefault(s => s.Id == context.CommissionerStatusId);
                                                }
                                                <MudChip T="string" 
                                                        Size="Size.Small" 
                                                        Color="@(commStatus?.Active == true ? Color.Success : Color.Default)"
                                                        Icon="@(commStatus?.Active == true ? Icons.Material.Filled.Check : Icons.Material.Filled.Circle)">
                                                    @(commStatus?.Status ?? "—")
                                                </MudChip>
                                            </MudTd>
                                            <MudTd DataLabel="Appointed">@(context.AppointedDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                            <MudTd DataLabel="Effective">@(context.EffectiveDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                            <MudTd DataLabel="End Date">
                                                @if (context.EndDate.HasValue)
                                                {
                                                    <MudText>@context.EndDate.Value.ToString("MMM d, yyyy")</MudText>
                                                }
                                                else
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Current</MudChip>
                                                }
                                            </MudTd>
                                            @if (isEditor)
                                            {
                                                <MudTd DataLabel="Actions">
                                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                                  Size="Size.Small" 
                                                                  Color="Color.Primary" 
                                                                  Title="View Commissioner Profile"
                                                                  OnClick="@(() => NavigationHelper.NavigateToEntity(NavigationManager, "/commissioners", context.PersonProfileId))" />
                                                </MudTd>
                                            }
                                        </RowTemplate>
                                    </MudTable>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.WarningAmber" Class="my-4">
                                        <MudText Typo="Typo.body2">This seat is currently <strong>VACANT</strong> - no commissioners assigned.</MudText>
                                    </MudAlert>
                                }
                            </SectionPanel>

                            <!-- Notes Section -->
                            @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
                            {
                                var noteCount = seatNoteCounts.TryGetValue(seat.Id, out var count) ? count : 0;
                                var refreshKey = notesPanelRefreshKeys.TryGetValue(seat.Id, out var key) ? key : 0;

                                <SectionPanel Title="Notes"
                                             Icon="@Icons.Material.Filled.Notes"
                                             MinimumViewMode="ViewMode.Admin"
                                             ShowCount="true"
                                             Count="@noteCount"
                                             CountColor="Color.Info">
                                    <NotesPanel @key="@($"notes-{seat.Id}-{refreshKey}")"
                                               EntityType="commission_seat" 
                                               EntityId="@seat.Id"
                                               ShowHistory="true"
                                               NotesCountChanged="@GetNoteCountCallback(seat.Id)" />
                                </SectionPanel>
                            }
                        </MudExpansionPanels>
                    </SectionPanel>
                }

                <!-- Report Builder Section -->
                @if (canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))
                {
                    <SectionPanel Title="Report Builder"
                                 Icon="@Icons.Material.Filled.Assessment"
                                 MinimumViewMode="ViewMode.Admin">
                        <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                            Report Builder functionality will be implemented here.
                        </MudAlert>
                    </SectionPanel>
                }
            </MudExpansionPanels>
        }
    </DetailContent>
</EntityManagementLayout>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int? ServiceAreaId { get; set; }

    private IEnumerable<CommissionSeat>? commissionSeats;
    private IEnumerable<CommissionSeatType>? commissionSeatTypes;
    private IEnumerable<CommissionSeatClass>? commissionSeatClasses;
    private IEnumerable<CommissionSeatStatus>? commissionSeatStatuses;
    private IEnumerable<ServiceArea>? serviceAreas;
    private IEnumerable<CommissionerProfile>? commissionerProfiles;
    private IEnumerable<CommissionerStatus>? commissionerStatuses;
    private IEnumerable<PersonProfile>? personProfiles;
    private IEnumerable<PersonHonorific>? personHonorifics;
    private IEnumerable<PersonSuffix>? personSuffixes;

    private ServiceArea? selectedServiceArea;
    private IEnumerable<CommissionSeat>? allSeatsForServiceArea;
    private bool isLoading = false;
    private bool isSaving = false;
    private bool canEdit = false;
    private bool isEditor = false;
    private string? errorMessage;
    private string[]? errorDetails;
    private string? successMessage;
    private CommissionSeat? editModel;
    private string _searchString = string.Empty;
    private EditContext? editContext;

    // Track which seat is being edited
    private int? editingSeatId = null;

    // Cache for seat version history
    private Dictionary<int, IEnumerable<CommissionSeat>> seatVersionCache = new();

    // Track currently displayed version for each seat
    private Dictionary<int, CommissionSeat> currentlyDisplayedVersions = new();

    // Track notes panel refresh keys
    private Dictionary<int, int> notesPanelRefreshKeys = new();

    // Track note counts per seat
    private Dictionary<int, int> seatNoteCounts = new();

    // Store callbacks per seat to make them stable references
    private Dictionary<int, Action<int>> noteCountCallbacks = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
        SelectServiceAreaFromParameters();
    }

    protected override void OnParametersSet()
    {
        SelectServiceAreaFromParameters();
    }

    private async Task LoadAllData()
    {
        isLoading = true;

        await DataLoaderHelper.LoadMultipleAsync(
            LoadCommissionSeats,
            LoadCommissionSeatTypes,
            LoadCommissionSeatClasses,
            LoadCommissionSeatStatuses,
            LoadServiceAreas,
            LoadCommissionerProfiles,
            LoadCommissionerStatuses,
            LoadPersonProfiles,
            LoadPersonHonorifics,
            LoadPersonSuffixes
        );

        isLoading = false;
    }

    private void HandleEditModeCancelled()
    {
        EntityPageHelper.HandleEditModeCancelled(editingSeatId.HasValue, CancelEdit);
    }

    private void SelectServiceAreaFromParameters()
    {
        if (serviceAreas == null || !serviceAreas.Any() || !ServiceAreaId.HasValue)
            return;

        var target = serviceAreas.FirstOrDefault(sa => sa.Id == ServiceAreaId.Value);

        if (target != null && selectedServiceArea?.Id != target.Id)
        {
            selectedServiceArea = target;
            editingSeatId = null;
            ClearMessages();
            LoadAllSeatsForServiceArea();
        }
    }

    private async Task LoadCommissionSeats()
    {
        commissionSeats = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatsApi.GetAllCommissionSeatsAsync());
    }

    private async Task LoadCommissionSeatTypes()
    {
        commissionSeatTypes = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatTypesApi.GetAllCommissionSeatTypesAsync());
    }

    private async Task LoadCommissionSeatClasses()
    {
        commissionSeatClasses = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatClassesApi.GetAllCommissionSeatClassesAsync());
    }

    private async Task LoadCommissionSeatStatuses()
    {
        commissionSeatStatuses = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatStatusesApi.GetAllCommissionSeatStatusesAsync());
    }

    private async Task LoadServiceAreas()
    {
        serviceAreas = await DataLoaderHelper.LoadDataAsync(() => ServiceAreasApi.GetAllServiceAreasAsync());
    }

    private async Task LoadCommissionerProfiles()
    {
        commissionerProfiles = await DataLoaderHelper.LoadDataAsync(() => CommissionerProfilesApi.GetAllCommissionerProfilesAsync());
    }

    private async Task LoadCommissionerStatuses()
    {
        commissionerStatuses = await DataLoaderHelper.LoadDataAsync(() => CommissionerStatusesApi.GetAllCommissionerStatusesAsync());
    }

    private async Task LoadPersonProfiles()
    {
        personProfiles = await DataLoaderHelper.LoadDataAsync(() => PersonProfilesApi.GetAllPersonProfilesAsync());
    }

    private async Task LoadPersonHonorifics()
    {
        personHonorifics = await DataLoaderHelper.LoadDataAsync(() => PersonHonorificsApi.GetAllPersonHonorificsAsync());
    }

    private async Task LoadPersonSuffixes()
    {
        personSuffixes = await DataLoaderHelper.LoadDataAsync(() => PersonSuffixesApi.GetAllPersonSuffixesAsync());
    }

    private void LoadAllSeatsForServiceArea()
    {
        if (selectedServiceArea == null) return;

        // Get all seats for this service area
        var seats = commissionSeats?
            .Where(s => s.ServiceAreaId == selectedServiceArea.Id)
            .ToList();

        if (seats != null)
        {
            // Separate UKN seats from others
            var nonUknSeats = seats.Where(s =>
            {
                var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == s.CommissionSeatClassId);
                return seatClass?.Class?.Equals("UKN", StringComparison.OrdinalIgnoreCase) != true;
            });

            var uknSeats = seats.Where(s =>
            {
                var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == s.CommissionSeatClassId);
                return seatClass?.Class?.Equals("UKN", StringComparison.OrdinalIgnoreCase) == true;
            });

            // Order non-UKN seats by CommissionSeatTypeId
            var orderedNonUkn = nonUknSeats
                .OrderBy(s => s.CommissionSeatTypeId)
                .ThenBy(s =>
                {
                    var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == s.CommissionSeatClassId);
                    return seatClass?.Class ?? string.Empty;
                });

            // Order UKN seats by CommissionSeatTypeId
            var orderedUkn = uknSeats
                .OrderBy(s => s.CommissionSeatTypeId)
                .ThenBy(s =>
                {
                    var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == s.CommissionSeatClassId);
                    return seatClass?.Class ?? string.Empty;
                });

            // Combine: non-UKN first, then UKN at bottom
            allSeatsForServiceArea = orderedNonUkn.Concat(orderedUkn).ToList();
        }
        else
        {
            allSeatsForServiceArea = null;
        }

        // Clear caches
        seatVersionCache.Clear();
        currentlyDisplayedVersions.Clear();
        noteCountCallbacks.Clear();
    }

    private IEnumerable<CommissionSeat>? GetSeatsForServiceArea(int serviceAreaId)
    {
        return commissionSeats?.Where(s => s.ServiceAreaId == serviceAreaId);
    }

    private IEnumerable<CommissionSeat>? GetNonUknSeatsForServiceArea(int serviceAreaId)
    {
        var seats = GetSeatsForServiceArea(serviceAreaId);
        if (seats == null) return null;

        return seats.Where(s =>
        {
            var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == s.CommissionSeatClassId);
            return seatClass?.Class?.Equals("UKN", StringComparison.OrdinalIgnoreCase) != true;
        });
    }

    private int GetVacantSeatsCount(int serviceAreaId)
    {
        var seats = GetSeatsForServiceArea(serviceAreaId);
        if (seats == null) return 0;

        return seats.Count(s => IsSeatVacant(s.Id));
    }

    private int GetBecomingVacantSeatsCount(int serviceAreaId)
    {
        var seats = GetSeatsForServiceArea(serviceAreaId);
        if (seats == null) return 0;

        return seats.Count(s => IsSeatBecomingVacant(s.Id));
    }

    private bool IsSeatVacant(int seatId)
    {
        if (commissionSeats == null || commissionSeatStatuses == null) return false;

        // Get the seat
        var seat = commissionSeats.FirstOrDefault(s => s.Id == seatId);
        if (seat == null) return false;

        // Check if the seat's status indicates vacancy
        var seatStatus = commissionSeatStatuses.FirstOrDefault(s => s.Id == seat.CommissionSeatStatusId);
        if (seatStatus == null) return false;

        // Check if status name or code indicates vacant
        return seatStatus.Status?.Equals("Vacant", StringComparison.OrdinalIgnoreCase) == true ||
               seatStatus.StatusCode?.Equals("V", StringComparison.OrdinalIgnoreCase) == true;
    }

    private bool IsSeatBecomingVacant(int seatId)
    {
        if (commissionSeats == null || commissionSeatStatuses == null) return false;

        // Get the seat
        var seat = commissionSeats.FirstOrDefault(s => s.Id == seatId);
        if (seat == null) return false;

        // Check if the seat's status indicates vacancy
        var seatStatus = commissionSeatStatuses.FirstOrDefault(s => s.Id == seat.CommissionSeatStatusId);
        if (seatStatus == null) return false;

        // Check if status name or code indicates vacant
        return seatStatus.Status?.Equals("Occupied/Vacant", StringComparison.OrdinalIgnoreCase) == true ||
               seatStatus.StatusCode?.Equals("R", StringComparison.OrdinalIgnoreCase) == true;
    }

    private IEnumerable<CommissionerProfile>? GetCommissionersForSeat(int seatId)
    {
        if (commissionerProfiles == null) return null;

        var profiles = commissionerProfiles.Where(cp => cp.CommissionSeatId == seatId);

        // In Public view mode, only show active commissioners
        if (!ViewModeService.IsAtLeast(ViewMode.Admin))
        {
            var activeStatusIds = commissionerStatuses?
                .Where(s => s.Active == true)
                .Select(s => s.Id)
                .ToHashSet();

            if (activeStatusIds != null && activeStatusIds.Any())
            {
                profiles = profiles.Where(cp => activeStatusIds.Contains(cp.CommissionerStatusId));
            }
        }

        return profiles
            .OrderByDescending(cp => cp.AppointedDate)
            .ThenByDescending(cp => cp.ValidFrom)
            .ToList();
    }

    private IEnumerable<CommissionSeat>? GetAllVersionsOfSeat(CommissionSeat seat)
    {
        if (seat == null) 
            return new[] { seat };

        // Check cache first
        if (seatVersionCache.TryGetValue(seat.Id, out var cachedVersions))
        {
            return cachedVersions;
        }

        // If not in cache, load from API
        _ = LoadSeatVersionsAsync(seat.Id);

        // Return just the current seat for now (will update when async load completes)
        return new[] { seat };
    }

    private async Task LoadSeatVersionsAsync(int seatId)
    {
        try
        {
            var result = await CommissionSeatsApi.GetCommissionSeatHistoryAsync(seatId);

            if (result?.IsSuccess == true && result.Data != null)
            {
                var versions = result.Data
                    .OrderByDescending(s => s.ValidFrom)
                    .ToList();

                seatVersionCache[seatId] = versions;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception)
        {
            // If history load fails, just use the current seat
            var currentSeat = allSeatsForServiceArea?.FirstOrDefault(s => s.Id == seatId);
            if (currentSeat != null)
            {
                seatVersionCache[seatId] = new[] { currentSeat };
            }
        }
    }

    private Task HandleVersionChanged(int seatId, CommissionSeat selectedVersion)
    {
        // Update the currently displayed version for this seat
        currentlyDisplayedVersions[seatId] = selectedVersion;

        // Trigger UI update
        StateHasChanged();

        return Task.CompletedTask;
    }

    private Action<int> GetNoteCountCallback(int seatId)
    {
        if (!noteCountCallbacks.ContainsKey(seatId))
        {
            noteCountCallbacks[seatId] = (count) => UpdateNoteCount(seatId, count);
        }
        return noteCountCallbacks[seatId];
    }

    private void UpdateNoteCount(int seatId, int count)
    {
        seatNoteCounts[seatId] = count;
    }

