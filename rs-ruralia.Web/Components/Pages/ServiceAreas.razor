    private async Task<(bool Success, string? ErrorMessage, string[]? ErrorDetails)> CreateServiceArea(ServiceArea entity)
    {
        try
        {
            var result = await ServiceAreasApi.CreateServiceAreaAsync(entity);

            if (result?.IsSuccess == true && result.Data != null)
            {
                // Update the entity with the returned data (which includes the ID)
                entity.Id = result.Data.Id;
                entity.ValidFrom = result.Data.ValidFrom;

                return (true, null, null);
            }
            else
            {
                return (false, result?.ErrorMessage ?? "Failed to create service area", result?.Errors);
            }
        }
        catch (Exception ex)
        {
            return (false, $"Error creating service area: {ex.Message}", null);
        }
    }
