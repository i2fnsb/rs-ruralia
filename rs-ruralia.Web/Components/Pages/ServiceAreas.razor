@page "/service-areas"
@rendermode InteractiveServer 
@using rs_ruralia.Shared.Enums
@using rs_ruralia.Web.Components.Dialogs
@using rs_ruralia.Web.Helpers
@inject ServiceAreasApiClient ServiceAreasApi
@inject ServiceAreaCodesApiClient ServiceAreaCodesApi
@inject OrdinancesApiClient OrdinancesApi
@inject OrdinanceTypesApiClient OrdinanceTypesApi
@inject CommissionSeatsApiClient CommissionSeatsApi
@inject CommissionSeatTypesApiClient CommissionSeatTypesApi
@inject CommissionSeatClassesApiClient CommissionSeatClassesApi
@inject CommissionSeatStatusesApiClient CommissionSeatStatusesApi
@inject CommissionerProfilesApiClient CommissionerProfilesApi
@inject CommissionerStatusesApiClient CommissionerStatusesApi
@inject CorrespondenceProfilesApiClient CorrespondenceProfilesApi
@inject CorrespondencePhonesApiClient CorrespondencePhonesApi
@inject CorrespondenceEmailsApiClient CorrespondenceEmailsApi
@inject PersonProfilesApiClient PersonProfilesApi
@inject PersonHonorificsApiClient PersonHonorificsApi
@inject PersonSuffixesApiClient PersonSuffixesApi
@inject RoadsApiClient RoadsApi
@inject RoadNamesApiClient RoadNamesApi
@inject RfqsApiClient RfqsApi
@inject RfqIfbTypesApiClient RfqIfbTypesApi
@inject RfqProjectScopesApiClient RfqProjectScopesApi
@inject NotesApiClient NotesApi
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject IDialogService DialogService
@inject ViewModeService ViewModeService

<EntityManagementLayout TEntity="ServiceArea"
                       Title="Service Areas"
                       Subtitle="Manage and view rural service area details, ordinances, commissions, and infrastructure"
                       Icon="@Icons.Material.Filled.Landscape"
                       ShowViewModeSelector="true"
                       ListTitle="Service Areas"
                       ListIcon="@Icons.Material.Filled.List"
                       SearchPlaceholder="Search areas..."
                       ShowSearch="true"
                       SearchString="@_searchString"
                       ShowTotalCount="true"
                       TotalCount="@(serviceAreas?.Count())"
                       CountIcon="@Icons.Material.Filled.LocationCity"
                       HasSelection="@(selectedServiceArea != null)"
                       EntitySingularName="Service Area"
                       EntityPluralName="service areas"
                       EnableViewModeManagement="true"
                       EnableEditPermissionCheck="true"
                       CanEditChanged="@(async (canEdit) => { this.canEdit = canEdit; await InvokeAsync(StateHasChanged); })"
                       IsEditorChanged="@(async (editor) => { this.isEditor = editor; await InvokeAsync(StateHasChanged); })"
                       OnEditModeCancelled="@HandleEditModeCancelled"
                       SelectedItem="@selectedServiceArea"
                       GetSelectedItemDisplayText="@(sa => sa.Name ?? "")"
                       ShowSelectedItemChip="true"
                       ShowCreateButton="true"
                       CreateButtonTitle="Create New Service Area"
                       OnCreateClicked="@OpenCreateDialog"
                       UseBuiltInDataGrid="true"
                       IsLoadingItems="@isLoading"
                       Items="@serviceAreas"
                       OnItemClicked="@(async (item) => await HandleItemClick(item))"
                       GetItemIcon="@(sa => Icons.Material.Filled.Landscape)"
                       GetItemDisplayText="@(sa => sa.Name ?? "")">

    <!-- Detail Content (Expandable Sections) -->
    <DetailContent>
        <MudExpansionPanels MultiExpansion="true">
            <SectionPanel Title="Details"
                             Icon="@Icons.Material.Filled.Info" 
                             Expanded="true"
                             MinimumViewMode="ViewMode.Public">
                    <VersionedDetailsPanel TEntity="ServiceArea"
                       AllVersions="@allVersions"
                       CurrentVersion="@currentViewVersion"
                       CurrentVersionChanged="@OnCurrentVersionChanged"
                       GetValidFrom="@(x => x.ValidFrom)"
                       GetValidTo="@(x => x.ValidTo)"
                       GetModifiedBy="@(x => x.ModifiedBy)"
                       GetDisplayText="@(x => x.Name ?? "")"
                       CanEdit="@(canEdit && ViewModeService.IsAtLeast(ViewMode.Admin))"
                       IsEditMode="@isEditMode"
                       OnEditClicked="@EnableEdit"
                       IsLoading="@(isLoading || isLoadingHistory)"
                       ErrorMessage="@(errorMessage ?? historyErrorMessage)"
                       OnRestore="@HandleRestore">
                            <!-- This contains the view for edit mode. -->
                            <DetailsContent Context="version">
                            @if (editContext != null && editModel != null)
                            {
                                <EditForm EditContext="@editContext" OnValidSubmit="SaveEdit">
                                    <DataAnnotationsValidator />
                                    <MudGrid>
                                        @if (canEdit && IsViewingCurrentVersion() && ViewModeService.IsAtLeast(ViewMode.Admin) && isEditMode)
                                        {
                                            <MudItem xs="12">
                                                <SaveCancelButtons IsSaving="@isSaving" OnCancel="@CancelEdit" />
                                            </MudItem>
                                        }

                                        <AlertMessages SuccessMessage="@successMessage" 
                                                      ErrorMessage="@errorMessage" 
                                                      ErrorDetails="@errorDetails" />

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.Name" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.Name)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.Name)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.FeatureObjectId" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.FeatureObjectId)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.FeatureObjectId)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.OrgKey" TModel="ServiceArea" TValue="int?" TLookup="object"
                                                       Property="@(x => x.OrgKey)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.OrgKey)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.CurrentMileage" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.CurrentMileage)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.CurrentMileage)" />
                                            @if (CanEditFields() && serviceAreaRoads != null && serviceAreaRoads.Any())
                                            {
                                                <MudButton Size="Size.Small" 
                                                          Variant="Variant.Outlined" 
                                                          Color="Color.Info"
                                                          StartIcon="@Icons.Material.Filled.Calculate"
                                                          OnClick="CalculateCurrentMileage"
                                                          Class="mt-2">
                                                    Calculate from Roads (@serviceAreaRoads.Count() roads)
                                                </MudButton>
                                            }
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.AbolishMergeYear" TModel="ServiceArea" TValue="int?" TLookup="object"
                                                       Property="@(x => x.AbolishMergeYear)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.AbolishMergeYear)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.MaximumMillRate" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.MaximumMillRate)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.MaximumMillRate)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.CurrentMillRate" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.CurrentMillRate)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.CurrentMillRate)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.FireMillRate" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.FireMillRate)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.FireMillRate)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.MillLevy" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.MillLevy)"
                                                       Format="N13"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.MillLevy)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.TaxAuthorityCode" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.TaxAuthorityCode)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.TaxAuthorityCode)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.InitialTaxYear" TModel="ServiceArea" TValue="int?" TLookup="object"
                                                       Property="@(x => x.InitialTaxYear)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.InitialTaxYear)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.MatchFeatureLayer" TModel="ServiceArea" TValue="bool?" TLookup="object"
                                                       Property="@(x => x.MatchFeatureLayer)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.MatchFeatureLayer)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.ServiceAreaCodeId" 
                                                       TModel="ServiceArea" 
                                                       TValue="int?"
                                                       TLookup="ServiceAreaCode"
                                                       Property="@(x => x.ServiceAreaCodeId)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       LookupItems="@serviceAreaCodes"
                                                       LookupTextSelector="@(item => $"{((ServiceAreaCode)item).Code} - {((ServiceAreaCode)item).Description}")"
                                                       ForeignKeyIdSelector="@(x => x.Id)"
                                                       ForeignKeyNameSelector="@(x => x.Code ?? "")"
                                                       ForeignKeyDescriptionSelector="@(x => x.Description ?? "")"
                                                       OnForeignKeyCreate="@CreateServiceAreaCode"
                                                       OnForeignKeyUpdate="@UpdateServiceAreaCode"
                                                       OnForeignKeyDelete="@DeleteServiceAreaCode"
                                                       OnForeignKeyDataChanged="@(EventCallback.Factory.Create(this, LoadServiceAreaCodes))"
                                                       ForeignKeyDialogTitle="Manage Service Area Codes"
                                                       For="@(() => editModel.ServiceAreaCodeId)">
                                                <ForeignKeyFormContent Context="entity">
                                                    <MudItem xs="12">
                                                        <AutoField @bind-Value="entity.Code" 
                                                                   TModel="ServiceAreaCode" 
                                                                   TValue="string"
                                                                   TLookup="object"
                                                                   Property="@(x => x.Code)"
                                                                   For="@(() => entity.Code)" />
                                                    </MudItem>
                                                    <MudItem xs="12">
                                                        <AutoField @bind-Value="entity.Description" 
                                                                   TModel="ServiceAreaCode" 
                                                                   TValue="string"
                                                                   TLookup="object"
                                                                   Property="@(x => x.Description)"
                                                                   For="@(() => entity.Description)" />
                                                    </MudItem>
                                                </ForeignKeyFormContent>
                                            </AutoField>
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField Value="editModel.ValidFrom" TModel="ServiceArea" TValue="DateTime?" TLookup="object"
                                                       Property="@(x => x.ValidFrom)"
                                                       ReadOnly="true" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.ModifiedBy" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.ModifiedBy)"
                                                       ReadOnly="true" />
                                        </MudItem>
                                    </MudGrid>
                                </EditForm>
                            }
                        </DetailsContent>
                        <!-- This contains the default view for all versions. -->
                        <ViewModeContent Context="version">
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Name" 
                                             Value="@version.Name" 
                                             Icon="@Icons.Material.Filled.Label"
                                             ValueStyle="font-weight: 600; font-size: 1.1rem;"
                                             PropertyExpression="@(x => x.Name)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Feature Object ID" 
                                             Value="@version.FeatureObjectId"
                                             Icon="@Icons.Material.Filled.Fingerprint"
                                             PropertyExpression="@(x => x.FeatureObjectId)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Org Key" 
                                             Value="@version.OrgKey?.ToString()"
                                             Icon="@Icons.Material.Filled.Key"
                                             PropertyExpression="@(x => x.OrgKey)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Current Mileage" 
                                             Value="@(version.CurrentMileage?.ToString("N3"))"
                                             Icon="@Icons.Material.Filled.Straighten"
                                             PropertyExpression="@(x => x.CurrentMileage)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Abolish/Merge Year"
                                             Value="@version.AbolishMergeYear?.ToString()"
                                             Icon="@Icons.Material.Filled.MergeType"
                                             PropertyExpression="@(x => x.AbolishMergeYear)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Maximum Mill Rate" 
                                             Value="@(version.MaximumMillRate?.ToString("N3"))"
                                             Icon="@Icons.Material.Filled.TrendingUp"
                                             PropertyExpression="@(x => x.MaximumMillRate)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Current Mill Rate" 
                                             Value="@(version.CurrentMillRate?.ToString("N3"))"
                                             Icon="@Icons.Material.Filled.AttachMoney"
                                             PropertyExpression="@(x => x.CurrentMillRate)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Fire Mill Rate" 
                                             Value="@(version.FireMillRate?.ToString("N3"))"
                                             Icon="@Icons.Material.Filled.LocalFireDepartment"
                                             PropertyExpression="@(x => x.FireMillRate)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Mill Levy" 
                                             Value="@(version.MillLevy?.ToString("N13"))"
                                             Icon="@Icons.Material.Filled.Calculate"
                                             PropertyExpression="@(x => x.MillLevy)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Tax Authority Code" 
                                             Value="@version.TaxAuthorityCode"
                                             Icon="@Icons.Material.Filled.AccountBalance"
                                             PropertyExpression="@(x => x.TaxAuthorityCode)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Initial Tax Year" 
                                             Value="@version.InitialTaxYear?.ToString()"
                                             Icon="@Icons.Material.Filled.CalendarToday"
                                             PropertyExpression="@(x => x.InitialTaxYear)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <BooleanInfoCard TModel="ServiceArea"
                                                   Value="@version.MatchFeatureLayer"
                                                   Label="Match Feature Layer" 
                                                   Icon="@Icons.Material.Filled.Layers"
                                                   PropertyExpression="@(x => x.MatchFeatureLayer)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <InfoCard TValue="string" TModel="ServiceArea"
                                             Label="Service Area Code" 
                                             Icon="@Icons.Material.Filled.Category"
                                             PropertyExpression="@(x => x.ServiceAreaCodeId)">
                                        <ValueContent>
                                            @{
                                                var code = serviceAreaCodes?.FirstOrDefault(c => c.Id == version.ServiceAreaCodeId);
                                                <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                                    @(code != null ? $"{code.Code} - {code.Description}" : "—")
                                                </MudText>
                                            }
                                        </ValueContent>
                                    </InfoCard>
                                </MudItem>
                            </MudGrid>
                        </ViewModeContent>
                    </VersionedDetailsPanel>
                </SectionPanel>

                @if (canEdit)
                {
                    <SectionPanel Title="Notes"
                                 Icon="@Icons.Material.Filled.Notes"
                                 MinimumViewMode="ViewMode.Admin"
                                 ShowCount="true"
                                 Count="@notesCount"
                                 CountColor="Color.Dark">
                        <NotesPanel EntityType="service_area" 
                                   EntityId="@selectedServiceArea.Id"
                                   HighlightedNoteDate="@(currentViewVersion?.ValidFrom)"
                                   ShowHistory="true"
                                   NotesCountChanged="@OnNotesCountChanged" />
                    </SectionPanel>
                }

                <SectionPanel Title="Map" 
                             Icon="@Icons.Material.Filled.Map"
                             MinimumViewMode="ViewMode.Public">
                    @if (!string.IsNullOrEmpty(selectedServiceArea?.FeatureObjectId))
                    {
                        <FeatureLayerMap @ref="_mapRef"
                                        FeatureLayerUrl="@GetFeatureLayerUrl()"
                                        QueryParameters="@GetMapQueryParameters()"
                                        RoadsLayerUrl="@GetRoadsLayerUrl()"
                                        ShowRoads="@showRoadsOnMap"
                                        Height="600px"
                                        Title="@selectedServiceArea.Name" />
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                            No feature layer URL configured for this service area.
                        </MudAlert>
                    }
                </SectionPanel>
                <SectionPanel Title="Ordinances" 
                             Icon="@Icons.Material.Filled.Gavel"
                             MinimumViewMode="ViewMode.Public"
                             ShowCount="true"
                             Count="@(serviceAreaOrdinances?.Count() ?? 0)"
                             CountColor="Color.Info">
                    <ChildContent>
                    @if (selectedServiceArea != null)
                    {
                        <MudStack Spacing="2">
                            @if (isLoadingOrdinances)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (serviceAreaOrdinances != null && serviceAreaOrdinances.Any())
                            {
                                <MudTable T="Ordinance" Items="@serviceAreaOrdinances" Hover="true" Striped="true" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Ordinance</MudTh>
                                        <MudTh>Year</MudTh>
                                        <MudTh>Type</MudTh>
                                        <MudTh>Passed</MudTh>
                                        <MudTh Style="width: 100px;">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Ordinance">@context.OrdinanceName</MudTd>
                                        <MudTd DataLabel="Year">@context.OrdinanceYear</MudTd>
                                        <MudTd DataLabel="Type">
                                            <LookupDisplay TLookup="OrdinanceType"
                                                         LookupId="@context.OrdinanceTypeId"
                                                         LookupItems="@ordinanceTypes"
                                                         DisplaySelector="@(t => $"{t.Type} - {t.Description}")" />
                                        </MudTd>
                                        <MudTd DataLabel="Passed">
                                            <BooleanTableCell Value="@context.OrdinancePassed" 
                                                            FalseColor="Color.Error" />
                                        </MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                          Size="Size.Small" 
                                                          Color="Color.Primary" 
                                                          OnClick="@(() => NavigateToOrdinance(context))"
                                                          Title="Open Ordinance Details" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No ordinances linked to this service area.</MudText>
                            }
                        </MudStack>
                    }
                    </ChildContent>
                </SectionPanel>

                <SectionPanel Title="Commission" 
                             Icon="@Icons.Material.Filled.Groups"
                             MinimumViewMode="ViewMode.Public"
                             ShowCount="true"
                             Count="@(GetOrderedCommissionSeats()?.Count() ?? 0)"
                             CountColor="Color.Secondary">
                    @if (selectedServiceArea != null)
                    {
                        <MudStack Spacing="2">
                            @if (isLoadingCommissionSeats)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (commissionSeats != null && commissionSeats.Any())
                            {
                                @foreach (var seat in GetOrderedCommissionSeats())
                                {
                                    var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
                                    var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);
                                    var seatStatus = commissionSeatStatuses?.FirstOrDefault(s => s.Id == seat.CommissionSeatStatusId);
                                    var seatCommissioners = GetCommissionersForSeat(seat.Id);

                                    <MudCard Outlined="true" Class="mb-2">
                                        <MudCardHeader>
                                            <CardHeaderContent>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                    <MudStack Row="false" Spacing="0">
                                                        <MudText Typo="Typo.h6">
                                                            @seatType?.Type
                                                            @if (isEditor)
                                                            {
                                                                @($" - {seatClass?.Class}")
                                                            }
                                                        </MudText>
                                                        <MudStack Row="true" Spacing="2">
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@seatStatus?.Status</MudChip>
                                                            @if (seat.TermStartDate.HasValue && seat.TermEndDate.HasValue)
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                    Term: @seat.TermStartDate?.ToString("MMM d, yyyy") - @seat.TermEndDate?.ToString("MMM d, yyyy")
                                                                </MudText>
                                                            }
                                                        </MudStack>
                                                    </MudStack>
                                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                                  Size="Size.Small" 
                                                                  Color="Color.Primary" 
                                                                  OnClick="@(() => NavigateToCommissionSeat(seat))" />
                                                </MudStack>
                                            </CardHeaderContent>
                                        </MudCardHeader>
                                        <MudCardContent>
                                            @if (seatCommissioners.Any())
                                            {
                                                <MudTable T="CommissionerProfile" Items="@seatCommissioners" Hover="true" Dense="true" Elevation="0">
                                                    <HeaderContent>
                                                        <MudTh>Person</MudTh>
                                                        <MudTh>Contact</MudTh>
                                                        <MudTh>Status</MudTh>
                                                        <MudTh>Appointed</MudTh>
                                                        <MudTh>End Date</MudTh>
                                                        <MudTh>Oath</MudTh>
                                                        <MudTh Style="width: 80px;">Actions</MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd DataLabel="Person">@GetFormattedPersonName(context.PersonProfileId)</MudTd>
                                                        <MudTd DataLabel="Contact">
                                                            @{
                                                                var correspondence = GetPublicCorrespondence(context.Id);
                                                            }
                                                            @if (correspondence.HasValue)
                                                            {
                                                                <MudStack Spacing="0">
                                                                    @if (!string.IsNullOrEmpty(correspondence.Value.EmailAddress))
                                                                    {
                                                                        <MudText Typo="Typo.caption">
                                                                            <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" /> @correspondence.Value.EmailAddress
                                                                        </MudText>
                                                                    }
                                                                    @if (!string.IsNullOrEmpty(correspondence.Value.PhoneNumber))
                                                                    {
                                                                        <MudText Typo="Typo.caption">
                                                                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> @correspondence.Value.PhoneNumber
                                                                        </MudText>
                                                                    }
                                                                </MudStack>
                                                            }
                                                            else
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">No public contact</MudText>
                                                            }
                                                        </MudTd>
                                                        <MudTd DataLabel="Status">
                                                            @{
                                                                var commissionerStatus = commissionerStatuses?.FirstOrDefault(s => s.Id == context.CommissionerStatusId);
                                                            }
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@commissionerStatus?.Status</MudChip>
                                                        </MudTd>
                                                        <MudTd DataLabel="Appointed">@(context.AppointedDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                                        <MudTd DataLabel="End Date">@(context.EndDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                                        <MudTd DataLabel="Oath">
                                                            @if (context.Oath == true)
                                                            {
                                                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                                            }
                                                            else
                                                            {
                                                                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" />
                                                            }
                                                        </MudTd>
                                                        <MudTd DataLabel="Actions">
                                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                                          Size="Size.Small" 
                                                                          Color="Color.Primary" 
                                                                          OnClick="@(() => NavigationManager.NavigateTo($"/commissioners?id={context.Id}"))" />
                                                        </MudTd>
                                                    </RowTemplate>
                                                </MudTable>
                                            }
                                            else
                                            {
                                                <MudAlert Severity="Severity.Info" Dense="true">No commissioners assigned to this seat</MudAlert>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No commission seats for this service area.</MudText>
                            }
                        </MudStack>
                    }
                </SectionPanel>

                <SectionPanel Title="Request For Quotes" 
                             Icon="@Icons.Material.Filled.RequestQuote"
                             MinimumViewMode="ViewMode.Public"
                             ShowCount="true"
                             Count="@(serviceAreaRfqs?.Count() ?? 0)"
                             CountColor="Color.Warning">
                    @if (selectedServiceArea != null)
                    {
                        <MudStack Spacing="2">
                            @if (!string.IsNullOrEmpty(rfqsErrorMessage))
                            {
                                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                                    @rfqsErrorMessage
                                </MudAlert>
                            }

                            @if (isLoadingRfqs)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (serviceAreaRfqs != null && serviceAreaRfqs.Any())
                            {
                                <MudTable T="Rfq" Items="@serviceAreaRfqs" Hover="true" Striped="true" Dense="true">
                                    <HeaderContent>
                                        <MudTh>RFQ Number</MudTh>
                                        <MudTh>Type</MudTh>
                                        <MudTh>Project Scope</MudTh>
                                        <MudTh>Issue Date</MudTh>
                                        <MudTh>Opening Date</MudTh>
                                        <MudTh>Completed</MudTh>
                                        <MudTh Style="width: 100px;">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="RFQ Number">@context.RfqNumber</MudTd>
                                        <MudTd DataLabel="Type">
                                            <LookupDisplay TLookup="RfqIfbType"
                                                         LookupId="@context.RfqIfbTypeId"
                                                         LookupItems="@rfqIfbTypes"
                                                         DisplaySelector="@(t => t.Type ?? "—")" />
                                        </MudTd>
                                        <MudTd DataLabel="Project Scope">
                                            @{
                                                var scope = rfqProjectScopes?.FirstOrDefault(s => s.Id == context.RfqProjectScopeId);
                                                var scopeText = scope?.Scope ?? context.CustomProjectScope ?? "—";
                                                @(scopeText.Length > 50 ? scopeText.Substring(0, 47) + "..." : scopeText)
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Issue Date">@(context.IssueDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                        <MudTd DataLabel="Opening Date">@(context.OpeningDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                        <MudTd DataLabel="Completed">
                                            <BooleanTableCell Value="@context.Completed" 
                                                            FalseColor="Color.Warning" 
                                                            FalseIcon="@Icons.Material.Filled.HourglassEmpty" />
                                        </MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                          Size="Size.Small" 
                                                          Color="Color.Primary" 
                                                          OnClick="@(() => NavigateToRfq(context))" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No RFQs found for this service area.</MudText>
                            }
                        </MudStack>
                    }
                </SectionPanel>

                <SectionPanel Title="Roads" 
                             Icon="@Icons.Material.Filled.Route"
                             MinimumViewMode="ViewMode.Public"
                             ShowCount="true"
                             Count="@(serviceAreaRoads?.Count() ?? 0)"
                             CountColor="Color.Tertiary">
                    @if (selectedServiceArea != null)
                    {
                        <MudStack Spacing="2">
                            @if (!string.IsNullOrEmpty(roadsErrorMessage))
                            {
                                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                                    @roadsErrorMessage
                                </MudAlert>
                            }

                            @if (isLoadingRoads)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (serviceAreaRoads != null && serviceAreaRoads.Any())
                            {
                                <MudTable T="Road" Items="@serviceAreaRoads" Hover="true" Striped="true" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Road Name</MudTh>
                                        <MudTh>Phase</MudTh>
                                        <MudTh>Distance (Feet)</MudTh>
                                        <MudTh>Start Description</MudTh>
                                        <MudTh>End Description</MudTh>
                                        <MudTh>Approved for Maintenance</MudTh>
                                        <MudTh Style="width: 100px;">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Road Name">
                                            <LookupDisplay TLookup="RoadName"
                                                         LookupId="@context.RoadNameId"
                                                         LookupItems="@roadNames"
                                                         DisplaySelector="@(rn => rn.Name ?? "—")" />
                                        </MudTd>
                                        <MudTd DataLabel="Phase">@(context.Phase?.ToString() ?? "—")</MudTd>
                                        <MudTd DataLabel="Distance (Feet)">@(context.DistanceFeet?.ToString("N2") ?? "—")</MudTd>
                                        <MudTd DataLabel="Start Description">@(context.StartDescription ?? "—")</MudTd>
                                        <MudTd DataLabel="End Description">@(context.EndDescription ?? "—")</MudTd>
                                        <MudTd DataLabel="Approved for Maintenance">
                                            <BooleanTableCell Value="@context.ApprovedForMaintenance" />
                                        </MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                          Size="Size.Small" 
                                                          Color="Color.Primary" 
                                                          OnClick="@(() => NavigateToRoad(context))" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No roads found for this service area.</MudText>
                            }
                        </MudStack>
                    }
                </SectionPanel>
                <SectionPanel Title="Citizen Problem Reporter" 
                             Icon="@Icons.Material.Filled.CarRepair"
                             MinimumViewMode="ViewMode.Public">
                             <MudText>Insert Citizen Problem Reporter map and/or list of problems</MudText>
                </SectionPanel>
                <SectionPanel Title="Meetings" 
                             Icon="@Icons.Material.Filled.MeetingRoom"
                             MinimumViewMode="ViewMode.Public">
                             <MudText>Meetings -- need to add to database.</MudText>
                </SectionPanel>
                <SectionPanel Title="Report Builder" 
                             Icon="@Icons.Material.Filled.Report"
                             MinimumViewMode="ViewMode.Admin">
                             <MudText>Reports -- PowerBI? Or do I do in a  dedicated Report page?</MudText>
                </SectionPanel>
            </MudExpansionPanels>
    </DetailContent>
</EntityManagementLayout>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int? ServiceAreaId { get; set; }

    private IEnumerable<ServiceArea>? serviceAreas;
    private IEnumerable<ServiceAreaCode>? serviceAreaCodes;
    private ServiceArea? selectedServiceArea;
    private bool isLoading = false;
    private bool isSaving = false;
    private bool isEditMode = false;
    private bool canEdit = false;
    private string? errorMessage;
    private string[]? errorDetails;
    private string? successMessage;
    private ServiceArea? editModel;
    private string _searchString = string.Empty;
    private EditContext? editContext;

    // Version navigation fields
    private IEnumerable<ServiceArea>? allVersions;
    private ServiceArea? currentViewVersion;
    private bool isLoadingHistory = false;
    private string? historyErrorMessage;

    // Map fields
    private bool showRoadsOnMap = false;
    private FeatureLayerMap? _mapRef;

    // Ordinances management fields
    private IEnumerable<Ordinance>? serviceAreaOrdinances;
    private IEnumerable<OrdinanceType>? ordinanceTypes;
    private bool isLoadingOrdinances = false;

    // Notes management field
    private int notesCount = 0;

    // Commission Seats management fields
    private IEnumerable<CommissionSeat>? commissionSeats;
    private IEnumerable<CommissionSeatType>? commissionSeatTypes;
    private IEnumerable<CommissionSeatClass>? commissionSeatClasses;
    private IEnumerable<CommissionSeatStatus>? commissionSeatStatuses;
    private bool isLoadingCommissionSeats = false;

    // Commissioners management fields
    private IEnumerable<CommissionerProfile>? commissioners;
    private IEnumerable<CommissionerStatus>? commissionerStatuses;
    private bool isLoadingCommissioners = false;

    // Correspondence data
    private IEnumerable<CorrespondenceProfile>? correspondenceProfiles;
    private IEnumerable<CorrespondencePhone>? correspondencePhones;
    private IEnumerable<CorrespondenceEmail>? correspondenceEmails;

    // Person data
    private IEnumerable<PersonProfile>? personProfiles;
    private IEnumerable<PersonHonorific>? personHonorifics;
    private IEnumerable<PersonSuffix>? personSuffixes;

    // Roads management fields
    private IEnumerable<Road>? serviceAreaRoads;
    private IEnumerable<RoadName>? roadNames;
    private bool isLoadingRoads = false;
    private string? roadsErrorMessage;

    // RFQ management fields
    private IEnumerable<Rfq>? serviceAreaRfqs;
    private IEnumerable<RfqIfbType>? rfqIfbTypes;
    private IEnumerable<RfqProjectScope>? rfqProjectScopes;
    private bool isLoadingRfqs = false;
    private string? rfqsErrorMessage;

    // Permission flags
    private bool isEditor = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadServiceAreas();
        await LoadServiceAreaCodes();
        await LoadOrdinanceTypes();
        await LoadCommissionSeatLookups();
        await LoadCommissionerStatusLookups();
        await LoadRoadNames();
        await LoadRfqLookups();
        SelectServiceAreaFromParameters();
    }

    protected override void OnParametersSet()
    {
        SelectServiceAreaFromParameters();
    }

    private void HandleEditModeCancelled()
    {
        EntityPageHelper.HandleEditModeCancelled(isEditMode, CancelEdit);
    }

    private void SelectServiceAreaFromParameters()
    {
        if (serviceAreas == null || !serviceAreas.Any() || !ServiceAreaId.HasValue)
            return;

        var targetServiceArea = serviceAreas.FirstOrDefault(sa => sa.Id == ServiceAreaId.Value);

        if (targetServiceArea != null && selectedServiceArea?.Id != targetServiceArea.Id)
        {
            selectedServiceArea = targetServiceArea;
            isEditMode = false;
            ClearMessages();
            _ = LoadAllVersions();
        }
    }

    private async Task LoadServiceAreas()
    {
        isLoading = true;
        ClearMessages();

        serviceAreas = await DataLoaderHelper.LoadDataWithErrorHandlingAsync(
            () => ServiceAreasApi.GetAllServiceAreasAsync(),
            onError: (error, errors) =>
            {
                errorMessage = error ?? "Failed to load service areas";
                errorDetails = errors;
            });

        isLoading = false;
    }

    private async Task LoadServiceAreaCodes()
    {
        serviceAreaCodes = await DataLoaderHelper.LoadDataAsync(() => ServiceAreaCodesApi.GetAllServiceAreaCodesAsync());
    }

    private async Task LoadServiceAreaOrdinances()
    {
        if (selectedServiceArea == null) return;

        isLoadingOrdinances = true;
        serviceAreaOrdinances = await DataLoaderHelper.LoadDataAsync(
            () => OrdinancesApi.GetOrdinancesByServiceAreaAsync(selectedServiceArea.Id));
        isLoadingOrdinances = false;
    }

    private async Task LoadOrdinanceTypes()
    {
        ordinanceTypes = await DataLoaderHelper.LoadDataAsync(() => OrdinanceTypesApi.GetAllOrdinanceTypesAsync());
    }

    private async Task LoadCommissionSeats()
    {
        if (selectedServiceArea == null) return;

        isLoadingCommissionSeats = true;

        commissionSeats = await DataLoaderHelper.LoadDataAsync(
            () => CommissionSeatsApi.GetCommissionSeatsByServiceAreaAsync(selectedServiceArea.Id));

        if (commissionSeats.Any())
        {
            await LoadCommissioners();
        }
        else
        {
            commissioners = Array.Empty<CommissionerProfile>();
        }

        isLoadingCommissionSeats = false;
    }

    private async Task LoadCommissionSeatLookups()
    {
        await DataLoaderHelper.LoadMultipleAsync(
            async () => commissionSeatTypes = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatTypesApi.GetAllCommissionSeatTypesAsync()),
            async () => commissionSeatClasses = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatClassesApi.GetAllCommissionSeatClassesAsync()),
            async () => commissionSeatStatuses = await DataLoaderHelper.LoadDataAsync(() => CommissionSeatStatusesApi.GetAllCommissionSeatStatusesAsync())
        );
    }

    private async Task LoadCommissioners()
    {
        if (commissionSeats == null || !commissionSeats.Any()) 
        {
            commissioners = Array.Empty<CommissionerProfile>();
            return;
        }

        isLoadingCommissioners = true;

        // Load all data in parallel using DataLoaderHelper
        await DataLoaderHelper.LoadMultipleAsync(
            async () => 
            {
                var allCommissioners = await DataLoaderHelper.LoadDataAsync(() => CommissionerProfilesApi.GetAllCommissionerProfilesAsync());
                var seatIds = commissionSeats.Select(s => s.Id).ToHashSet();
                commissioners = allCommissioners.Where(c => seatIds.Contains(c.CommissionSeatId)).ToList();
            },
            async () => correspondenceProfiles = await DataLoaderHelper.LoadDataAsync(() => CorrespondenceProfilesApi.GetAllCorrespondenceProfilesAsync()),
            async () => correspondencePhones = await DataLoaderHelper.LoadDataAsync(() => CorrespondencePhonesApi.GetAllCorrespondencePhonesAsync()),
            async () => correspondenceEmails = await DataLoaderHelper.LoadDataAsync(() => CorrespondenceEmailsApi.GetAllCorrespondenceEmailsAsync()),
            async () => personProfiles = await DataLoaderHelper.LoadDataAsync(() => PersonProfilesApi.GetAllPersonProfilesAsync()),
            async () => personHonorifics = await DataLoaderHelper.LoadDataAsync(() => PersonHonorificsApi.GetAllPersonHonorificsAsync()),
            async () => personSuffixes = await DataLoaderHelper.LoadDataAsync(() => PersonSuffixesApi.GetAllPersonSuffixesAsync())
        );

        isLoadingCommissioners = false;
    }

    private async Task LoadCommissionerStatusLookups()
    {
        commissionerStatuses = await DataLoaderHelper.LoadDataAsync(() => CommissionerStatusesApi.GetAllCommissionerStatusesAsync());
    }

    private async Task LoadAllVersions()
    {
        if (selectedServiceArea == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        var (versions, current, error) = await VersionHistoryHelper.LoadAllVersionsAsync(
            selectedServiceArea,
            id => ServiceAreasApi.GetServiceAreaHistoryAsync(id),
            x => x.Id,
            x => x.ValidFrom);

        allVersions = versions;
        currentViewVersion = current;
        historyErrorMessage = error;
        UpdateEditModel(currentViewVersion);

        // Load related data for this service area
        await LoadServiceAreaOrdinances();
        await LoadOrdinanceTypes();
        await LoadCommissionSeats();
        await LoadServiceAreaRoads();
        await LoadServiceAreaRfqs();

        isLoadingHistory = false;
    }

    private async Task OnCurrentVersionChanged(ServiceArea newVersion)
    {
        currentViewVersion = newVersion;
        UpdateEditModel(newVersion);
        await InvokeAsync(StateHasChanged);
    }

    private void OnNotesCountChanged(int count)
    {
        notesCount = count;
        StateHasChanged();
    }

    private void UpdateEditModel(ServiceArea version)
    {
        editModel = CloneServiceArea(version);
        editContext = new EditContext(editModel);
        
        // Cancel edit mode when viewing historical versions
        if (!IsViewingCurrentVersion())
        {
            isEditMode = false;
        }
    }

    private bool IsViewingCurrentVersion()
    {
        return EntityPageHelper.IsViewingCurrentVersion(currentViewVersion, selectedServiceArea, x => x.ValidFrom);
    }

    private bool CanEditFields()
    {
        return EntityPageHelper.CanEditFields(isEditMode, IsViewingCurrentVersion());
    }

    private async Task HandleItemClick(ServiceArea item)
    {
        selectedServiceArea = item;
        isEditMode = false;
        ClearMessages();
        await LoadAllVersions();
        await InvokeAsync(StateHasChanged);

        NavigationHelper.UpdateUrlWithSelection(NavigationManager, selectedServiceArea.Id);
    }

    private async Task HandleRestore(ServiceArea historicalRecord)
    {
        if (selectedServiceArea == null) return;

        isSaving = true;
        ClearMessages();

        var (success, errorMsg, errors) = await VersionHistoryHelper.HandleRestoreAsync(
            selectedServiceArea,
            historicalRecord,
            CloneServiceArea,
            (entity, id) => entity.Id = id,
            (id, entity) => ServiceAreasApi.UpdateServiceAreaAsync(id, entity),
            x => x.Id,
            x => x.ValidFrom);

        if (success)
        {
            successMessage = errorMsg;
            await LoadServiceAreas();
            selectedServiceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == selectedServiceArea.Id);
            if (selectedServiceArea != null)
            {
                await LoadAllVersions();
            }
            isEditMode = false;
        }
        else
        {
            errorMessage = errorMsg;
            errorDetails = errors;
        }

        isSaving = false;
    }

    private void EnableEdit()
    {
        if (!IsViewingCurrentVersion())
        {
            // Navigate to current version before editing
            if (selectedServiceArea != null)
            {
                currentViewVersion = selectedServiceArea;
                UpdateEditModel(currentViewVersion);
            }
        }
        
        isEditMode = true;
        ClearMessages();
    }

    private async Task SaveEdit()
    {
        if (editModel == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var userEmail = await AuthenticationHelper.SetModifiedByAsync(
                editModel,
                AuthenticationStateProvider,
                (entity, email) => entity.ModifiedBy = email);

            var result = await ServiceAreasApi.UpdateServiceAreaAsync(editModel.Id, editModel);

            if (result?.IsSuccess == true)
            {
                successMessage = "Service area updated successfully!";
                isEditMode = false;

                // Reload data
                await LoadServiceAreas();
                selectedServiceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == editModel.Id);

                if (selectedServiceArea != null)
                {
                    await LoadAllVersions();
                }

                // Prompt user to add a note about the changes
                await PromptForEditNote(editModel.Id, userEmail);
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to update service area";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating service area: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelEdit()
    {
        if (currentViewVersion != null)
        {
            editModel = CloneServiceArea(currentViewVersion);
            editContext = new EditContext(editModel);
        }
        isEditMode = false;
        ClearMessages();
    }

    private void ClearMessages()
    {
        EntityPageHelper.ClearMessages(ref errorMessage, ref errorDetails, ref successMessage);
    }

    private ServiceArea CloneServiceArea(ServiceArea source) => EntityCloneHelper.ShallowClone(source);

    private async Task<bool> CreateServiceAreaCode(ServiceAreaCode entity)
    {
        var result = await ServiceAreaCodesApi.CreateServiceAreaCodeAsync(entity);
        return result?.IsSuccess ?? false;
    }

    private async Task<bool> UpdateServiceAreaCode(ServiceAreaCode entity)
    {
        var result = await ServiceAreaCodesApi.UpdateServiceAreaCodeAsync(entity.Id, entity);
        return result?.IsSuccess ?? false;
    }

    private async Task<bool> DeleteServiceAreaCode(ServiceAreaCode entity)
    {
        var result = await ServiceAreaCodesApi.DeleteServiceAreaCodeAsync(entity.Id);
        return result?.IsSuccess ?? false;
    }

    // Map helper methods
    private string? GetFeatureLayerUrl()
    {
        // TODO: Replace with your actual ArcGIS Feature Service URL
        // Example: "https://services.arcgis.com/your-org/arcgis/rest/services/ServiceAreas/FeatureServer/0"
