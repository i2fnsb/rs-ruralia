@page "/service-areas"
@rendermode InteractiveServer 
@* @(new InteractiveServerRenderMode(prerender: false)) *@
@inject ServiceAreasApiClient ServiceAreasApi
@inject ServiceAreaCodesApiClient ServiceAreaCodesApi
@inject OrdinancesApiClient OrdinancesApi
@inject OrdinanceTypesApiClient OrdinanceTypesApi
@inject CommissionSeatsApiClient CommissionSeatsApi
@inject CommissionSeatTypesApiClient CommissionSeatTypesApi
@inject CommissionSeatClassesApiClient CommissionSeatClassesApi
@inject CommissionSeatStatusesApiClient CommissionSeatStatusesApi
@inject CommissionerProfilesApiClient CommissionerProfilesApi
@inject CommissionerStatusesApiClient CommissionerStatusesApi
@inject CorrespondenceProfilesApiClient CorrespondenceProfilesApi
@inject CorrespondencePhonesApiClient CorrespondencePhonesApi
@inject CorrespondenceEmailsApiClient CorrespondenceEmailsApi
@inject PersonProfilesApiClient PersonProfilesApi
@inject PersonHonorificsApiClient PersonHonorificsApi
@inject PersonSuffixesApiClient PersonSuffixesApi
@inject RoadsApiClient RoadsApi
@inject RoadNamesApiClient RoadNamesApi
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="2">
        <MudDataGrid T="ServiceArea" 
                     Items="@serviceAreas" 
                     QuickFilter="@_quickFilter"
                     Height="calc(100vh - 200px)"
                     FixedHeader="true"
                     Virtualize="true"
                     RowClick="RowClicked"
                     SelectedItem="selectedServiceArea">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Service Area" />
            </Columns>
        </MudDataGrid>
    </MudItem>
    <MudItem xs="10">
        @if (selectedServiceArea != null)
        {
            <MudExpansionPanels MultiExpansion>
                <MudExpansionPanel Text="Details" Expanded="true">
                    <VersionedDetailsPanel TEntity="ServiceArea"
                       AllVersions="@allVersions"
                       CurrentVersion="@currentViewVersion"
                       CurrentVersionChanged="@OnCurrentVersionChanged"
                       GetValidFrom="@(x => x.ValidFrom)"
                       GetValidTo="@(x => x.ValidTo)"
                       GetModifiedBy="@(x => x.ModifiedBy)"
                       GetDisplayText="@(x => x.Name ?? "")"
                       CanEdit="@canEdit"
                       IsEditMode="@isEditMode"
                       OnEditClicked="@EnableEdit"
                       IsLoading="@(isLoading || isLoadingHistory)"
                       ErrorMessage="@(errorMessage ?? historyErrorMessage)"
                       OnRestore="@HandleRestore">
                            <!-- This contains the view for edit mode. -->
                            <DetailsContent Context="version">
                            @if (editContext != null && editModel != null)
                            {
                                <EditForm EditContext="@editContext" OnValidSubmit="SaveEdit">
                                    <DataAnnotationsValidator />
                                    <MudGrid>
                                        <MudItem xs="12">
                                            @if (canEdit && IsViewingCurrentVersion())
                                            {
                                                @if (isEditMode)
                                                {
                                                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-3">
                                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Disabled="@isSaving">
                                                            @if (isSaving)
                                                            {
                                                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                                                <MudText Class="ms-2">Saving...</MudText>
                                                            }
                                                            else
                                                            {
                                                                <MudIcon Icon="@Icons.Material.Filled.Save" Class="me-1" /> <MudText>Save</MudText>
                                                            }
                                                        </MudButton>
                                                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="CancelEdit" Disabled="@isSaving">
                                                            Cancel
                                                        </MudButton>
                                                    </MudStack>
                                                }
                                                else
                                                {
                                                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-3">
                                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EnableEdit">
                                                            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="me-1" /> Edit
                                                        </MudButton>
                                                    </MudStack>
                                                }
                                            }
                                        </MudItem>

                                        @if (!string.IsNullOrEmpty(successMessage))
                                        {
                                            <MudItem xs="12">
                                                <MudAlert Severity="Severity.Success" Variant="Variant.Filled">@successMessage</MudAlert>
                                            </MudItem>
                                        }

                                        @if (!string.IsNullOrEmpty(errorMessage))
                                        {
                                            <MudItem xs="12">
                                                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                                                    <MudText>@errorMessage</MudText>
                                                    @if (errorDetails != null && errorDetails.Length > 0)
                                                    {
                                                        <MudList T="string" Dense="true">
                                                            @foreach (var detail in errorDetails)
                                                            {
                                                                <MudListItem>@detail</MudListItem>
                                                            }
                                                        </MudList>
                                                    }
                                                </MudAlert>
                                            </MudItem>
                                        }

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.Name" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.Name)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.Name)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.FeatureObjectId" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.FeatureObjectId)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.FeatureObjectId)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.OrgKey" TModel="ServiceArea" TValue="int?" TLookup="object"
                                                       Property="@(x => x.OrgKey)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.OrgKey)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.CurrentMileage" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.CurrentMileage)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.CurrentMileage)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.AbolishMergeYear" TModel="ServiceArea" TValue="int?" TLookup="object"
                                                       Property="@(x => x.AbolishMergeYear)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.AbolishMergeYear)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.MaximumMillRate" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.MaximumMillRate)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.MaximumMillRate)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.CurrentMillRate" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.CurrentMillRate)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.CurrentMillRate)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.FireMillRate" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.FireMillRate)"
                                                       Format="N3"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.FireMillRate)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.MillLevy" TModel="ServiceArea" TValue="decimal?" TLookup="object"
                                                       Property="@(x => x.MillLevy)"
                                                       Format="N13"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.MillLevy)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.TaxAuthorityCode" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.TaxAuthorityCode)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.TaxAuthorityCode)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.InitialTaxYear" TModel="ServiceArea" TValue="int?" TLookup="object"
                                                       Property="@(x => x.InitialTaxYear)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.InitialTaxYear)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.MatchFeatureLayer" TModel="ServiceArea" TValue="bool?" TLookup="object"
                                                       Property="@(x => x.MatchFeatureLayer)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       For="@(() => editModel.MatchFeatureLayer)" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.ServiceAreaCodeId" 
                                                       TModel="ServiceArea" 
                                                       TValue="int?"
                                                       TLookup="ServiceAreaCode"
                                                       Property="@(x => x.ServiceAreaCodeId)"
                                                       ReadOnly="@(!CanEditFields())"
                                                       LookupItems="@serviceAreaCodes"
                                                       LookupTextSelector="@(item => $"{((ServiceAreaCode)item).Code} - {((ServiceAreaCode)item).Description}")"
                                                       ForeignKeyIdSelector="@(x => x.Id)"
                                                       ForeignKeyNameSelector="@(x => x.Code ?? "")"
                                                       ForeignKeyDescriptionSelector="@(x => x.Description ?? "")"
                                                       OnForeignKeyCreate="@CreateServiceAreaCode"
                                                       OnForeignKeyUpdate="@UpdateServiceAreaCode"
                                                       OnForeignKeyDelete="@DeleteServiceAreaCode"
                                                       OnForeignKeyDataChanged="@(EventCallback.Factory.Create(this, LoadServiceAreaCodes))"
                                                       ForeignKeyDialogTitle="Manage Service Area Codes"
                                                       For="@(() => editModel.ServiceAreaCodeId)">
                                                <ForeignKeyFormContent Context="entity">
                                                    <MudItem xs="12">
                                                        <AutoField @bind-Value="entity.Code" 
                                                                   TModel="ServiceAreaCode" 
                                                                   TValue="string"
                                                                   TLookup="object"
                                                                   Property="@(x => x.Code)"
                                                                   For="@(() => entity.Code)" />
                                                    </MudItem>
                                                    <MudItem xs="12">
                                                        <AutoField @bind-Value="entity.Description" 
                                                                   TModel="ServiceAreaCode" 
                                                                   TValue="string"
                                                                   TLookup="object"
                                                                   Property="@(x => x.Description)"
                                                                   For="@(() => entity.Description)" />
                                                    </MudItem>
                                                </ForeignKeyFormContent>
                                            </AutoField>
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField Value="editModel.ValidFrom" TModel="ServiceArea" TValue="DateTime?" TLookup="object"
                                                       Property="@(x => x.ValidFrom)"
                                                       ReadOnly="true" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <AutoField @bind-Value="editModel.ModifiedBy" TModel="ServiceArea" TValue="string" TLookup="object"
                                                       Property="@(x => x.ModifiedBy)"
                                                       ReadOnly="true" />
                                        </MudItem>
                                    </MudGrid>
                                </EditForm>
                            }
                        </DetailsContent>
                        <!-- This contains the default view for all versions. -->
                        <ViewModeContent Context="version">
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Name</MudText>
                                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@version.Name</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Feature Object ID</MudText>
                                            <MudText Typo="Typo.body1">@version.FeatureObjectId</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Org Key</MudText>
                                            <MudText Typo="Typo.body1">@(version.OrgKey?.ToString() ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Current Mileage</MudText>
                                            <MudText Typo="Typo.body1">@(version.CurrentMileage?.ToString("N3") ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Abolish/Merge Year</MudText>
                                            <MudText Typo="Typo.body1">@(version.AbolishMergeYear?.ToString() ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Maximum Mill Rate</MudText>
                                            <MudText Typo="Typo.body1">@(version.MaximumMillRate?.ToString("N3") ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Current Mill Rate</MudText>
                                            <MudText Typo="Typo.body1">@(version.CurrentMillRate?.ToString("N3") ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Fire Mill Rate</MudText>
                                            <MudText Typo="Typo.body1">@(version.FireMillRate?.ToString("N3") ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Mill Levy</MudText>
                                            <MudText Typo="Typo.body1">@(version.MillLevy?.ToString("N13") ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Tax Authority Code</MudText>
                                            <MudText Typo="Typo.body1">@(version.TaxAuthorityCode ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Initial Tax Year</MudText>
                                            <MudText Typo="Typo.body1">@(version.InitialTaxYear?.ToString() ?? "—")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Match Feature Layer</MudText>
                                            @if (version.MatchFeatureLayer == true)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Check">Yes</MudChip>
                                            }
                                            else if (version.MatchFeatureLayer == false)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Close">No</MudChip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body1">—</MudText>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudCard Outlined="true" Class="pa-2">
                                        <MudCardContent>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Service Area Code</MudText>
                                            <MudText Typo="Typo.body1">
                                                @{
                                                    var code = serviceAreaCodes?.FirstOrDefault(c => c.Id == version.ServiceAreaCodeId);
                                                    @(code != null ? $"{code.Code} - {code.Description}" : "—")
                                                }
                                            </MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            </MudGrid>
                        </ViewModeContent>
                    </VersionedDetailsPanel>
                </MudExpansionPanel>

                @if (canEdit)
                {
                    <MudExpansionPanel Text="Notes">
                        <NotesPanel EntityType="service_area" 
                                   EntityId="@selectedServiceArea.Id"
                                   HighlightedNoteDate="@(currentViewVersion?.ValidFrom)"
                                   ShowHistory="true" />
                    </MudExpansionPanel>
                }

                <MudExpansionPanel Text="Map">
                    @if (!string.IsNullOrEmpty(selectedServiceArea?.FeatureObjectId))
                    {
                        <MudStack Spacing="2">
                            <MudSwitch @bind-Value="showRoadsOnMap" Color="Color.Primary" Label="Show Roads" />

                            <FeatureLayerMap @ref="_mapRef"
                                            FeatureLayerUrl="@GetFeatureLayerUrl()"
                                            QueryParameters="@GetMapQueryParameters()"
                                            RoadsLayerUrl="@GetRoadsLayerUrl()"
                                            ShowRoads="@showRoadsOnMap"
                                            Height="600px"
                                            Title="@selectedServiceArea.Name" />
                        </MudStack>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                            No feature layer URL configured for this service area.
                        </MudAlert>
                    }
                </MudExpansionPanel>
                <MudExpansionPanel Text="Ordinances">
                    @if (selectedServiceArea != null)
                    {
                        <MudStack Spacing="2">
                            @if (canEdit)
                            {
                                <MudStack Row="true" Justify="Justify.FlexEnd">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Link" OnClick="@OpenLinkOrdinanceDialog">
                                        Link Ordinance
                                    </MudButton>
                                </MudStack>
                            }

                            @if (isLoadingOrdinances)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (serviceAreaOrdinances != null && serviceAreaOrdinances.Any())
                            {
                                <MudTable T="Ordinance" Items="@serviceAreaOrdinances" Hover="true" Striped="true" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Ordinance</MudTh>
                                        <MudTh>Year</MudTh>
                                        <MudTh>Type</MudTh>
                                        <MudTh>Passed</MudTh>
                                        <MudTh Style="width: 100px;">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Ordinance">@context.OrdinanceName</MudTd>
                                        <MudTd DataLabel="Year">@context.OrdinanceYear</MudTd>
                                        <MudTd DataLabel="Type">
                                            @{
                                                var type = ordinanceTypes?.FirstOrDefault(t => t.Id == context.OrdinanceTypeId);
                                                @(type != null ? $"{type.Type} - {type.Description}" : "—")
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Passed">
                                            @if (context.OrdinancePassed == true)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Check">Yes</MudChip>
                                            }
                                            else if (context.OrdinancePassed == false)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Close">No</MudChip>
                                            }
                                            else
                                            {
                                                <MudText>—</MudText>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                          Size="Size.Small" 
                                                          Color="Color.Primary" 
                                                          OnClick="@(() => NavigateToOrdinance(context))"
                                                          Title="Open Ordinance Details" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No ordinances linked to this service area.</MudText>
                            }
                        </MudStack>
                    }
                </MudExpansionPanel>
                <MudExpansionPanel Text="Commission">
                    @if (selectedServiceArea != null)
                    {
                        <MudStack Spacing="2">
                            @if (isLoadingCommissionSeats)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (commissionSeats != null && commissionSeats.Any())
                            {
                                @foreach (var seat in GetOrderedCommissionSeats())
                                {
                                    var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seat.CommissionSeatTypeId);
                                    var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId);
                                    var seatStatus = commissionSeatStatuses?.FirstOrDefault(s => s.Id == seat.CommissionSeatStatusId);
                                    var seatCommissioners = GetCommissionersForSeat(seat.Id);

                                    <MudCard Outlined="true" Class="mb-2">
                                        <MudCardHeader>
                                            <CardHeaderContent>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                    <MudStack Row="false" Spacing="0">
                                                        <MudText Typo="Typo.h6">
                                                            @seatType?.Type
                                                            @if (isEditor)
                                                            {
                                                                @($" - {seatClass?.Class}")
                                                            }
                                                        </MudText>
                                                        <MudStack Row="true" Spacing="2">
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@seatStatus?.Status</MudChip>
                                                            @if (seat.TermStartDate.HasValue && seat.TermEndDate.HasValue)
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                    Term: @seat.TermStartDate?.ToString("MMM d, yyyy") - @seat.TermEndDate?.ToString("MMM d, yyyy")
                                                                </MudText>
                                                            }
                                                        </MudStack>
                                                    </MudStack>
                                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                                  Size="Size.Small" 
                                                                  Color="Color.Primary" 
                                                                  OnClick="@(() => NavigateToCommissionSeat(seat))"
                                                                  Title="View Commission Seat Details" />
                                                </MudStack>
                                            </CardHeaderContent>
                                        </MudCardHeader>
                                        <MudCardContent>
                                            @if (seatCommissioners.Any())
                                            {
                                                <MudTable T="CommissionerProfile" Items="@seatCommissioners" Hover="true" Dense="true" Elevation="0">
                                                    <HeaderContent>
                                                        <MudTh>Person</MudTh>
                                                        <MudTh>Contact</MudTh>
                                                        <MudTh>Status</MudTh>
                                                        <MudTh>Appointed</MudTh>
                                                        <MudTh>End Date</MudTh>
                                                        <MudTh>Oath</MudTh>
                                                        <MudTh Style="width: 80px;">Actions</MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd DataLabel="Person">@GetFormattedPersonName(context.PersonProfileId)</MudTd>
                                                        <MudTd DataLabel="Contact">
                                                            @{
                                                                var correspondence = GetPublicCorrespondence(context.Id);
                                                            }
                                                            @if (correspondence.HasValue)
                                                            {
                                                                <MudStack Spacing="0">
                                                                    @if (!string.IsNullOrEmpty(correspondence.Value.EmailAddress))
                                                                    {
                                                                        <MudText Typo="Typo.caption">
                                                                            <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" /> @correspondence.Value.EmailAddress
                                                                        </MudText>
                                                                    }
                                                                    @if (!string.IsNullOrEmpty(correspondence.Value.PhoneNumber))
                                                                    {
                                                                        <MudText Typo="Typo.caption">
                                                                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> @correspondence.Value.PhoneNumber
                                                                        </MudText>
                                                                    }
                                                                </MudStack>
                                                            }
                                                            else
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">No public contact</MudText>
                                                            }
                                                        </MudTd>
                                                        <MudTd DataLabel="Status">
                                                            @{
                                                                var commissionerStatus = commissionerStatuses?.FirstOrDefault(s => s.Id == context.CommissionerStatusId);
                                                            }
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@commissionerStatus?.Status</MudChip>
                                                        </MudTd>
                                                        <MudTd DataLabel="Appointed">@(context.AppointedDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                                        <MudTd DataLabel="End Date">@(context.EndDate?.ToString("MMM d, yyyy") ?? "—")</MudTd>
                                                        <MudTd DataLabel="Oath">
                                                            @if (context.Oath == true)
                                                            {
                                                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                                            }
                                                            else
                                                            {
                                                                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" />
                                                            }
                                                        </MudTd>
                                                        <MudTd DataLabel="Actions">
                                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                                          Size="Size.Small" 
                                                                          Color="Color.Primary" 
                                                                          OnClick="@(() => NavigationManager.NavigateTo($"/commissioners?id={context.Id}"))"
                                                                          Title="View Details" />
                                                        </MudTd>
                                                    </RowTemplate>
                                                </MudTable>
                                            }
                                            else
                                            {
                                                <MudAlert Severity="Severity.Info" Dense="true">No commissioners assigned to this seat</MudAlert>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No commission seats for this service area.</MudText>
                            }
                        </MudStack>
                    }
                </MudExpansionPanel>
                <MudExpansionPanel Text="Request For Quotes"></MudExpansionPanel>
                <MudExpansionPanel Text="Roads">
                    @if (selectedServiceArea != null)
                    {
                        <MudStack Spacing="2">
                            @if (!string.IsNullOrEmpty(roadsErrorMessage))
                            {
                                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                                    @roadsErrorMessage
                                </MudAlert>
                            }

                            @if (isLoadingRoads)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (serviceAreaRoads != null && serviceAreaRoads.Any())
                            {
                                <MudTable T="Road" Items="@serviceAreaRoads" Hover="true" Striped="true" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Road Name</MudTh>
                                        <MudTh>Phase</MudTh>
                                        <MudTh>Distance (Feet)</MudTh>
                                        <MudTh>Start Description</MudTh>
                                        <MudTh>End Description</MudTh>
                                        <MudTh>Approved for Maintenance</MudTh>
                                        <MudTh Style="width: 100px;">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Road Name">
                                            @{
                                                var roadName = roadNames?.FirstOrDefault(rn => rn.Id == context.RoadNameId);
                                                @(roadName?.Name ?? "—")
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Phase">@(context.Phase?.ToString() ?? "—")</MudTd>
                                        <MudTd DataLabel="Distance (Feet)">@(context.DistanceFeet?.ToString("N2") ?? "—")</MudTd>
                                        <MudTd DataLabel="Start Description">@(context.StartDescription ?? "—")</MudTd>
                                        <MudTd DataLabel="End Description">@(context.EndDescription ?? "—")</MudTd>
                                        <MudTd DataLabel="Approved for Maintenance">
                                            @if (context.ApprovedForMaintenance == true)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Check">Yes</MudChip>
                                            }
                                            else if (context.ApprovedForMaintenance == false)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Close">No</MudChip>
                                            }
                                            else
                                            {
                                                <MudText>—</MudText>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" 
                                                          Size="Size.Small" 
                                                          Color="Color.Primary" 
                                                          OnClick="@(() => NavigateToRoad(context))"
                                                          Title="View Road Details" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="my-4">No roads found for this service area.</MudText>
                            }
                        </MudStack>
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Align="Align.Center">Select a service area from the list to view details</MudText>
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int? ServiceAreaId { get; set; }

    private IEnumerable<ServiceArea>? serviceAreas;
    private IEnumerable<ServiceAreaCode>? serviceAreaCodes;
    private ServiceArea? selectedServiceArea;
    private bool isLoading = false;
    private bool isSaving = false;
    private bool isEditMode = false;
    private bool canEdit = false;
    private string? errorMessage;
    private string[]? errorDetails;
    private string? successMessage;
    private ServiceArea? editModel;
    private string _searchString = string.Empty;
    private EditContext? editContext;

    // Version navigation fields
    private IEnumerable<ServiceArea>? allVersions;
    private ServiceArea? currentViewVersion;
    private bool isLoadingHistory = false;
    private string? historyErrorMessage;

    // Map fields
    private bool showRoadsOnMap = false;
    private FeatureLayerMap? _mapRef;

    // Ordinances management fields
    private IEnumerable<Ordinance>? serviceAreaOrdinances;
    private IEnumerable<OrdinanceType>? ordinanceTypes;
    private bool isLoadingOrdinances = false;

    // Commission Seats management fields
    private IEnumerable<CommissionSeat>? commissionSeats;
    private IEnumerable<CommissionSeatType>? commissionSeatTypes;
    private IEnumerable<CommissionSeatClass>? commissionSeatClasses;
    private IEnumerable<CommissionSeatStatus>? commissionSeatStatuses;
    private bool isLoadingCommissionSeats = false;

    // Commissioners management fields
    private IEnumerable<CommissionerProfile>? commissioners;
    private IEnumerable<CommissionerStatus>? commissionerStatuses;
    private bool isLoadingCommissioners = false;

    // Correspondence data
    private IEnumerable<CorrespondenceProfile>? correspondenceProfiles;
    private IEnumerable<CorrespondencePhone>? correspondencePhones;
    private IEnumerable<CorrespondenceEmail>? correspondenceEmails;

    // Person data
    private IEnumerable<PersonProfile>? personProfiles;
    private IEnumerable<PersonHonorific>? personHonorifics;
    private IEnumerable<PersonSuffix>? personSuffixes;

    // Roads management fields
    private IEnumerable<Road>? serviceAreaRoads;
    private IEnumerable<RoadName>? roadNames;
    private bool isLoadingRoads = false;
    private string? roadsErrorMessage;

    // Permission flags
    private bool isEditor = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadServiceAreas();
        await LoadServiceAreaCodes();
        await LoadOrdinanceTypes();
        await LoadCommissionSeatLookups();
        await LoadCommissionerStatusLookups();
        await LoadRoadNames();
        await CheckEditPermission();
        SelectServiceAreaFromParameters();
    }

    protected override void OnParametersSet()
    {
        SelectServiceAreaFromParameters();
    }

    private async Task CheckEditPermission()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            canEdit = user.Identity?.IsAuthenticated == true && 
                      (user.IsInRole("fnsbuser") || user.IsInRole("admin"));

            // Check if user has editor role (can see UKN and inactive items)
            isEditor = user.Identity?.IsAuthenticated == true && 
                      (user.IsInRole("editor") || user.IsInRole("admin"));
        }
        catch
        {
            canEdit = false;
            isEditor = false;
        }
    }

    private void SelectServiceAreaFromParameters()
    {
        if (serviceAreas == null || !serviceAreas.Any() || !ServiceAreaId.HasValue)
            return;

        var targetServiceArea = serviceAreas.FirstOrDefault(sa => sa.Id == ServiceAreaId.Value);

        if (targetServiceArea != null && selectedServiceArea?.Id != targetServiceArea.Id)
        {
            selectedServiceArea = targetServiceArea;
            isEditMode = false;
            ClearMessages();
            _ = LoadAllVersions();
        }
    }

    private async Task LoadServiceAreas()
    {
        isLoading = true;
        errorMessage = null;
        errorDetails = null;
        successMessage = null;

        try
        {
            var result = await ServiceAreasApi.GetAllServiceAreasAsync();

            if (result?.IsSuccess == true && result.Data != null)
            {
                serviceAreas = result.Data;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to load service areas";
                errorDetails = result?.Errors;
                serviceAreas = Array.Empty<ServiceArea>();
            }
        }
        catch (HttpRequestException ex)
        {
            errorMessage = "Network error. Please check your connection and try again.";
            serviceAreas = Array.Empty<ServiceArea>();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
            serviceAreas = Array.Empty<ServiceArea>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadServiceAreaCodes()
    {
        try
        {
            var result = await ServiceAreaCodesApi.GetAllServiceAreaCodesAsync();

            if (result?.IsSuccess == true && result.Data != null)
            {
                serviceAreaCodes = result.Data;
            }
            else
            {
                serviceAreaCodes = Array.Empty<ServiceAreaCode>();
            }
        }
        catch (Exception)
        {
            serviceAreaCodes = Array.Empty<ServiceAreaCode>();
        }
    }

    private async Task LoadServiceAreaOrdinances()
    {
        if (selectedServiceArea == null) return;

        isLoadingOrdinances = true;

        try
        {
            var result = await OrdinancesApi.GetOrdinancesByServiceAreaAsync(selectedServiceArea.Id);

            if (result?.IsSuccess == true && result.Data != null)
            {
                serviceAreaOrdinances = result.Data;
            }
            else
            {
                serviceAreaOrdinances = Array.Empty<Ordinance>();
            }
        }
        catch (Exception)
        {
            serviceAreaOrdinances = Array.Empty<Ordinance>();
        }
        finally
        {
            isLoadingOrdinances = false;
        }
    }

    private async Task LoadOrdinanceTypes()
    {
        try
        {
            var result = await OrdinanceTypesApi.GetAllOrdinanceTypesAsync();

            if (result?.IsSuccess == true && result.Data != null)
            {
                ordinanceTypes = result.Data;
            }
            else
            {
                ordinanceTypes = Array.Empty<OrdinanceType>();
            }
        }
        catch (Exception)
        {
            ordinanceTypes = Array.Empty<OrdinanceType>();
        }
    }

    private async Task LoadCommissionSeats()
    {
        if (selectedServiceArea == null) return;

        isLoadingCommissionSeats = true;

        try
        {
            var result = await CommissionSeatsApi.GetCommissionSeatsByServiceAreaAsync(selectedServiceArea.Id);

            if (result?.IsSuccess == true && result.Data != null)
            {
                commissionSeats = result.Data;
                await LoadCommissioners();
            }
            else
            {
                commissionSeats = Array.Empty<CommissionSeat>();
                commissioners = Array.Empty<CommissionerProfile>();
            }
        }
        catch (Exception)
        {
            commissionSeats = Array.Empty<CommissionSeat>();
            commissioners = Array.Empty<CommissionerProfile>();
        }
        finally
        {
            isLoadingCommissionSeats = false;
        }
    }

    private async Task LoadCommissionSeatLookups()
    {
        try
        {
            var typesTask = CommissionSeatTypesApi.GetAllCommissionSeatTypesAsync();
            var classesTask = CommissionSeatClassesApi.GetAllCommissionSeatClassesAsync();
            var statusesTask = CommissionSeatStatusesApi.GetAllCommissionSeatStatusesAsync();

            await Task.WhenAll(typesTask, classesTask, statusesTask);

            commissionSeatTypes = (await typesTask)?.Data ?? Array.Empty<CommissionSeatType>();
            commissionSeatClasses = (await classesTask)?.Data ?? Array.Empty<CommissionSeatClass>();
            commissionSeatStatuses = (await statusesTask)?.Data ?? Array.Empty<CommissionSeatStatus>();
        }
        catch (Exception)
        {
            commissionSeatTypes = Array.Empty<CommissionSeatType>();
            commissionSeatClasses = Array.Empty<CommissionSeatClass>();
            commissionSeatStatuses = Array.Empty<CommissionSeatStatus>();
        }
    }

    private async Task LoadCommissioners()
    {
        if (commissionSeats == null || !commissionSeats.Any()) 
        {
            commissioners = Array.Empty<CommissionerProfile>();
            return;
        }

        isLoadingCommissioners = true;

        try
        {
            var allCommissionersTask = CommissionerProfilesApi.GetAllCommissionerProfilesAsync();
            var correspondenceProfilesTask = CorrespondenceProfilesApi.GetAllCorrespondenceProfilesAsync();
            var correspondencePhonesTask = CorrespondencePhonesApi.GetAllCorrespondencePhonesAsync();
            var correspondenceEmailsTask = CorrespondenceEmailsApi.GetAllCorrespondenceEmailsAsync();
            var personProfilesTask = PersonProfilesApi.GetAllPersonProfilesAsync();
            var personHonorificsTask = PersonHonorificsApi.GetAllPersonHonorificsAsync();
            var personSuffixesTask = PersonSuffixesApi.GetAllPersonSuffixesAsync();

            await Task.WhenAll(
                allCommissionersTask, 
                correspondenceProfilesTask, 
                correspondencePhonesTask, 
                correspondenceEmailsTask,
                personProfilesTask,
                personHonorificsTask,
                personSuffixesTask);

            var allCommissionersResult = await allCommissionersTask;

            if (allCommissionersResult?.IsSuccess == true && allCommissionersResult.Data != null)
            {
                // Filter commissioners that belong to seats in this service area
                var seatIds = commissionSeats.Select(s => s.Id).ToHashSet();
                commissioners = allCommissionersResult.Data
                    .Where(c => seatIds.Contains(c.CommissionSeatId))
                    .ToList();
            }
            else
            {
                commissioners = Array.Empty<CommissionerProfile>();
            }

            // Load correspondence data
            var correspondenceProfilesResult = await correspondenceProfilesTask;
            correspondenceProfiles = correspondenceProfilesResult?.Data ?? Array.Empty<CorrespondenceProfile>();

            var correspondencePhonesResult = await correspondencePhonesTask;
            correspondencePhones = correspondencePhonesResult?.Data ?? Array.Empty<CorrespondencePhone>();

            var correspondenceEmailsResult = await correspondenceEmailsTask;
            correspondenceEmails = correspondenceEmailsResult?.Data ?? Array.Empty<CorrespondenceEmail>();

            // Load person data
            var personProfilesResult = await personProfilesTask;
            personProfiles = personProfilesResult?.Data ?? Array.Empty<PersonProfile>();

            var personHonorificsResult = await personHonorificsTask;
            personHonorifics = personHonorificsResult?.Data ?? Array.Empty<PersonHonorific>();

            var personSuffixesResult = await personSuffixesTask;
            personSuffixes = personSuffixesResult?.Data ?? Array.Empty<PersonSuffix>();
        }
        catch (Exception)
        {
            commissioners = Array.Empty<CommissionerProfile>();
            correspondenceProfiles = Array.Empty<CorrespondenceProfile>();
            correspondencePhones = Array.Empty<CorrespondencePhone>();
            correspondenceEmails = Array.Empty<CorrespondenceEmail>();
            personProfiles = Array.Empty<PersonProfile>();
            personHonorifics = Array.Empty<PersonHonorific>();
            personSuffixes = Array.Empty<PersonSuffix>();
        }
        finally
        {
            isLoadingCommissioners = false;
        }
    }

    private async Task LoadCommissionerStatusLookups()
    {
        try
        {
            var result = await CommissionerStatusesApi.GetAllCommissionerStatusesAsync();
            commissionerStatuses = result?.Data ?? Array.Empty<CommissionerStatus>();
        }
        catch (Exception)
        {
            commissionerStatuses = Array.Empty<CommissionerStatus>();
        }
    }

    private async Task LoadAllVersions()
    {
        if (selectedServiceArea == null) return;

        isLoadingHistory = true;
        historyErrorMessage = null;

        try
        {
            // Load history
            var historyResult = await ServiceAreasApi.GetServiceAreaHistoryAsync(selectedServiceArea.Id);
            var historyRecords = new List<ServiceArea>();

            if (historyResult?.IsSuccess == true && historyResult.Data != null)
            {
                historyRecords.AddRange(historyResult.Data);
            }

            // Combine current with history
            var versions = new List<ServiceArea> { selectedServiceArea };
            versions.AddRange(historyRecords.Where(h => h.ValidFrom != selectedServiceArea.ValidFrom));
            
            allVersions = versions;
            
            // Set the current version as the view version
            currentViewVersion = selectedServiceArea;
            UpdateEditModel(currentViewVersion);

            // Load related data for this service area
            await LoadServiceAreaOrdinances();
            await LoadOrdinanceTypes();
            await LoadCommissionSeats();
            await LoadServiceAreaRoads();
        }
        catch (Exception ex)
        {
            historyErrorMessage = $"Error loading versions: {ex.Message}";
            allVersions = new List<ServiceArea> { selectedServiceArea };
            currentViewVersion = selectedServiceArea;
            UpdateEditModel(currentViewVersion);
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private async Task OnCurrentVersionChanged(ServiceArea newVersion)
    {
        currentViewVersion = newVersion;
        UpdateEditModel(newVersion);
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateEditModel(ServiceArea version)
    {
        editModel = CloneServiceArea(version);
        editContext = new EditContext(editModel);
        
        // Cancel edit mode when viewing historical versions
        if (!IsViewingCurrentVersion())
        {
            isEditMode = false;
        }
    }

    private bool IsViewingCurrentVersion()
    {
        if (currentViewVersion == null || selectedServiceArea == null)
            return true;

        return currentViewVersion.ValidFrom == selectedServiceArea.ValidFrom;
    }

    private bool CanEditFields()
    {
        return isEditMode && IsViewingCurrentVersion();
    }

    private async Task RowClicked(DataGridRowClickEventArgs<ServiceArea> args)
    {
        selectedServiceArea = args.Item;
        isEditMode = false;
        ClearMessages();
        await LoadAllVersions();
        await InvokeAsync(StateHasChanged);

        // Update URL with the selected service area ID
        var uri = NavigationManager.GetUriWithQueryParameter("id", selectedServiceArea.Id);
        NavigationManager.NavigateTo(uri, replace: true);
    }

    private async Task HandleRestore(ServiceArea historicalRecord)
    {
        if (selectedServiceArea == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            // Clone the historical record but keep the current ID
            var restoredData = CloneServiceArea(historicalRecord);
            restoredData.Id = selectedServiceArea.Id;

            var result = await ServiceAreasApi.UpdateServiceAreaAsync(restoredData.Id, restoredData);

            if (result?.IsSuccess == true)
            {
                successMessage = $"Successfully restored version from {historicalRecord.ValidFrom:g}";
                
                // Reload all data
                await LoadServiceAreas();
                
                // Update the current selection
                selectedServiceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == selectedServiceArea.Id);
                if (selectedServiceArea != null)
                {
                    await LoadAllVersions();
                }
                
                isEditMode = false;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to restore historical version";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error restoring historical version: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void EnableEdit()
    {
        if (!IsViewingCurrentVersion())
        {
            // Navigate to current version before editing
            if (selectedServiceArea != null)
            {
                currentViewVersion = selectedServiceArea;
                UpdateEditModel(currentViewVersion);
            }
        }
        
        isEditMode = true;
        ClearMessages();
    }

    private async Task SaveEdit()
    {
        if (editModel == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var result = await ServiceAreasApi.UpdateServiceAreaAsync(editModel.Id, editModel);

            if (result?.IsSuccess == true)
            {
                successMessage = "Service area updated successfully!";
                isEditMode = false;
                
                // Reload data
                await LoadServiceAreas();
                selectedServiceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == editModel.Id);
                
                if (selectedServiceArea != null)
                {
                    await LoadAllVersions();
                }
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to update service area";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating service area: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelEdit()
    {
        if (currentViewVersion != null)
        {
            editModel = CloneServiceArea(currentViewVersion);
            editContext = new EditContext(editModel);
        }
        isEditMode = false;
        ClearMessages();
    }

    private void ClearMessages()
    {
        errorMessage = null;
        errorDetails = null;
        successMessage = null;
    }

    private ServiceArea CloneServiceArea(ServiceArea source) => new()
    {
        Id = source.Id,
        Name = source.Name,
        FeatureObjectId = source.FeatureObjectId,
        OrgKey = source.OrgKey,
        CurrentMileage = source.CurrentMileage,
        AbolishMergeYear = source.AbolishMergeYear,
        MaximumMillRate = source.MaximumMillRate,
        CurrentMillRate = source.CurrentMillRate,
        FireMillRate = source.FireMillRate,
        MillLevy = source.MillLevy,
        TaxAuthorityCode = source.TaxAuthorityCode,
        InitialTaxYear = source.InitialTaxYear,
        MatchFeatureLayer = source.MatchFeatureLayer,
        ServiceAreaCodeId = source.ServiceAreaCodeId,
        ValidFrom = source.ValidFrom,
        ValidTo = source.ValidTo,
        ModifiedBy = source.ModifiedBy
    };

    private Func<ServiceArea, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return x.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true;
    };

    private async Task<bool> CreateServiceAreaCode(ServiceAreaCode entity)
    {
        var result = await ServiceAreaCodesApi.CreateServiceAreaCodeAsync(entity);
        return result?.IsSuccess ?? false;
    }

    private async Task<bool> UpdateServiceAreaCode(ServiceAreaCode entity)
    {
        var result = await ServiceAreaCodesApi.UpdateServiceAreaCodeAsync(entity.Id, entity);
        return result?.IsSuccess ?? false;
    }

    private async Task<bool> DeleteServiceAreaCode(ServiceAreaCode entity)
    {
        var result = await ServiceAreaCodesApi.DeleteServiceAreaCodeAsync(entity.Id);
        return result?.IsSuccess ?? false;
    }

    // Map helper methods
    private string? GetFeatureLayerUrl()
    {
        // TODO: Replace with your actual ArcGIS Feature Service URL
        // Example: "https://services.arcgis.com/your-org/arcgis/rest/services/ServiceAreas/FeatureServer/0"
        return Configuration.GetValue<string>("FeatureLayer:ServiceAreasUrl");
    }

    private string? GetRoadsLayerUrl()
    {
        return Configuration.GetValue<string>("FeatureLayer:RoadsUrl");
    }

    private Dictionary<string, string>? GetMapQueryParameters()
    {
        if (selectedServiceArea?.FeatureObjectId == null)
            return null;

        return new Dictionary<string, string>
        {
            { "where", $"OBJECTID = {selectedServiceArea.FeatureObjectId}" },
            { "outFields", "*" },
            { "returnGeometry", "true" }
        };
    }

    private async Task OpenLinkOrdinanceDialog()
    {
        if (selectedServiceArea == null) return;

        // Get ALL ordinances (not just unlinked ones, since service_area_id is required)
        var allOrdinancesResult = await OrdinancesApi.GetAllOrdinancesAsync();

        if (allOrdinancesResult?.IsSuccess != true || allOrdinancesResult.Data == null)
        {
            errorMessage = "Failed to load available ordinances";
            return;
        }

        // Exclude ordinances already linked to THIS service area
        var availableOrdinances = allOrdinancesResult.Data
            .Where(o => o.ServiceAreaId != selectedServiceArea.Id)
            .ToList();

        if (!availableOrdinances.Any())
        {
            errorMessage = "All ordinances are already linked to this service area";
            return;
        }

        var parameters = new DialogParameters<LinkOrdinanceDialog>
        {
            { x => x.AvailableOrdinances, availableOrdinances },
            { x => x.OrdinanceTypes, ordinanceTypes },
            { x => x.AllServiceAreas, serviceAreas },
            { x => x.TargetServiceAreaName, selectedServiceArea.Name }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LinkOrdinanceDialog>("Link Ordinance to Service Area", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Ordinance selectedOrdinance)
        {
            await LinkOrdinanceToServiceArea(selectedOrdinance);
        }
    }

    private async Task LinkOrdinanceToServiceArea(Ordinance ordinance)
    {
        if (selectedServiceArea == null) return;

        isSaving = true;
        ClearMessages();

        try
        {
            var oldServiceAreaId = ordinance.ServiceAreaId;
            var oldServiceAreaName = serviceAreas?.FirstOrDefault(sa => sa.Id == oldServiceAreaId)?.Name ?? "Unknown";

            // Update the ordinance to link it to this service area
            ordinance.ServiceAreaId = selectedServiceArea.Id;
            var result = await OrdinancesApi.UpdateOrdinanceAsync(ordinance.Id, ordinance);

            if (result?.IsSuccess == true)
            {
                if (oldServiceAreaId.HasValue && oldServiceAreaId != selectedServiceArea.Id)
                {
                    successMessage = $"Successfully transferred ordinance '{ordinance.OrdinanceName}' from {oldServiceAreaName} to {selectedServiceArea.Name}";
                }
                else
                {
                    successMessage = $"Successfully linked ordinance '{ordinance.OrdinanceName}' to {selectedServiceArea.Name}";
                }

                await LoadServiceAreaOrdinances();
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "Failed to link ordinance";
                errorDetails = result?.Errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error linking ordinance: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

