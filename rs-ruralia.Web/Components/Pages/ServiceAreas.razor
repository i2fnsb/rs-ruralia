    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<CreateEntityDialog<ServiceArea>>
        {
            { x => x.EntityDisplayName, "Service Area" },
            { x => x.Description, "Create a new service area record. All fields marked with * are required." },
            { x => x.OnCreate, new Func<ServiceArea, Task<(bool, string?, string[]?)>>(CreateServiceArea) },
            { x => x.AutoSetModifiedBy, true },
            { x => x.FormContent, GetServiceAreaFormContent() }
        };

        var options = new DialogOptions 
        { 
            CloseButton = true, 
            MaxWidth = MaxWidth.Large, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<CreateEntityDialog<ServiceArea>>("Create New Service Area", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ServiceArea createdServiceArea)
        {
            // Reload service areas to include the new one
            await LoadServiceAreas();

            // Select the newly created service area
            selectedServiceArea = serviceAreas?.FirstOrDefault(sa => sa.Id == createdServiceArea.Id);
            if (selectedServiceArea != null)
            {
                await LoadAllVersions();

                NavigationHelper.UpdateUrlWithSelection(NavigationManager, selectedServiceArea.Id);
            }

            successMessage = $"Service area '{createdServiceArea.Name}' created successfully!";
            await InvokeAsync(StateHasChanged);
        }
    }

