    private void CalculateCurrentMileage()
    {
        if (editModel == null || serviceAreaRoads == null || !serviceAreaRoads.Any())
            return;

        // Sum all DistanceFeet values from linked roads
        var totalFeet = serviceAreaRoads
            .Where(r => r.DistanceFeet.HasValue)
            .Sum(r => r.DistanceFeet!.Value);

        // Convert feet to miles (1 mile = 5280 feet)
        var totalMiles = totalFeet / 5280.0m;

        // Update the CurrentMileage field
        editModel.CurrentMileage = Math.Round(totalMiles, 3);

        // Trigger state change to update UI
        StateHasChanged();
    }

    private async Task LoadServiceAreaRfqs()
    {
        if (selectedServiceArea == null) return;

        isLoadingRfqs = true;
        rfqsErrorMessage = null;

        var allRfqs = await DataLoaderHelper.LoadDataWithErrorHandlingAsync(
            () => RfqsApi.GetAllRfqsAsync(),
            onError: (error, errors) => rfqsErrorMessage = error ?? "Failed to load RFQs");

        serviceAreaRfqs = allRfqs
            .Where(r => r.ServiceAreaId == selectedServiceArea.Id)
            .OrderByDescending(r => r.IssueDate)
            .ThenBy(r => r.RfqNumber)
            .ToList();

        isLoadingRfqs = false;
    }

