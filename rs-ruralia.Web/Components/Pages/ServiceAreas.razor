    // Helper methods for ordering and grouping
    private IEnumerable<CommissionSeat> GetOrderedCommissionSeats()
    {
        if (commissionSeats == null || !commissionSeats.Any())
            return Enumerable.Empty<CommissionSeat>();

        var filteredSeats = commissionSeats.AsEnumerable();

        // Filter out UKN class seats if user is not an editor
        if (!isEditor)
        {
            filteredSeats = filteredSeats.Where(seat => !IsUnknownClass(seat.CommissionSeatClassId));
        }

        return filteredSeats
            .OrderBy(seat => IsUnknownClass(seat.CommissionSeatClassId) ? 1 : 0) // UKN class at bottom
            .ThenBy(seat => GetSeatTypeSortOrder(seat.CommissionSeatTypeId))
            .ThenBy(seat => commissionSeatClasses?.FirstOrDefault(c => c.Id == seat.CommissionSeatClassId)?.Class ?? "")
            .ToList();
    }

    private bool IsUnknownClass(int classId)
    {
        var seatClass = commissionSeatClasses?.FirstOrDefault(c => c.Id == classId);
        var className = seatClass?.Class?.ToUpperInvariant() ?? "";
        return className.Contains("UKN") || className.Contains("UNKNOWN");
    }

    private int GetSeatTypeSortOrder(int seatTypeId)
    {
        var seatType = commissionSeatTypes?.FirstOrDefault(t => t.Id == seatTypeId);
        var typeName = seatType?.Type?.ToLowerInvariant() ?? "";

        // Order: 1) Commission Chair, 2) Commission (by Class), 3) Alternate Commissioner
        if (typeName.Contains("chair") && !typeName.Contains("alternate"))
            return 1; // Commission Chair
        else if (typeName.Contains("alternate"))
            return 3; // Alternate Commissioner
        else if (typeName.Contains("commission"))
            return 2; // Regular Commission seat
        else
            return 4; // Other types
    }

    private IEnumerable<CommissionerProfile> GetCommissionersForSeat(int seatId)
    {
        if (commissioners == null)
            return Enumerable.Empty<CommissionerProfile>();

        var seatCommissioners = commissioners.Where(c => c.CommissionSeatId == seatId);

        // Filter out inactive commissioners if user is not an editor
        if (!isEditor)
        {
            seatCommissioners = seatCommissioners.Where(c =>
            {
                var status = commissionerStatuses?.FirstOrDefault(s => s.Id == c.CommissionerStatusId);
                return status?.Active == true;
            });
        }

        return seatCommissioners
            .OrderBy(c => c.CommissionerStatusId)
            .ToList();
    }

    private (string? PhoneNumber, string? EmailAddress)? GetPublicCorrespondence(int commissionerProfileId)
    {
        // Find correspondence profile for this commissioner where public_profile = 1
        var correspondence = correspondenceProfiles?
            .FirstOrDefault(cp => cp.CommissionerProfileId == commissionerProfileId && cp.PublicProfile == true);

        if (correspondence == null)
            return null;

        // Get phone number if enabled
        string? phoneNumber = null;
        if (correspondence.Phone == true && correspondence.CorrespondencePhoneId.HasValue)
        {
            var phone = correspondencePhones?.FirstOrDefault(p => p.Id == correspondence.CorrespondencePhoneId);
            phoneNumber = phone?.Number;
        }

        // Get email address if enabled
        string? emailAddress = null;
        if (correspondence.Email == true && correspondence.CorrespondenceEmailId.HasValue)
        {
            var email = correspondenceEmails?.FirstOrDefault(e => e.Id == correspondence.CorrespondenceEmailId);
            emailAddress = email?.Email;
        }

        // Only return if we have at least one contact method
        if (!string.IsNullOrEmpty(phoneNumber) || !string.IsNullOrEmpty(emailAddress))
        {
            return (phoneNumber, emailAddress);
        }

        return null;
    }

    private string GetFormattedPersonName(int personProfileId)
    {
        var person = personProfiles?.FirstOrDefault(p => p.Id == personProfileId);
        if (person == null)
            return $"Person ID: {personProfileId}";

        var nameParts = new List<string>();

        // Add honorific
        if (person.PersonHonorificId.HasValue)
        {
            var honorific = personHonorifics?.FirstOrDefault(h => h.Id == person.PersonHonorificId);
            if (!string.IsNullOrEmpty(honorific?.Honorific))
                nameParts.Add(honorific.Honorific);
        }

        // Add first name
        if (!string.IsNullOrEmpty(person.FirstName))
            nameParts.Add(person.FirstName);

        // Add preferred name in quotes
        if (!string.IsNullOrEmpty(person.PreferredName))
            nameParts.Add($"\"{person.PreferredName}\"");

        // Add last name
        if (!string.IsNullOrEmpty(person.LastName))
            nameParts.Add(person.LastName);

        // Add suffix
        if (person.PersonSuffixId.HasValue)
        {
            var suffix = personSuffixes?.FirstOrDefault(s => s.Id == person.PersonSuffixId);
            if (!string.IsNullOrEmpty(suffix?.Suffix))
                nameParts.Add(suffix.Suffix);
        }

        return nameParts.Any() ? string.Join(" ", nameParts) : $"Person ID: {personProfileId}";
    }

    private async Task LoadServiceAreaRoads()
    {
        if (selectedServiceArea == null) return;

        isLoadingRoads = true;
        roadsErrorMessage = null;

        try
        {
            var result = await RoadsApi.GetAllRoadsAsync();

            if (result?.IsSuccess == true && result.Data != null)
            {
                var allRoads = result.Data.ToList();

                // Filter roads by the selected service area
                serviceAreaRoads = allRoads
                    .Where(r => r.ServiceAreaId == selectedServiceArea.Id)
                    .OrderBy(r => roadNames?.FirstOrDefault(rn => rn.Id == r.RoadNameId)?.Name ?? "")
                    .ThenBy(r => r.Phase)
                    .ToList();

                // Debug info: Log how many roads were found
                Console.WriteLine($"Total roads from API: {allRoads.Count}, Filtered for service area {selectedServiceArea.Id}: {serviceAreaRoads.Count()}");
            }
            else
            {
                roadsErrorMessage = result?.ErrorMessage ?? "Failed to load roads";
                serviceAreaRoads = Array.Empty<Road>();
            }
        }
        catch (HttpRequestException ex)
        {
            roadsErrorMessage = $"Network error loading roads: {ex.Message}";
            serviceAreaRoads = Array.Empty<Road>();
        }
        catch (Exception ex)
        {
            roadsErrorMessage = $"Error loading roads: {ex.Message}";
            serviceAreaRoads = Array.Empty<Road>();
        }
        finally
        {
            isLoadingRoads = false;
        }
    }

