@typeparam TValue

<MudCard Outlined="true" Class="@($"pa-3 {Class}")" Style="@Style">
    <MudCardContent>
        <MudStack Spacing="1">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">
                    @Label
                </MudText>
                @if (!string.IsNullOrEmpty(Icon))
                {
                    <MudIcon Icon="@Icon" Size="Size.Small" Color="Color.Secondary" />
                }
            </MudStack>
            <MudText Typo="@ValueTypo" Style="@ValueStyle">
                @if (ValueContent != null)
                {
                    @ValueContent
                }
                else
                {
                    @(Value?.ToString() ?? EmptyText)
                }
            </MudText>
            @if (HelperText != null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @HelperText
                </MudText>
            }
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public TValue? Value { get; set; }

    [Parameter]
    public RenderFragment? ValueContent { get; set; }

    [Parameter]
    public string EmptyText { get; set; } = "—";

    [Parameter]
    public string? Icon { get; set; }

    [Parameter]
    public Typo ValueTypo { get; set; } = Typo.body1;

    [Parameter]
    public string? ValueStyle { get; set; } = "font-weight: 500;";

    [Parameter]
    public string? HelperText { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }
}
