@using MudBlazor
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                <MudText Typo="Typo.body2">
                    You've successfully updated <strong>@EntityName</strong>. 
                    Please provide a brief note describing the changes you made.
                </MudText>
            </MudAlert>

            <MudTextField @bind-Value="noteText"
                         Label="Change Note"
                         Variant="Variant.Outlined"
                         Lines="5"
                         Placeholder="@Placeholder"
                         HelperText="This note will be saved with the current timestamp for audit purposes"
                         AutoFocus="true"
                         Immediate="true" />

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" 
                   Variant="Variant.Text" 
                   Color="Color.Default">
            Skip
        </MudButton>
        <MudButton OnClick="Submit" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(noteText))"
                   StartIcon="@Icons.Material.Filled.Save">
            Save Note
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// The name of the entity being edited (e.g., "Service Area: Chena-Goldstream", "Road: Airport Way")
    /// </summary>
    [Parameter]
    public string EntityName { get; set; } = string.Empty;

    /// <summary>
    /// Optional custom placeholder text for the note field
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    private string noteText = string.Empty;
    private string? errorMessage;

    protected override void OnParametersSet()
    {
        // Set default placeholder if not provided
        if (string.IsNullOrEmpty(Placeholder))
        {
            Placeholder = "e.g., Updated rates, Corrected data entry error, Added new information, etc.";
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(noteText))
        {
            errorMessage = "Please enter a note before saving.";
            return;
        }

        MudDialog.Close(DialogResult.Ok(noteText));
    }
}
