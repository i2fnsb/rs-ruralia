@using rs_ruralia.Web.Authorization
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">rs_ruralia</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-plus-square-fill" aria-hidden="true"></span> Counter
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list-nested" aria-hidden="true"></span> Weather
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="service-areas">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Service Areas
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="service-areas-example">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Service Areas Example
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ordinances-example">
                <span class="bi bi-file-text-fill" aria-hidden="true"></span> Ordinances
            </NavLink>
        </div>

        <AuthorizeView Policy="@Policies.VendorOrAbove">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="vendor">
                    <span class="bi bi-briefcase-fill" aria-hidden="true"></span> Vendor
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Policy="@Policies.CommissionerOrAbove">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="commissioner">
                    <span class="bi bi-people-fill" aria-hidden="true"></span> Commissioner
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Policy="@Policies.FnsbUserOrAbove">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="fnsbuser">
                    <span class="bi bi-person-badge-fill" aria-hidden="true"></span> FNSB User
            </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Policy="@Policies.AdminOnly">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="bi bi-gear-fill" aria-hidden="true"></span> Admin
                </NavLink>
            </div>
        </AuthorizeView>

        <hr />

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <span class="nav-link disabled">
                        <span class="bi bi-person-circle" aria-hidden="true"></span> @context.User.Identity?.Name
                    </span>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="/api/auth/logout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="@($"Account/Login?ReturnUrl={Uri.EscapeDataString(NavigationManager.Uri)}")">
                        <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>
